<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-hashes'; script-src-attr 'unsafe-hashes'; style-src 'self' https: 'unsafe-hashes'; style-src-attr 'unsafe-hashes'">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>UIverse Animated Library System</title>

  <!-- Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />

  <!-- CSS -->
  <link rel="stylesheet" href="analytics-dashboard.css" />
</head>

<body>

  <!-- ================= SIDEBAR ================= -->

  <aside class="sidebar">

    <div class="logo">
      📚 UIverse Library
    </div>

    <nav>

      <a href="#" class="active">
        <i class="fa-solid fa-house"></i>
        Dashboard
      </a>

      <a href="#">
        <i class="fa-solid fa-book"></i>
        Books
      </a>

      <a href="#">
        <i class="fa-solid fa-users"></i>
        Members
      </a>

      <a href="#">
        <i class="fa-solid fa-bookmark"></i>
        Borrowed
      </a>

      <a href="#">
        <i class="fa-solid fa-chart-line"></i>
        Reports
      </a>

      <a href="#">
        <i class="fa-solid fa-gear"></i>
        Settings
      </a>

    </nav>

  </aside>

  <!-- ================= MAIN ================= -->

  <main class="main">

    <!-- ================= TOPBAR ================= -->

    <header class="topbar">

      <div>

        <h1>
          Animated Library Dashboard
        </h1>

        <p>
          Smart digital management for books, readers, and activity.
        </p>

      </div>

      <div class="topbar-actions">

        <div class="search-box">

          <i class="fa-solid fa-magnifying-glass"></i>

          <input
            type="text"
            placeholder="Search books, members..."
          />

        </div>

        <button class="top-btn">
          <i class="fa-solid fa-download"></i>
          Export
        </button>

        <button class="top-btn primary">
          <i class="fa-solid fa-plus"></i>
          Add Book
        </button>

      </div>

    </header>

    <!-- ================= HERO ================= -->

    <section class="hero-card">

      <div class="hero-content">

        <span class="hero-tag">
          DIGITAL KNOWLEDGE HUB
        </span>

        <h2>
          Explore Thousands <br />
          of Books Instantly
        </h2>

        <p>
          Manage readers, track borrowing history,
          and monitor library activity in real time.
        </p>

        <div class="hero-actions">

          <button class="hero-btn primary">
            Browse Collection
          </button>

          <button class="hero-btn">
            View Analytics
          </button>

        </div>

      </div>

      <div class="floating-books">

        <div class="book book1"></div>
        <div class="book book2"></div>
        <div class="book book3"></div>

      </div>

    </section>

    <!-- ================= STATS ================= -->

    <section class="stats-grid">

      <div class="stat-card">

        <div class="stat-icon purple">
          <i class="fa-solid fa-book-open"></i>
        </div>

        <div>

          <span class="stat-label">
            Total Books
          </span>

          <h2>
            18.4K
          </h2>

          <p class="positive">
            +8% this month
          </p>

        </div>

      </div>

      <div class="stat-card">

        <div class="stat-icon blue">
          <i class="fa-solid fa-users"></i>
        </div>

        <div>

          <span class="stat-label">
            Active Members
          </span>

          <h2>
            6.2K
          </h2>

          <p class="positive">
            +12% growth
          </p>

        </div>

      </div>

      <div class="stat-card">

        <div class="stat-icon green">
          <i class="fa-solid fa-bookmark"></i>
        </div>

        <div>

          <span class="stat-label">
            Borrowed Today
          </span>

          <h2>
            324
          </h2>

          <p class="positive">
            +5.6% increase
          </p>

        </div>

      </div>

      <div class="stat-card">

        <div class="stat-icon orange">
          <i class="fa-solid fa-clock"></i>
        </div>

        <div>

          <span class="stat-label">
            Late Returns
          </span>

          <h2>
            14
          </h2>

          <p class="negative">
            -2% from yesterday
          </p>

        </div>

      </div>

    </section>

    <!-- ================= CONTENT GRID ================= -->

    <section class="content-grid">

      <!-- Popular Books -->

      <div class="card large">

        <div class="card-header">

          <div>

            <h3>
              Popular Books
            </h3>

            <p>
              Most borrowed books this week
            </p>

          </div>

          <button class="menu-btn">
            <i class="fa-solid fa-ellipsis"></i>
          </button>

        </div>

        <div class="books-list">

          <div class="book-item">

            <div class="book-cover gradient1"></div>

            <div class="book-info">

              <h4>
                Atomic Habits
              </h4>

              <p>
                James Clear
              </p>

            </div>

            <span class="badge success">
              Available
            </span>

          </div>

          <div class="book-item">

            <div class="book-cover gradient2"></div>

            <div class="book-info">

              <h4>
                Rich Dad Poor Dad
              </h4>

              <p>
                Robert Kiyosaki
              </p>

            </div>

            <span class="badge warning">
              Limited
            </span>

          </div>

          <div class="book-item">

            <div class="book-cover gradient3"></div>

            <div class="book-info">

              <h4>
                Deep Work
              </h4>

              <p>
                Cal Newport
              </p>

            </div>

            <span class="badge failed">
              Borrowed
            </span>

          </div>

        </div>

      </div>

      <!-- Circular Chart -->

      <div class="card">

        <div class="card-header">

          <div>

            <h3>
              Reading Progress
            </h3>

            <p>
              Monthly engagement
            </p>

          </div>

        </div>

        <div class="progress-wrapper">

          <div class="progress-ring">

            <div class="progress-center">
              84%
            </div>

          </div>

        </div>

      </div>

    </section>

    <!-- ================= TABLE ================= -->

    <section class="table-card">

      <div class="card-header">

        <div>

          <h3>
            Recent Transactions
          </h3>

          <p>
            Latest library activities
          </p>

        </div>

      </div>

      <table>

        <thead>

          <tr>
            <th>Member</th>
            <th>Book</th>
            <th>Status</th>
            <th>Time</th>
          </tr>

        </thead>

        <tbody>

          <tr>
            <td>Alex Morgan</td>
            <td>The Psychology of Money</td>
            <td>
              <span class="badge success">
                Returned
              </span>
            </td>
            <td>5 mins ago</td>
          </tr>

          <tr>
            <td>Emma Watson</td>
            <td>Think Like a Monk</td>
            <td>
              <span class="badge warning">
                Borrowed
              </span>
            </td>
            <td>20 mins ago</td>
          </tr>

          <tr>
            <td>John Carter</td>
            <td>Clean Code</td>
            <td>
              <span class="badge success">
                Issued
              </span>
            </td>
            <td>1 hour ago</td>
          </tr>

          <tr>
            <td>Sophia Lee</td>
            <td>The Alchemist</td>
            <td>
              <span class="badge failed">
                Overdue
              </span>
            </td>
            <td>2 hours ago</td>
          </tr>

        </tbody>

      </table>

    </section>

  </main>

  <!-- JS -->
  <script src="analysis-dashboard.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>