<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
<!-- =====================================================
NAVBAR
===================================================== -->

<header class="navbar">

  <div class="search-bar">

    <i class="fa-solid fa-magnifying-glass"></i>

    <input
      type="text"
      placeholder="Search modal components..."
    >

  </div>

  <div class="nav-actions">

    <button class="outline-btn">
      Documentation
    </button>

    <button class="primary-btn">
      Explore UI
    </button>

  </div>

</header>

<!-- =====================================================
MAIN
===================================================== -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-badge">
      ✦ Premium Popup Components
    </div>

    <h1>
      Modern <span>Modal UI</span>
    </h1>

    <p>

      Explore beautiful popup modals,
      dialog windows, alerts and modern
      confirmation boxes crafted for
      premium interfaces.

    </p>

  </section>

  <!-- GRID -->

  <section class="modal-grid">

    <!-- CARD -->

    <div class="modal-card">

      <div class="card-icon orange">
        <i class="fa-solid fa-bolt"></i>
      </div>

      <span class="card-label">
        BASIC
      </span>

      <h2>
        Simple Modal
      </h2>

      <p>

        Minimal modern popup
        with smooth animation
        and glassmorphism UI.

      </p>

      <button
        class="open-modal"
        data-modal="modal1"
      >
        Open Modal
      </button>

    </div>

    <!-- CARD -->

    <div class="modal-card">

      <div class="card-icon purple">
        <i class="fa-solid fa-circle-check"></i>
      </div>

      <span class="card-label">
        SUCCESS
      </span>

      <h2>
        Success Modal
      </h2>

      <p>

        Premium success popup
        for actions, forms and
        verification messages.

      </p>

      <button
        class="open-modal"
        data-modal="modal2"
      >
        Open Modal
      </button>

    </div>

    <!-- CARD -->

    <div class="modal-card">

      <div class="card-icon blue">
        <i class="fa-solid fa-credit-card"></i>
      </div>

      <span class="card-label">
        PAYMENT
      </span>

      <h2>
        Payment Modal
      </h2>

      <p>

        Elegant payment dialog
        designed for premium
        dashboard experiences.

      </p>

      <button
        class="open-modal"
        data-modal="modal3"
      >
        Open Modal
      </button>

    </div>

  </section>

</main>

<!-- =====================================================
MODAL 1
===================================================== -->

<div
  class="modal-overlay"
  id="modal1"
>

  <div class="modal-box">

    <button class="close-modal">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="modal-icon orange">
      <i class="fa-solid fa-bolt"></i>
    </div>

    <h2>
      Premium Modal UI
    </h2>

    <p>

      This is a modern modal
      component crafted for
      UIverse design systems.

    </p>

    <div class="modal-actions">

      <button class="cancel-btn">
        Cancel
      </button>

      <button class="confirm-btn">
        Continue
      </button>

    </div>

  </div>

</div>

<!-- =====================================================
MODAL 2
===================================================== -->

<div
  class="modal-overlay"
  id="modal2"
>

  <div class="modal-box">

    <button class="close-modal">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="modal-icon green">
      <i class="fa-solid fa-circle-check"></i>
    </div>

    <h2>
      Payment Successful
    </h2>

    <p>

      Your subscription has
      been activated successfully.

    </p>

    <button class="full-btn">
      Done
    </button>

  </div>

</div>

<!-- =====================================================
MODAL 3
===================================================== -->

<div
  class="modal-overlay"
  id="modal3"
>

  <div class="modal-box payment-modal">

    <button class="close-modal">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="modal-icon blue">
      <i class="fa-solid fa-credit-card"></i>
    </div>

    <h2>
      Upgrade Plan
    </h2>

    <p>

      Unlock premium components
      and advanced UI kits.

    </p>

    <div class="payment-card">

      <span>
        Premium Pro
      </span>

      <strong>
        $29/mo
      </strong>

    </div>

    <button class="full-btn">
      Continue Payment
    </button>

  </div>

</div>

<script src="modal.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>