<!-- =========================================================
   NAVBAR
========================================================= -->

<header class="navbar" id="navbar">
  <button class="menu-toggle" onclick="toggleSidebar()">
    <i class="fa-solid fa-bars"></i>
  </button>
  <div class="logo">UIverse</div>
  <div class="search-bar">
    <i class="fa-solid fa-magnifying-glass search-icon"></i>
    <input type="text" id="searchInput" placeholder="Search components..." oninput="liveFilter(this.value)" />
    <kbd class="search-kbd">⌘K</kbd>
  </div>
  <div class="nav-right">
    <button class="nav-btn outline-nav-btn"><i class="fa-solid fa-plus"></i> Add Component</button>
    <button class="nav-btn primary-nav-btn"><i class="fa-solid fa-bookmark"></i> My Collection</button>
    <button id="darkModeToggle" class="theme-toggle"><i class="fa-solid fa-moon"></i></button>
  </div>
</header>
<!-- APP LAYOUT -->
  <div class="app-shell">
<!-- PAGE CONTENT -->
    <div class="page-shell">
      <!-- MAIN CONTENT -->
      <main class="main-content">

        <!-- HERO SECTION -->
        <section class="hero-panel">
          <div class="hero-copy">
            <span class="hero-badge">Premium Collection</span>
            <h1>Modern Command Palette Components</h1>
            <p>
              Discover premium spotlight search and command launcher patterns inspired by VS Code, Linear,
              Raycast, Notion, and ChatGPT desktop experiences.
            </p>
            <div class="hero-badges">
              <span class="pill">Keyboard Friendly</span>
              <span class="pill">Spotlight Search</span>
              <span class="pill">AI Inspired</span>
            </div>
            <div class="hero-actions">
              <button class="primary-btn">Explore Components</button>
              <button class="outline-btn">See Example</button>
            </div>
          </div>

          <div class="hero-preview">
            <div class="palette-modal">
              <div class="palette-header">
                <span>Search commands</span>
                <kbd>⌘K</kbd>
              </div>
              <div class="palette-search-panel">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="search" placeholder="Type a command or action..." aria-label="Hero command search" />
              </div>
              <div class="palette-suggestions">
                <div class="suggestion-row active">
                  <span class="suggestion-icon"><i class="fa-solid fa-terminal"></i></span>
                  <div>
                    <p class="suggestion-title">Open Command Palette</p>
                    <p class="suggestion-subtitle">Quick launch global actions and navigation.</p>
                  </div>
                  <kbd>⌘P</kbd>
                </div>
                <div class="suggestion-row">
                  <span class="suggestion-icon"><i class="fa-solid fa-lightbulb"></i></span>
                  <div>
                    <p class="suggestion-title">AI Search Assistant</p>
                    <p class="suggestion-subtitle">Generate instant prompts and smart actions.</p>
                  </div>
                  <kbd>AI</kbd>
                </div>
                <div class="suggestion-row">
                  <span class="suggestion-icon"><i class="fa-solid fa-file-lines"></i></span>
                  <div>
                    <p class="suggestion-title">Find file</p>
                    <p class="suggestion-subtitle">Locate components, pages, or docs fast.</p>
                  </div>
                  <kbd>F</kbd>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- FILTER BAR -->
        <section class="filter-panel" aria-label="Component filters">
          <div class="filter-title">
            <h2>Filter components</h2>
            <p>Choose a category to browse polished command palette demos.</p>
          </div>
          <div class="filter-actions">
            <button class="filter-chip active" type="button">All</button>
            <button class="filter-chip" type="button">Search</button>
            <button class="filter-chip" type="button">Spotlight</button>
            <button class="filter-chip" type="button">AI</button>
            <button class="filter-chip" type="button">Glassmorphism</button>
            <button class="filter-chip" type="button">Dark Mode</button>
          </div>
        </section>

        <!-- COMPONENTS GRID -->
        <section class="components-section" aria-label="Command palette components">
          <div class="section-header">
            <h2>Palette Component Library</h2>
            <p>Premium command palette templates ready for styling and interaction.</p>
          </div>

          <div class="component-grid">

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">VS Code style command menu</span>
                <span class="tag">Productivity</span>
              </div>
              <div class="card-preview card-preview-terminal">
                <div class="preview-search">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input type="search" placeholder="Search commands..." aria-label="VS Code command menu search" />
                </div>
                <div class="preview-group">
                  <span class="group-title">Navigation</span>
                  <ul>
                    <li class="command-row active"><i class="fa-solid fa-file-lines"></i> Open file <kbd>Ctrl+P</kbd></li>
                    <li class="command-row"><i class="fa-solid fa-cube"></i> Go to symbol <kbd>Ctrl+Shift+O</kbd></li>
                  </ul>
                </div>
                <div class="preview-group">
                  <span class="group-title">Workspace</span>
                  <ul>
                    <li class="command-row"><i class="fa-solid fa-gear"></i> Open settings <kbd>Ctrl+,</kbd></li>
                  </ul>
                </div>
              </div>
              <p>Classic palette layout with grouped command rows, active selection, and keyboard shortcuts.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Use pattern</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">AI assistant search palette</span>
                <span class="tag">AI</span>
              </div>
              <div class="card-preview card-preview-ai">
                <div class="preview-search">
                  <i class="fa-solid fa-robot"></i>
                  <input type="search" placeholder="Ask your assistant..." aria-label="AI assistant search" />
                </div>
                <div class="preview-suggestions">
                  <div class="ai-suggestion active">
                    <span class="suggestion-icon"><i class="fa-solid fa-brain"></i></span>
                    <div>
                      <p class="suggestion-title">Summarize meeting notes</p>
                      <p class="suggestion-subtitle">AI suggestion based on recent docs.</p>
                    </div>
                  </div>
                  <div class="ai-suggestion">
                    <span class="suggestion-icon"><i class="fa-solid fa-language"></i></span>
                    <div>
                      <p class="suggestion-title">Translate to Spanish</p>
                      <p class="suggestion-subtitle">Instant language support.</p>
                    </div>
                  </div>
                </div>
              </div>
              <p>AI-first palette with intelligent suggestions, grouped prompts, and quick action previews.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Copy code</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Spotlight search overlay</span>
                <span class="tag">Spotlight</span>
              </div>
              <div class="card-preview card-preview-spotlight">
                <div class="preview-overlay-header">
                  <span>Spotlight search</span>
                  <kbd>⌘</kbd><kbd>Space</kbd>
                </div>
                <div class="preview-search">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input type="search" placeholder="Search apps, commands, or docs" aria-label="Spotlight search" />
                </div>
                <ul class="preview-results">
                  <li class="command-row active"><i class="fa-solid fa-folder-open"></i> Open project settings</li>
                  <li class="command-row"><i class="fa-solid fa-comments"></i> Show chat history</li>
                </ul>
              </div>
              <p>Minimal overlay with instant search, grouped results, and highlighted active items.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Details</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Floating quick launcher</span>
                <span class="tag">Launcher</span>
              </div>
              <div class="card-preview card-preview-float">
                <div class="preview-floating-panel">
                  <div class="preview-search">
                    <i class="fa-solid fa-meteor"></i>
                    <input type="search" placeholder="Launch action..." aria-label="Floating launcher search" />
                  </div>
                  <div class="quick-actions">
                    <button type="button">New tab</button>
                    <button type="button">Create note</button>
                    <button type="button">Search files</button>
                  </div>
                </div>
              </div>
              <p>Floating palette with quick action buttons, compact search, and an effortless launcher layout.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Copy code</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Recent searches dropdown</span>
                <span class="tag">History</span>
              </div>
              <div class="card-preview card-preview-history">
                <div class="preview-search">
                  <i class="fa-solid fa-clock-rotate-left"></i>
                  <input type="search" placeholder="Search history..." aria-label="Recent search history" />
                </div>
                <div class="dropdown-list">
                  <div class="dropdown-group">
                    <span class="group-title">Recent</span>
                    <ul>
                      <li class="command-row">Open roadmap</li>
                      <li class="command-row">Switch workspace</li>
                      <li class="command-row">Run deploy</li>
                    </ul>
                  </div>
                </div>
              </div>
              <p>Recent history dropdown with searchable items and fast access to past commands.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Use pattern</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Keyboard shortcuts panel</span>
                <span class="tag">Workflow</span>
              </div>
              <div class="card-preview card-preview-shortcuts">
                <div class="shortcut-row">
                  <span><i class="fa-solid fa-magnifying-glass"></i> Search command</span>
                  <kbd>⌘</kbd><kbd>K</kbd>
                </div>
                <div class="shortcut-row">
                  <span><i class="fa-solid fa-file-code"></i> Find file</span>
                  <kbd>⌘</kbd><kbd>P</kbd>
                </div>
                <div class="shortcut-row">
                  <span><i class="fa-solid fa-bolt"></i> Run action</span>
                  <kbd>⌘</kbd><kbd>R</kbd>
                </div>
              </div>
              <p>Keyboard-focused panel with shortcut badges, command labels, and quick key guidance.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Details</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">File finder command menu</span>
                <span class="tag">Files</span>
              </div>
              <div class="card-preview card-preview-files">
                <div class="preview-search">
                  <i class="fa-solid fa-file-circle-plus"></i>
                  <input type="search" placeholder="Type file name..." aria-label="File finder search" />
                </div>
                <ul>
                  <li class="command-row active"><i class="fa-solid fa-file-code"></i> src/app/main.js <span class="file-path">/src/app</span></li>
                  <li class="command-row"><i class="fa-solid fa-file-alt"></i> README.md <span class="file-path">/docs</span></li>
                  <li class="command-row"><i class="fa-solid fa-file-lines"></i> package.json <span class="file-path">/</span></li>
                </ul>
              </div>
              <p>File finder menu with instant search, file previews, and grouped file commands.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Copy code</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Glassmorphism search overlay</span>
                <span class="tag">Glass</span>
              </div>
              <div class="card-preview card-preview-glass">
                <div class="preview-overlay-header">
                  <span>Glass overlay</span>
                  <span class="tag sm">Blur</span>
                </div>
                <div class="preview-search">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input type="search" placeholder="Search commands" aria-label="Glass command overlay search" />
                </div>
                <div class="preview-actions">
                  <button type="button">Recent</button>
                  <button type="button">Favorites</button>
                </div>
              </div>
              <p>Translucent glass palette with blurred background, pill actions, and soft focus.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Details</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Minimal command palette</span>
                <span class="tag">Minimal</span>
              </div>
              <div class="card-preview card-preview-minimal">
                <div class="preview-search">
                  <input type="search" placeholder="Type command..." aria-label="Minimal command palette search" />
                </div>
                <ul>
                  <li class="command-row active">Open command palette</li>
                  <li class="command-row">Toggle sidebar</li>
                  <li class="command-row">Run workflow</li>
                </ul>
              </div>
              <p>Minimal interface for fast command entry, understated visuals, and essential actions.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Copy code</button>
              </div>
            </article>

            <article class="component-card">
              <div class="card-meta">
                <span class="card-label">Dark premium search panel</span>
                <span class="tag">Dark</span>
              </div>
              <div class="card-preview card-preview-dark">
                <div class="preview-search dark-mode">
                  <i class="fa-solid fa-magnifying-glass"></i>
                  <input type="search" placeholder="Search premium commands" aria-label="Dark command panel search" />
                </div>
                <ul>
                  <li class="command-row active"><i class="fa-solid fa-star"></i> Open premium dashboard</li>
                  <li class="command-row"><i class="fa-solid fa-shield-alt"></i> Security scan</li>
                  <li class="command-row"><i class="fa-solid fa-sun"></i> Theme settings</li>
                </ul>
              </div>
              <p>Premium dark palette with neon highlights, command groups, and active item emphasis.</p>
              <div class="card-actions">
                <button type="button">Preview</button>
                <button type="button">Details</button>
              </div>
            </article>

          </div>
          <!-- =========================================
   NEON CYBER COMMAND PALETTE
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">Neon cyber palette</span>
    <span class="tag">Cyber</span>
  </div>

  <div class="card-preview card-preview-cyber">
    <div class="cyber-topbar">
      <span class="status-dot"></span>
      <span>System connected</span>
    </div>

    <div class="preview-search cyber-search">
      <i class="fa-solid fa-wave-square"></i>
      <input type="search" placeholder="Execute cyber command..." />
    </div>

    <ul class="cyber-command-list">
      <li class="command-row active">
        <i class="fa-solid fa-shield"></i>
        Initialize firewall
        <kbd>⌘F</kbd>
      </li>

      <li class="command-row">
        <i class="fa-solid fa-database"></i>
        Sync database
        <kbd>⌘D</kbd>
      </li>

      <li class="command-row">
        <i class="fa-solid fa-terminal"></i>
        Open terminal
        <kbd>⌘T</kbd>
      </li>
    </ul>
  </div>

  <p>Futuristic neon-inspired command system with glowing interactions and terminal styling.</p>

  <div class="card-actions">
    <button>Preview</button>
    <button>Copy code</button>
  </div>
</article>

<!-- =========================================
   MUSIC PLAYER COMMAND PALETTE
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">Music command palette</span>
    <span class="tag">Music</span>
  </div>

  <div class="card-preview card-preview-music">

    <div class="music-header">
      <img src="https://images.unsplash.com/photo-1511379938547-c1f69419868d?q=80&w=300" alt="">
      <div>
        <h4>Midnight Echoes</h4>
        <span>Synthwave playlist</span>
      </div>
    </div>

    <div class="preview-search">
      <i class="fa-solid fa-headphones"></i>
      <input type="search" placeholder="Search tracks or artists..." />
    </div>

    <div class="music-actions">
      <button><i class="fa-solid fa-backward"></i></button>
      <button class="play-btn"><i class="fa-solid fa-play"></i></button>
      <button><i class="fa-solid fa-forward"></i></button>
    </div>

  </div>

  <p>Modern music-inspired palette with album preview, controls, and immersive search experience.</p>

  <div class="card-actions">
    <button>Preview</button>
    <button>Details</button>
  </div>
</article>

<!-- =========================================
   HOLOGRAM COMMAND PANEL
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">Hologram UI palette</span>
    <span class="tag">Hologram</span>
  </div>

  <div class="card-preview card-preview-holo">

    <div class="holo-circle"></div>

    <div class="preview-search">
      <i class="fa-solid fa-satellite-dish"></i>
      <input type="search" placeholder="Search holographic controls..." />
    </div>

    <div class="holo-actions">
      <button>Deploy</button>
      <button>Analyze</button>
      <button>Track</button>
    </div>

  </div>

  <p>Glass holographic panel with floating blur effects and futuristic command interactions.</p>

  <div class="card-actions">
    <button>Preview</button>
    <button>Use pattern</button>
  </div>
</article>

<!-- =========================================
   GAMING COMMAND MENU
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">Gaming action menu</span>
    <span class="tag">Gaming</span>
  </div>

  <div class="card-preview card-preview-gaming">

    <div class="gaming-level">
      <span>Level 42</span>
      <div class="xp-bar">
        <div class="xp-fill"></div>
      </div>
    </div>

    <div class="preview-search">
      <i class="fa-solid fa-gamepad"></i>
      <input type="search" placeholder="Search quests or inventory..." />
    </div>

    <ul class="gaming-actions">
      <li class="command-row active">⚔ Start battle mode</li>
      <li class="command-row">🎒 Open inventory</li>
      <li class="command-row">🗺 Explore map</li>
    </ul>

  </div>

  <p>Game-inspired UI featuring XP progress bars, quest actions, and immersive dark styling.</p>

  <div class="card-actions">
    <button>Preview</button>
    <button>Copy code</button>
  </div>
</article>

<!-- =========================================
   3D GLASS COMMAND CARD
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">3D glass palette</span>
    <span class="tag">3D</span>
  </div>

  <div class="card-preview card-preview-3d">

    <div class="glass-floating-card">

      <div class="preview-search">
        <i class="fa-solid fa-cube"></i>
        <input type="search" placeholder="Search floating commands..." />
      </div>

      <div class="floating-stats">
        <div>
          <strong>24</strong>
          <span>Commands</span>
        </div>

        <div>
          <strong>08</strong>
          <span>Projects</span>
        </div>

        <div>
          <strong>99%</strong>
          <span>Speed</span>
        </div>
      </div>

    </div>

  </div>

  <p>3D floating glassmorphism interface with soft shadows and premium dashboard aesthetics.</p>

  <div class="card-actions">
    <button>Preview</button>
    <button>Details</button>
  </div>
</article>

<!-- =========================================
   AI CHAT COMMAND CENTER
========================================= -->
<article class="component-card">
  <div class="card-meta">
    <span class="card-label">AI chat control panel</span>
