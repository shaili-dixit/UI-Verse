<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>

  <title>PulseWire — News Aggregator Dashboard</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

  <!-- CSS -->
  <link rel="stylesheet" href="news-aggregator-dashboard.css"/>
</head>

<body>

  <!-- ================= SIDEBAR ================= -->
  <aside class="sidebar" aria-label="Sidebar navigation">

    <div class="logo">
      📰 PulseWire
    </div>

    <nav class="sidebar-nav" aria-label="Main menu">

      <a href="#" class="active"><i class="fa-solid fa-house"></i> Dashboard</a>
      <a href="#"><i class="fa-solid fa-globe"></i> World News</a>
      <a href="#"><i class="fa-solid fa-chart-line"></i> Business</a>
      <a href="#"><i class="fa-solid fa-microchip"></i> Technology</a>
      <a href="#"><i class="fa-solid fa-football"></i> Sports</a>
      <a href="#"><i class="fa-solid fa-clapperboard"></i> Entertainment</a>
      <a href="#"><i class="fa-solid fa-bookmark"></i> Saved</a>
      <a href="#"><i class="fa-solid fa-gear"></i> Settings</a>

    </nav>

    <!-- USER PROFILE -->
    <div class="user-card" aria-label="User profile">

      <img src="https://i.pravatar.cc/100?img=15" alt="User avatar"/>

      <h3>Sophia Turner</h3>
      <p>Premium Subscriber</p>

      <button type="button">Manage Plan</button>

    </div>

  </aside>

  <!-- ================= MAIN ================= -->
  <main class="main">

    <!-- TOPBAR -->
    <header class="topbar">

      <div class="topbar-text">
        <h1>Stay Updated With Global News</h1>
        <p>Personalized headlines, live updates and trending stories.</p>
      </div>

      <div class="top-actions">

        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search articles, topics..." />
        </div>

        <button class="notification-btn" aria-label="Notifications">
          <i class="fa-solid fa-bell"></i>
        </button>

      </div>

    </header>

    <!-- ================= HERO ================= -->
    <section class="hero-banner">

      <div class="hero-content">

        <span class="hero-tag">Breaking News</span>

        <h2>AI Revolution Reshaping Modern Industries</h2>

        <p>
          Artificial Intelligence continues transforming healthcare,
          education, finance and global productivity at an unprecedented pace.
        </p>

        <div class="hero-buttons">
          <button class="read-btn">Read Full Story</button>
          <button class="save-btn">Save Article</button>
        </div>

      </div>

      <div class="hero-image">
        <img
          src="https://images.unsplash.com/photo-1495020689067-958852a7765e?q=80&w=1400&auto=format&fit=crop"
          alt="AI news banner"
        />
      </div>

    </section>

    <!-- ================= STATS ================= -->
    <section class="stats-grid">

      <article class="stat-card"><h2>12K+</h2><p>Daily Articles</p></article>
      <article class="stat-card"><h2>180+</h2><p>Trusted Sources</p></article>
      <article class="stat-card"><h2>95%</h2><p>Reader Satisfaction</p></article>
      <article class="stat-card"><h2>24/7</h2><p>Live Coverage</p></article>

    </section>

    <!-- ================= TRENDING ================= -->
    <section class="news-section">

      <div class="section-header">
        <h2>🔥 Trending Headlines</h2>
        <button type="button">View All</button>
      </div>

      <div class="news-grid">

        <!-- CARD 1 -->
        <article class="news-card">

          <div class="news-image">
            <img src="https://images.unsplash.com/photo-1504711434969-e33886168f5c?q=80&w=1200&auto=format&fit=crop" alt="Quantum computing"/>
            <button class="bookmark-btn" aria-label="Bookmark article">
              <i class="fa-regular fa-bookmark"></i>
            </button>
          </div>

          <div class="news-info">
            <span class="news-category tech">Technology</span>
            <h3>Quantum Computing Breakthrough Announced</h3>
            <p>Scientists unveil a major leap in computational power...</p>

            <div class="news-meta">
              <span><i class="fa-regular fa-clock"></i> 2h ago</span>
              <span><i class="fa-regular fa-eye"></i> 18K views</span>
            </div>
          </div>

        </article>

        <!-- CARD 2 -->
        <article class="news-card">

          <div class="news-image">
            <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?q=80&w=1200&auto=format&fit=crop" alt="Business news"/>
            <button class="bookmark-btn" aria-label="Bookmark article">
              <i class="fa-regular fa-bookmark"></i>
            </button>
          </div>

          <div class="news-info">
            <span class="news-category business">Business</span>
            <h3>Global Markets Rally Amid Economic Optimism</h3>
            <p>Investors react positively to stronger-than-expected growth...</p>

            <div class="news-meta">
              <span><i class="fa-regular fa-clock"></i> 4h ago</span>
              <span><i class="fa-regular fa-eye"></i> 12K views</span>
            </div>
          </div>

        </article>

        <!-- CARD 3 -->
        <article class="news-card">

          <div class="news-image">
            <img src="https://images.unsplash.com/photo-1517649763962-0c623066013b?q=80&w=1200&auto=format&fit=crop" alt="Sports news"/>
            <button class="bookmark-btn" aria-label="Bookmark article">
              <i class="fa-regular fa-bookmark"></i>
            </button>
          </div>

          <div class="news-info">
            <span class="news-category sports">Sports</span>
            <h3>Championship Finals Deliver Historic Moment</h3>
            <p>Fans celebrate an unforgettable ending with record-breaking action...</p>

            <div class="news-meta">
              <span><i class="fa-regular fa-clock"></i> 1h ago</span>
              <span><i class="fa-regular fa-eye"></i> 22K views</span>
            </div>
          </div>

        </article>

      </div>

    </section>

    <!-- ================= LIVE FEED ================= -->
    <section class="feed-section">

      <div class="section-header">
        <h2>⚡ Live Feed</h2>
      </div>

      <div class="feed-list">

        <article class="feed-item">
          <div class="feed-dot"></div>
          <div>
            <h3>Space agency launches next-generation satellite.</h3>
            <p>10 minutes ago</p>
          </div>
        </article>

        <article class="feed-item">
          <div class="feed-dot blue-dot"></div>
          <div>
            <h3>Major tech company reveals new AI-powered devices.</h3>
            <p>18 minutes ago</p>
          </div>
        </article>

        <article class="feed-item">
          <div class="feed-dot pink-dot"></div>
          <div>
            <h3>International summit focuses on climate innovation.</h3>
            <p>30 minutes ago</p>
          </div>
        </article>

      </div>

    </section>

  </main>

  <!-- JS -->
  <script src="news-aggregator-dashboard.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>