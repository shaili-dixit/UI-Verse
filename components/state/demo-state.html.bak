  <meta charset="utf-8" />
    <title>State Manager Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      body { font-family: system-ui, Arial; padding: 20px; }
      button { margin-right: 8px; }
