  <body>
    <h1>State Manager Demo</h1>
    <div>
      <strong>Counter:</strong> <span id="counter">0</span>
    </div>
    <div style="margin-top:12px;">
      <button id="inc">Increment</button>
      <button id="reset">Reset</button>
    </div>

    <script type="module" src="./demo-state.js"></script>
      <script src="../../dist/shared.js"></script>
</body>
</html>
