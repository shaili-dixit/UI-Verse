<!doctype html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../../dist/shared.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Design Tokens Demo</title>
  <link rel="stylesheet" href="/design-tokens.css">
  <style>
    body {
      margin: 0;
      font-family: var(--font-body);
      background: linear-gradient(180deg, var(--bg-primary), var(--bg-secondary));
      color: var(--text-primary);
      min-height: 100vh;
    }

    .wrap {
      max-width: 960px;
      margin: 0 auto;
      padding: 48px 24px;
    }

    .toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 24px;
      border: 1px solid var(--border-primary);
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.72);
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(16px);
    }

    .eyebrow {
      margin-bottom: 8px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 12px;
    }

    h1 {
      margin: 0;
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 3.5rem);
    }

    uv-theme-switcher {
      display: inline-flex;
      align-items: center;
    }

    .uv-theme-switcher {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 10px 12px;
      border: 1px solid var(--border-primary);
      border-radius: 999px;
      background: var(--bg-secondary);
      color: var(--text-primary);
      box-shadow: var(--shadow-sm);
    }

    .uv-theme-switcher__label {
      font-size: 14px;
      font-weight: 700;
    }

    .uv-theme-switcher__select {
      border: 0;
      background: transparent;
      color: inherit;
      font: inherit;
      outline: none;
      cursor: pointer;
    }
  </style>
  <script type="module">
    import '/js/features/design-tokens.js';
    import '/components/WebComponents/uv-theme-switcher.js';

    window.addEventListener('DOMContentLoaded', () => {
      DesignTokens.init && DesignTokens.init();
    });
  </script>
</head>
<body>
  <div class="wrap">
    <div class="toolbar">
      <div>
        <div class="eyebrow">Centralized design tokens</div>
        <h1>Theme Management</h1>
      </div>
      <uv-theme-switcher></uv-theme-switcher>
    </div>
  </div>
    <script src="../../dist/shared.js"></script>
</body>
</html>
