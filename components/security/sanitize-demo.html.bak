<!doctype html>
<html lang="en">
  <head>
  <link rel="stylesheet" href="../../dist/shared.css">
  <meta charset="utf-8" />
    <title>Sanitize Demo</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>body{font-family:system-ui,Arial;padding:20px}</style>
  </head>
  <body>
    <h1>Sanitizer Demo</h1>
    <label for="payload">HTML payload:</label>
    <textarea id="payload" rows="4" cols="60">&lt;img src=x onerror=alert(1)&gt;&lt;strong&gt;safe text&lt;/strong&gt;</textarea>
    <div style="margin-top:12px;"><button id="render">Render</button></div>
    <h2>Output</h2>
    <div id="output"></div>

    <script type="module" src="./sanitize-demo.js"></script>
      <script src="../../dist/shared.js"></script>
</body>
</html>
