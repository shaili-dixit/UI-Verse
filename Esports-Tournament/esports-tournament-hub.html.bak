<!-- index.html -->
<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Nova Clash — eSports Tournament</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- CSS -->
  <link rel="stylesheet" href="esports-tournament.css" />
</head>
<body>

  <!-- Background Glow -->
  <div class="bg-glow glow-1"></div>
  <div class="bg-glow glow-2"></div>

  <!-- Header -->
  <header class="header">
    <div class="logo">
      <span>⚡</span> Nova Clash
    </div>

    <nav class="nav">
      <a href="#home">Home</a>
      <a href="#tournaments">Tournaments</a>
      <a href="#teams">Teams</a>
      <a href="#schedule">Schedule</a>
      <a href="#contact">Contact</a>
    </nav>

    <button class="join-btn">Join Now</button>
  </header>

  <!-- Hero -->
  <section class="hero" id="home">

    <div class="hero-content">
      <p class="tag">GLOBAL eSPORTS CHAMPIONSHIP 2026</p>

      <h1>
        Dominate The <span>Battlefield</span>
      </h1>

      <p class="hero-text">
        Compete with the best teams worldwide in the most intense
        online gaming tournament experience.
      </p>

      <div class="hero-buttons">
        <button class="primary-btn">Register Team</button>
        <button class="secondary-btn">Watch Trailer</button>
      </div>

      <div class="stats">
        <div class="stat-card">
          <h2>120+</h2>
          <p>Teams</p>
        </div>

        <div class="stat-card">
          <h2>$250K</h2>
          <p>Prize Pool</p>
        </div>

        <div class="stat-card">
          <h2>40M+</h2>
          <p>Viewers</p>
        </div>
      </div>
    </div>

    <div class="hero-image">
      <img
        src="https://images.unsplash.com/photo-1542751110-97427bbecf20?q=80&w=1200&auto=format&fit=crop"
        alt="Gaming"
      />
    </div>

  </section>

  <!-- Tournament Cards -->
  <section class="tournaments" id="tournaments">

    <div class="section-title">
      <p>FEATURED EVENTS</p>
      <h2>Upcoming Tournaments</h2>
    </div>

    <div class="cards">

      <div class="t-card">
        <div class="card-top">
          <span class="live">LIVE</span>
          <h3>Valorant Masters</h3>
        </div>

        <p>
          Elite FPS showdown with international esports teams.
        </p>

        <div class="card-info">
          <span>📅 12 Aug 2026</span>
          <span>🏆 $80K Prize</span>
        </div>

        <button>View Details</button>
      </div>

      <div class="t-card">
        <div class="card-top">
          <span class="upcoming">SOON</span>
          <h3>BGMI Royale</h3>
        </div>

        <p>
          India's biggest battle royale gaming competition.
        </p>

        <div class="card-info">
          <span>📅 20 Sep 2026</span>
          <span>🏆 $100K Prize</span>
        </div>

        <button>View Details</button>
      </div>

      <div class="t-card">
        <div class="card-top">
          <span class="live">LIVE</span>
          <h3>League Arena</h3>
        </div>

        <p>
          Strategic MOBA battles featuring top esports clubs.
        </p>

        <div class="card-info">
          <span>📅 02 Oct 2026</span>
          <span>🏆 $70K Prize</span>
        </div>

        <button>View Details</button>
      </div>

    </div>

  </section>

  <!-- Teams -->
  <section class="teams" id="teams">

    <div class="section-title">
      <p>TOP PLAYERS</p>
      <h2>Featured Teams</h2>
    </div>

    <div class="team-grid">

      <div class="team-card">
        <img
          src="https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1000&auto=format&fit=crop"
          alt="team"
        />

        <div class="team-info">
          <h3>Shadow Reapers</h3>
          <p>Asia Champions</p>
        </div>
      </div>

      <div class="team-card">
        <img
          src="https://images.unsplash.com/photo-1545239351-1141bd82e8a6?q=80&w=1000&auto=format&fit=crop"
          alt="team"
        />

        <div class="team-info">
          <h3>Nova Titans</h3>
          <p>Global Finalists</p>
        </div>
      </div>

      <div class="team-card">
        <img
          src="https://images.unsplash.com/photo-1511882150382-421056c89033?q=80&w=1000&auto=format&fit=crop"
          alt="team"
        />

        <div class="team-info">
          <h3>Cyber Wolves</h3>
          <p>World Ranked #1</p>
        </div>
      </div>

    </div>

  </section>

  <!-- Countdown -->
  <section class="countdown-section" id="schedule">

    <div class="section-title">
      <p>GRAND FINAL</p>
      <h2>Event Starts In</h2>
    </div>

    <div class="countdown">

      <div class="time-box">
        <h2 id="days">00</h2>
        <p>Days</p>
      </div>

      <div class="time-box">
        <h2 id="hours">00</h2>
        <p>Hours</p>
      </div>

      <div class="time-box">
        <h2 id="minutes">00</h2>
        <p>Minutes</p>
      </div>

      <div class="time-box">
        <h2 id="seconds">00</h2>
        <p>Seconds</p>
      </div>

    </div>

  </section>

  <!-- Footer -->
  <footer class="footer" id="contact">

    <h2>Ready For The Ultimate Clash?</h2>

    <p>
      Register your squad today and become the next esports legend.
    </p>

    <button class="primary-btn">
      Register Tournament
    </button>

  </footer>

  <!-- JS -->
  <script src="esports-tournament.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>