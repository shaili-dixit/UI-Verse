          Commercial Usage
        </div>

        <div class="detail-right success">
          Allowed
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-left">
          <i class="fa-solid fa-user"></i>
          Attribution
        </div>

        <div class="detail-right neutral">
          Appreciated but Optional
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-left">
          <i class="fa-solid fa-copy"></i>
          Redistribution
        </div>

        <div class="detail-right danger">
          Restricted
        </div>
      </div>

    </div>

  </section>

  <!-- CTA -->
