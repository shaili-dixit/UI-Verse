<!-- MAIN -->
<main class="main-home">

  <!-- HERO -->
  <section class="license-hero">

    <div class="license-badge">
      <i class="fa-solid fa-scale-balanced"></i>
      Open Source Friendly
    </div>

    <h1 class="license-title">
      Simple & Transparent <span>Licensing</span>
    </h1>

    <p class="license-desc">
      UIverse components are designed to be easy to use in personal,
      commercial, and client projects without unnecessary restrictions.
    </p>

    <div class="hero-license-cards">

      <div class="hero-mini-card">
        <i class="fa-solid fa-check"></i>
        <span>Commercial Use</span>
      </div>

      <div class="hero-mini-card">
        <i class="fa-solid fa-check"></i>
        <span>Modify Freely</span>
      </div>

      <div class="hero-mini-card">
        <i class="fa-solid fa-check"></i>
        <span>No Attribution Required</span>
      </div>

    </div>

  </section>

  <!-- LICENSE GRID -->
  <section class="license-grid">

    <!-- Allowed -->
    <div class="license-card allowed">
      <div class="license-card-top">
        <div class="license-icon">
          <i class="fa-solid fa-circle-check"></i>
        </div>

        <div>
          <h2>What You Can Do</h2>
          <p>Everything below is fully allowed.</p>
        </div>
      </div>

      <ul class="license-list">
        <li><i class="fa-solid fa-check"></i> Use in personal projects</li>
        <li><i class="fa-solid fa-check"></i> Use in commercial websites</li>
        <li><i class="fa-solid fa-check"></i> Modify components freely</li>
        <li><i class="fa-solid fa-check"></i> Use for client work</li>
        <li><i class="fa-solid fa-check"></i> Learn from the source code</li>
        <li><i class="fa-solid fa-check"></i> Build your own designs</li>
      </ul>
    </div>

    <!-- Restricted -->
    <div class="license-card restricted">
      <div class="license-card-top">
        <div class="license-icon">
          <i class="fa-solid fa-ban"></i>
        </div>

        <div>
          <h2>Restrictions</h2>
          <p>Please avoid these actions.</p>
        </div>
      </div>

      <ul class="license-list">
        <li><i class="fa-solid fa-xmark"></i> Reselling components as-is</li>
        <li><i class="fa-solid fa-xmark"></i> Re-uploading full UIverse collections</li>
        <li><i class="fa-solid fa-xmark"></i> Claiming ownership of original designs</li>
        <li><i class="fa-solid fa-xmark"></i> Using branding without permission</li>
      </ul>
    </div>

  </section>

  <!-- LICENSE DETAILS -->
  <section class="license-details">

    <div class="details-header">
      <span class="section-tag">LICENSE TERMS</span>
      <h2>Quick Overview</h2>
    </div>

    <div class="details-box">

      <div class="detail-row">
        <div class="detail-left">
          <i class="fa-solid fa-code"></i>
          Source Code
        </div>

        <div class="detail-right success">
          Fully Editable
        </div>
      </div>

      <div class="detail-row">
        <div class="detail-left">
