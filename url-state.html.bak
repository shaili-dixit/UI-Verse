<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>404 — Page Not Found</title>

  <!-- Google Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      background:
      radial-gradient(circle at top left,#7c3aed22,transparent 35%),
      radial-gradient(circle at bottom right,#2563eb22,transparent 35%),
      #0f172a;
      font-family:'DM Sans',sans-serif;
      overflow:hidden;
      color:#fff;
      position:relative;
    }

    /* Animated Background */
    .bg-blur{
      position:absolute;
      width:450px;
      height:450px;
      border-radius:50%;
      background:linear-gradient(135deg,#7c3aed,#2563eb);
      filter:blur(120px);
      opacity:.25;
      animation:float 8s ease-in-out infinite;
    }

    .bg-blur.one{
      top:-120px;
      left:-120px;
    }

    .bg-blur.two{
      bottom:-120px;
      right:-120px;
      animation-delay:4s;
    }

    @keyframes float{
      0%,100%{
        transform:translateY(0px);
      }
      50%{
        transform:translateY(-30px);
      }
    }

    /* Container */
    .error-container{
      width:min(92%,720px);
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter:blur(18px);
      border-radius:32px;
      padding:70px 50px;
      text-align:center;
      position:relative;
      z-index:2;
      box-shadow:
      0 20px 60px rgba(0,0,0,.35);
    }

    /* 404 Number */
    .error-code{
      font-size:8rem;
      font-family:'Syne',sans-serif;
      font-weight:800;
      line-height:1;
      background:linear-gradient(135deg,#fff,#8b5cf6,#3b82f6);
      -webkit-background-clip:text;
      -webkit-text-fill-color:transparent;
      margin-bottom:18px;
      letter-spacing:4px;
    }

    .error-icon{
      width:110px;
      height:110px;
      margin:auto;
      margin-bottom:28px;
      border-radius:28px;
      display:grid;
      place-items:center;
      font-size:2.6rem;
      background:linear-gradient(135deg,#7c3aed,#2563eb);
      box-shadow:
      0 20px 40px rgba(124,58,237,.35);
    }

    h1{
      font-size:2.6rem;
      margin-bottom:18px;
      font-family:'Syne',sans-serif;
      font-weight:700;
    }

    p{
      color:#cbd5e1;
      line-height:1.8;
      font-size:1.05rem;
      max-width:520px;
      margin:auto;
      margin-bottom:38px;
    }

    /* Buttons */
    .btn-group{
      display:flex;
      justify-content:center;
      gap:18px;
      flex-wrap:wrap;
    }

    .btn{
      text-decoration:none;
      padding:15px 28px;
      border-radius:16px;
      font-weight:700;
      transition:.35s ease;
      display:inline-flex;
      align-items:center;
      gap:10px;
      font-size:.95rem;
    }

    .btn-primary{
      background:linear-gradient(135deg,#7c3aed,#2563eb);
      color:#fff;
      box-shadow:
      0 12px 28px rgba(59,130,246,.3);
    }

    .btn-primary:hover{
      transform:translateY(-4px);
      box-shadow:
      0 18px 35px rgba(59,130,246,.45);
    }

    .btn-outline{
      border:1px solid rgba(255,255,255,.15);
      background:rgba(255,255,255,.04);
      color:#fff;
    }

    .btn-outline:hover{
      background:rgba(255,255,255,.08);
      transform:translateY(-4px);
    }

    /* Floating Shapes */
    .shape{
      position:absolute;
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter:blur(10px);
      border-radius:22px;
      animation:rotate 18s linear infinite;
    }

    .shape.one{
      width:90px;
      height:90px;
      top:10%;
      left:8%;
    }

    .shape.two{
      width:70px;
      height:70px;
      bottom:12%;
      right:10%;
      animation-direction:reverse;
    }

    @keyframes rotate{
      from{
        transform:rotate(0deg);
      }
      to{
        transform:rotate(360deg);
      }
    }

    /* Responsive */
    @media(max-width:768px){

      .error-container{
        padding:55px 28px;
      }

      .error-code{
        font-size:5.8rem;
      }

      h1{
        font-size:2rem;
      }

      p{
        font-size:.95rem;
      }

    }

  </style>
</head>

<body>

  <!-- Background Blur -->
  <div class="bg-blur one"></div>
  <div class="bg-blur two"></div>

  <!-- Floating Shapes -->
  <div class="shape one"></div>
  <div class="shape two"></div>

  <!-- 404 Card -->
  <div class="error-container">

    <div class="error-icon">
      <i class="fa-solid fa-link-slash"></i>
    </div>

    <div class="error-code">
      404
    </div>

    <h1>
      Page Not Found
    </h1>

    <p>
      The page you are looking for might have been removed,
      renamed, or is temporarily unavailable.
    </p>

    <div class="btn-group">

      <a href="/" class="btn btn-primary">
        <i class="fa-solid fa-house"></i>
        Back Home
      </a>

      <a href="#" class="btn btn-outline">
        <i class="fa-solid fa-arrow-left"></i>
        Go Back
      </a>

    </div>

  </div>

  <script src="dist/shared.js"></script>
</body>
</html>