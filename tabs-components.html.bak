<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modern Tab Navigation Components</title>
  <link rel="stylesheet" href="tabs-components.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script defer>
    function switchTab(container, clickedItem) {
      const items = container.querySelectorAll('.tab-item-js');
      items.forEach(i => i.classList.remove('active'));
      clickedItem.classList.add('active');
    }

  }

  /* =========================================
     COPY BUTTON
  ========================================= */

  const copyButtons =
    document.querySelectorAll(
      '.btn-primary'
    );

  copyButtons.forEach(button => {

    button.addEventListener(
      'click',
      () => {

        navigator.clipboard.writeText(
          'UI-Verse Component Copied'
        );

        const originalText =
          button.innerText;

        button.innerText =
          'Copied ✓';

        button.disabled = true;

        setTimeout(() => {

          button.innerText =
            originalText;

          button.disabled = false;

        }, 1800);

      }
    );

  });

  /* =========================================
     VIEW CODE BUTTON
  ========================================= */

  const viewButtons =
    document.querySelectorAll(
      '.btn-secondary'
    );

  viewButtons.forEach(button => {

    button.addEventListener(
      'click',
      () => {

        const original =
          button.innerText;

        button.innerText =
          'Opening...';

      <div class="footer-col subscribe-col">
        <h4>STAY UPDATED</h4>
        <p>Get notified when new components drop.</p>
        <form class="subscribe-form" onsubmit="event.preventDefault()">
          <input type="email" placeholder="your@email.com" aria-label="Email address" required>
          <button type="submit" class="btn-subscribe">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 UI-Verse. Made with <span class="heart">♥</span> for developers worldwide.
    </div>
  </footer>
  <script src="dist/shared.js"></script>
</body>
</html>
