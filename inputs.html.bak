  <script>
    /* Dark Mode */
    const toggle = document.getElementById('darkModeToggle');
    const icon = toggle.querySelector('i');
    if (localStorage.getItem('theme') === 'dark') {
      document.body.classList.add('dark-mode');
      icon.className = 'fa-solid fa-sun';
    }
    toggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      const isDark = document.body.classList.contains('dark-mode');
      icon.className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    /* Sidebar */
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarBackdrop').classList.toggle('visible');
    }

    /* Scroll Top */
    function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
    window.addEventListener('scroll', () => {
      document.getElementById('scroll-top-btn').classList.toggle('visible', window.scrollY > 400);
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
    });

    /* Code Toggle */
    function toggleCode(id, btn) {
      const block = document.getElementById(id);
      const isOpen = block.classList.toggle('open');
      btn.innerHTML = isOpen
        ? '<i class="fa-solid fa-eye-slash"></i> Hide Code'
        : '<i class="fa-solid fa-code"></i> View Code';
    }

    /* Copy */
    function copyCode(id, btn) {
      navigator.clipboard.writeText(document.getElementById(id).innerText).then(() => {
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copy';
          btn.classList.remove('copied');
        }, 2000);
      });
    }

    /* Filter by section */
    function filterSection(sec, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.inputs-section').forEach(s => {
        s.style.display = (sec === 'all' || s.dataset.section === sec) ? '' : 'none';
      });
    }




    /* Live search */
    function liveFilter(val) {
      const q = val.toLowerCase();
      document.querySelectorAll('.inputs-section').forEach(section => {
        let visibleCards = 0;
        section.querySelectorAll('.component-card').forEach(card => {
          const name = card.dataset.name.toLowerCase();
          const label = card.querySelector('.card-label')?.textContent.toLowerCase() || '';
          const match = name.includes(q) || label.includes(q);

          card.style.display = match ? '' : 'none';
          if (match) visibleCards++;
        });
        section.style.display = visibleCards > 0 ? '' : 'none';
      });
    }


    /* Scroll animations with local file / environment failsafe */
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in-view'); });
      }, { threshold: 0.08 });
      document.querySelectorAll('.component-card').forEach(el => observer.observe(el));

      // Failsafe: if cards aren't marked in-view after a short delay (e.g. local file protocol restrictions), force show them
      setTimeout(() => {
        document.querySelectorAll('.component-card').forEach(el => {
          if (!el.classList.contains('in-view')) {
            el.classList.add('in-view');
          }
        });
      }, 300);
    } else {
      document.querySelectorAll('.component-card').forEach(el => {
        el.classList.add('in-view');
      });
    }
  </script>
  <script src="dist/shared.js"></script>
</body>

</html>
