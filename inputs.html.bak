              Copy</button>
          </div>
          <pre id="c18"
            class="code-block"><code>&lt;input type="text" pattern="[A-Z]+" placeholder="Uppercase only"&gt;</code></pre>
        </div>

      </div>
    </div>

  </div>

  <!-- Scroll to Top -->
  <button type="button" id="scroll-top-btn" onclick="scrollToTop()" aria-label="Scroll To Top" title="Back to top">
    <i class="fa-solid fa-chevron-up"></i>
  </button>

