  <!-- MAIN -->
  <div class="main-content">

    <!-- Page Hero -->
    <div class="page-hero">
      <div class="page-hero-left">
        <div class="breadcrumb">
          <a href="index.html">Home</a>
          <i class="fa-solid fa-chevron-right"></i>
          <span>Inputs</span>
        </div>
        <h1 class="page-title">Input Components</h1>
        <p class="page-desc">Every HTML input type you'll ever need — text, email, password, date, range, file, select,
          checkbox, radio and more. Click to copy.</p>
        <div class="page-meta">
          <span class="meta-badge"><i class="fa-solid fa-layer-group"></i> 23 Components</span>
          <span class="meta-badge"><i class="fa-solid fa-code"></i> Pure HTML</span>
          <span class="meta-badge"><i class="fa-solid fa-bolt"></i> No JS Required</span>
        </div>
      </div>
      <div class="page-hero-right">
        <div class="hero-inputs-preview">
          <div class="preview-input-wrap">
            <i class="fa-solid fa-user preview-icon"></i>
            <input class="preview-input" type="text" placeholder="Username" readonly >
          </div>
          <div class="preview-input-wrap">
            <i class="fa-solid fa-lock preview-icon"></i>
            <input class="preview-input" type="password" placeholder="Password" readonly >
          </div>
          <input class="preview-range" type="range" value="60" disabled>
        </div>
      </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <button type="button" class="filter-btn active" onclick="filterSection('all', this)">All</button>
      <button type="button" class="filter-btn" onclick="filterSection('basic', this)">Basic</button>
      <button type="button" class="filter-btn" onclick="filterSection('datetime', this)">Date &amp; Time</button>
      <button type="button" class="filter-btn" onclick="filterSection('advanced', this)">Advanced</button>
      <button type="button" class="filter-btn" onclick="filterSection('selection', this)">Selection</button>
      <button type="button" class="filter-btn" onclick="filterSection('specialized', this)">Specialized</button>
      <button type="button" class="filter-btn" onclick="filterSection('attributes', this)">Attributes</button>
      <div class="filter-search">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Filter inputs..." oninput="liveFilter(this.value)" >
      </div>
    </div>

    <!-- ===== BASIC INPUTS ===== -->
    <div class="inputs-section" data-section="basic">
      <div class="section-header-row">
        <h2 class="inputs-section-title">Basic Inputs</h2>
        <span class="section-count">3 components</span>
      </div>
      <div class="inputs-grid">

        <div class="component-card" data-name="text input basic" data-sec="basic">
          <div class="card-top">
