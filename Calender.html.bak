<!-- ================= SIDEBAR BACKDROP ================= -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
<!-- =====================================================
TOPBAR
===================================================== -->

<header class="topbar">

  <div class="search-box">

    <i class="fa-solid fa-magnifying-glass"></i>

    <input
      type="text"
      placeholder="Search calendar components..."
    >

  </div>

  <div class="topbar-actions">

    <button class="outline-btn">
      Docs
    </button>

    <button class="primary-btn">
      New Event
    </button>

  </div>

</header>

<!-- =====================================================
MAIN
===================================================== -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-badge">
      ✦ Productivity Components
    </div>

    <h1>
      Futuristic <span>Calendar</span>
    </h1>

    <p>

      A premium glassmorphism calendar
      experience crafted for dashboards,
      productivity apps and modern interfaces.

    </p>

  </section>

  <!-- DASHBOARD GRID -->

  <section class="calendar-layout">

    <!-- CALENDAR -->

    <div class="calendar-card">

      <div class="calendar-header">

        <div>

          <span class="calendar-mini">
            Monthly Planner
          </span>

          <h2 id="monthYear">
            July 2026
          </h2>

        </div>

        <div class="calendar-controls">

          <button id="prevBtn">
            <i class="fa-solid fa-chevron-left"></i>
          </button>

          <button id="nextBtn">
            <i class="fa-solid fa-chevron-right"></i>
          </button>

        </div>

      </div>

      <!-- DAYS -->

      <div class="days-row">

        <span>Sun</span>
        <span>Mon</span>
        <span>Tue</span>
        <span>Wed</span>
        <span>Thu</span>
        <span>Fri</span>
        <span>Sat</span>

      </div>

      <!-- DATES -->

      <div
        class="dates-grid"
        id="calendarDates"
      ></div>

    </div>

    <!-- EVENTS -->

    <div class="events-panel">

      <div class="events-header">

        <h3>
          Upcoming Events
        </h3>

        <button>
          View All
        </button>

      </div>

      <!-- EVENT -->

      <div class="event-card purple-event">

        <div class="event-time">
          09:30 AM
        </div>

        <div class="event-content">

          <h4>
            UI Design Meeting
          </h4>

          <p>
            Discord Voice Channel
          </p>

        </div>

      </div>

      <!-- EVENT -->

      <div class="event-card blue-event">

        <div class="event-time">
          01:00 PM
        </div>

        <div class="event-content">

          <h4>
            Frontend Sprint
          </h4>

          <p>
            Dashboard Components
          </p>

        </div>

      </div>

      <!-- EVENT -->

      <div class="event-card orange-event">

        <div class="event-time">
          07:00 PM
        </div>

        <div class="event-content">

          <h4>
            Community Stream
          </h4>

          <p>
            Live Showcase Event
          </p>

        </div>

      </div>

      <!-- STATS -->

      <div class="calendar-stats">

        <div class="stat-box">

          <h2>
            24
          </h2>

          <span>
            Tasks
          </span>

        </div>

        <div class="stat-box">

          <h2>
            8
          </h2>

          <span>
            Meetings
          </span>

        </div>

      </div>

    </div>

  </section>

</main>

