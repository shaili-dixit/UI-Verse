{
    "name": "ui-verse",
    "version": "1.0.0",
    "private": true,
    "description": "UI-Verse static site — quality gate tooling",
    "scripts": {
        "lint:js": "eslint '**/*.js' --ext .js",
        "lint:css": "stylelint '**/*.css'",
        "lint:html": "html-validate '**/*.html'",
        "link-check": "linkinator './index.html' --recursive --silent --summary",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "images:build": "node scripts/image-pipeline.js",
        "images:verify": "node scripts/image-pipeline.js --check",
        "security:csp": "node scripts/csp-hardening.js",
        "security:csp:verify": "node scripts/csp-hardening.js --check",
        "audit:a11y": "node scripts/a11y-remediation.js",
        "audit:a11y:apply": "node scripts/a11y-remediation.js --apply",
        "a11y:remediate": "node scripts/a11y-remediation.js",
        "a11y:remediate:apply": "node scripts/a11y-remediation.js --apply",
        "a11y:dashboard": "node scripts/a11y-dashboard.js",
        "a11y:remediation:check": "node scripts/a11y-remediation-check.js",
        "audit:a11y": "node scripts/a11y-audit.js",
        "a11y:dashboard": "node scripts/a11y-dashboard.js",
        "a11y:remediation:check": "node scripts/a11y-remediation-check.js",
        "test:visual": "playwright test",
        "test:visual:ui": "playwright test --ui",
        "test:visual:update": "playwright test --update-snapshots",
        "test:visual:debug": "playwright test --debug",
        "test:storybook": "playwright test --config playwright.storybook.config.ts",
        "quality": "npm run lint:html && npm run lint:css && npm run lint:js && npm run link-check && npm run audit:a11y && npm run test:visual",
        "test:e2e:accessibility": "playwright test tests/visual/accessibility --project=chromium-desktop --reporter=list",
        "perf": "node scripts/perf-budgets.js",
        "perf:ci": "node scripts/perf-budgets.js",
        "perf:monitor": "node scripts/performance-monitor.js",
        "perf:check": "node scripts/performance-monitor.js && echo '✅ Performance check completed'",
        "perf:dashboard": "npm run perf:monitor && echo '📊 Open performance-dashboard.html in your browser'",
        "wc:register": "node -e \"console.log('Web components are ES modules; import them in the browser via <script type=\\\"module\\\">')\"",
        "wc:test": "playwright test tests/webcomponents --project=chromium --reporter=list",
        "i18n:test": "playwright test tests/i18n --config=playwright.i18n.config.ts --reporter=list",
        "dependencies:analyze": "node scripts/dependency-analyzer.js",
        "dependencies:dashboard": "npm run dependencies:analyze && echo '📊 Open dependency-dashboard.html in your browser'",
        "visual:scale": "playwright test --config=playwright.visual-scale.config.ts",
        "visual:scale:quick": "node scripts/run-visual-scale-quick.js",
        "visual:scale:update": "playwright test --config=playwright.visual-scale.config.ts --update-snapshots",
        "visual:scale:summary": "node scripts/visual-results-summary.js",
        "docs:generate": "node scripts/documentation-generator.js",
        "docs:generate:check": "node scripts/documentation-generator-check.js",
        "theme:test": "playwright test tests/theme --config=playwright.theme.config.ts --reporter=list",
        "theme:demo": "node -e \"console.log('Open components/theme/demo-theme.html in a browser served from the static server')\"",
        "search:test": "playwright test tests/search --config=playwright.search.config.ts --reporter=list",
        "search:demo": "node -e \"console.log('Open components/discovery/component-discovery.html in a browser served from the static server')\"",
        "search:check": "node scripts/component-discovery-check.js",
        "a11y:test": "playwright test tests/a11y --config=playwright.a11y.config.ts --reporter=list"
        "theme:demo": "node -e \"console.log('Open components/theme/demo-theme.html in a browser served from the static server')\""
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.0.0",
        "@playwright/test": "^1.40.0",
        "@storybook/addon-essentials": "^8.6.14",
        "@storybook/html-vite": "^8.6.18",
        "axe-core": "^4.9.2",
        "eslint": "^8.50.0",
        "html-validate": "^8.5.0",
        "linkinator": "^7.6.1",
        "sharp": "^0.33.5",
        "storybook": "^8.6.18",
        "stylelint": "^15.0.0",
        "stylelint-config-standard": "^30.0.0"
    },
    "dependencies": {
        "fuse.js": "^7.3.0"
    }
}
