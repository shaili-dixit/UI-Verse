<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-hashes'; script-src-attr 'unsafe-hashes'; style-src 'self' https: 'unsafe-hashes'; style-src-attr 'unsafe-hashes'">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Image Carousel</title>
  <link rel="stylesheet" href="image.css">
</head>

<body>

  <section class="carousel-section">

    <div class="carousel-container">

      <!-- Slides -->
      <div class="carousel-track">

        <div
          class="slide active"
          style="background-image:url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=1600&auto=format&fit=crop')"
        >
          <div class="overlay"></div>

          <div class="content">
            <span class="tag">Nature</span>
            <h1>Explore Beautiful Landscapes</h1>
            <p>
              Discover breathtaking mountains, forests, and lakes from around the world.
            </p>

            <div class="buttons">
              <button class="primary-btn">Explore</button>
              <button class="secondary-btn">Learn More</button>
            </div>
          </div>
        </div>

        <div
          class="slide"
          style="background-image:url('https://images.unsplash.com/photo-1493246507139-91e8fad9978e?q=80&w=1600&auto=format&fit=crop')"
        >
          <div class="overlay"></div>

          <div class="content">
            <span class="tag">Travel</span>
            <h1>Adventure Starts Here</h1>
            <p>
              Experience exciting destinations and unforgettable journeys.
            </p>

            <div class="buttons">
              <button class="primary-btn">Book Trip</button>
              <button class="secondary-btn">Gallery</button>
            </div>
          </div>
        </div>

        <div
          class="slide"
          style="background-image:url('https://images.unsplash.com/photo-1519608487953-e999c86e7455?q=80&w=1600&auto=format&fit=crop')"
        >
          <div class="overlay"></div>

          <div class="content">
            <span class="tag">City Life</span>
            <h1>Modern Urban Experience</h1>
            <p>
              Enjoy vibrant nightlife, architecture, and futuristic skylines.
            </p>

            <div class="buttons">
              <button class="primary-btn">Discover</button>
              <button class="secondary-btn">See More</button>
            </div>
          </div>
        </div>

      </div>

      <!-- Controls -->
      <button class="nav-btn prev">&#10094;</button>
      <button class="nav-btn next">&#10095;</button>

      <!-- Indicators -->
      <div class="dots">
        <span class="dot active-dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>

      <!-- Progress Bar -->
      <div class="progress-bar">
        <div class="progress"></div>
      </div>

    </div>

  </section>

  <script src="image.js"></script>
    <script src="../dist/shared.js"></script>
</body>
</html>