<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bankify Pro Dashboard</title>
  <link rel="stylesheet" href="bank.css">
</head>

<body>

<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2>Bankify<span>Pro</span></h2>

    <nav>
      <a class="active">Dashboard</a>
      <a>Accounts</a>
      <a>Transactions</a>
      <a>Cards</a>
      <a>Analytics</a>
      <a>Settings</a>
    </nav>

    <div class="user-box">
      <p>Logged in as</p>
      <h4>John Doe</h4>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <header class="topbar">
      <div>
        <h1>Dashboard</h1>
        <p>Welcome back 👋</p>
      </div>

      <button class="primary-btn">+ Transfer Money</button>
    </header>

    <!-- CARDS -->
    <section class="cards">

      <div class="card balance">
        <h3>Total Balance</h3>
        <h2 id="balance">₹1,25,000</h2>
        <span>Updated just now</span>
      </div>

      <div class="card income">
        <h3>Income</h3>
        <h2>₹80,000</h2>
      </div>

      <div class="card expense">
        <h3>Expenses</h3>
        <h2>₹25,000</h2>
      </div>

    </section>

    <!-- CONTENT -->
    <section class="content">

      <!-- TRANSACTIONS -->
      <div class="panel">
        <h2>Recent Transactions</h2>

        <div class="txn income">
          <span>Salary Credit</span>
          <b>+ ₹50,000</b>
        </div>

        <div class="txn expense">
          <span>Amazon Purchase</span>
          <b>- ₹2,500</b>
        </div>

        <div class="txn expense">
          <span>Electricity Bill</span>
          <b>- ₹1,200</b>
        </div>

        <div class="txn expense">
          <span>Netflix</span>
          <b>- ₹799</b>
        </div>
      </div>

      <!-- QUICK ACTIONS -->
      <div class="panel actions">
        <h2>Quick Actions</h2>

        <button onclick="addMoney()">Add Money</button>
        <button onclick="sendMoney()">Send Money</button>
        <button>Pay Bills</button>
        <button>Recharge</button>
      </div>

    </section>

  </main>

</div>

<script src="bank.js"></script>
    <script src="../dist/shared.js"></script>
</body>
</html>