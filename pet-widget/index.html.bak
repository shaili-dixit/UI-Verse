<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Virtual Pet Widget</title>
  </head>
<body>

  <div class="pet-container">
    
    <div class="pet-face">
      <div class="eyes">
        <span></span>
        <span></span>
      </div>
      <div class="mouth"></div>
    </div>

    <h2 id="mood">Mood: Happy 😊</h2>

    <div class="buttons">
      <button id="feedBtn">Feed 🍎</button>
      <button id="playBtn">Play 🎮</button>
    </div>

  </div>

      <script src="../dist/shared.js"></script>
</body>
</html>