      <!-- HERO -->

      <section class="hero">

        <div class="hero-badge">

          <i class="fa-solid fa-cookie-bite"></i>

          Cookies & Privacy

        </div>

        <h1>

          Cookies
          <span class="gradient-text">
            Policy
          </span>

        </h1>

        <p>
          Learn how UIverse uses cookies and similar
          technologies to improve your browsing experience,
          personalize content and enhance platform performance.
        </p>

      </section>

      <!-- MAIN -->

      <div class="content-wrapper">

        <!-- SIDEBAR -->

        <aside class="policy-sidebar">

          <h3>
            Policy Sections
          </h3>

          <ul>

            <li>
              <a href="#what">
                <i class="fa-solid fa-circle-info"></i>
                What Are Cookies
              </a>
            </li>

            <li>
              <a href="#types">
                <i class="fa-solid fa-layer-group"></i>
                Cookie Types
              </a>
            </li>

            <li>
              <a href="#usage">
                <i class="fa-solid fa-chart-line"></i>
                How We Use Them
              </a>
            </li>

            <li>
              <a href="#manage">
                <i class="fa-solid fa-sliders"></i>
                Manage Cookies
              </a>
            </li>

            <li>
              <a href="#security">
                <i class="fa-solid fa-shield-halved"></i>
                Security
              </a>
            </li>

          </ul>

        </aside>

        <!-- CONTENT -->

        <section class="policy-content">

      <!-- WHAT -->

      <div class="policy-card" id="what">

        <h2>

          <i class="fa-solid fa-cookie-bite"></i>

          What Are Cookies?

        </h2>

        <p>
          Cookies are small text files stored on your device
          when you visit a website. They help websites remember
          user preferences, improve functionality and provide
          a better browsing experience.
        </p>

        <p>
          UIverse uses cookies to enhance performance,
          improve security and personalize your experience
          across our platform.
        </p>

      </div>

      <!-- TYPES -->

      <div class="policy-card" id="types">

        <h2>

          <i class="fa-solid fa-layer-group"></i>

          Types of Cookies

        </h2>

        <div class="cookie-grid">

          <div class="cookie-box">

            <div class="cookie-icon">
              <i class="fa-solid fa-shield"></i>
            </div>

            <h3>
              Essential Cookies
            </h3>

            <p>
              Required for authentication,
              security and basic website functionality.
            </p>

          </div>

          <div class="cookie-box">

            <div class="cookie-icon">
              <i class="fa-solid fa-chart-column"></i>
            </div>

            <h3>
              Analytics Cookies
            </h3>

            <p>
              Help us understand usage patterns
              and improve platform performance.
            </p>

          </div>

          <div class="cookie-box">

            <div class="cookie-icon">
              <i class="fa-solid fa-sliders"></i>
            </div>

            <h3>
              Preference Cookies
            </h3>

            <p>
              Save theme preferences, language
              settings and personalization options.
            </p>

          </div>

          <div class="cookie-box">

            <div class="cookie-icon">
              <i class="fa-solid fa-bullhorn"></i>
            </div>

            <h3>
              Marketing Cookies
            </h3>

            <p>
              Used to deliver relevant campaigns
              and measure advertising effectiveness.
            </p>

          </div>

        </div>

      </div>

      <!-- USAGE -->

      <div class="policy-card" id="usage">

        <h2>

          <i class="fa-solid fa-chart-line"></i>

          How We Use Cookies

        </h2>

        <ul>

          <li>

            <i class="fa-solid fa-check"></i>

            Improve website speed and performance.

          </li>

          <li>

            <i class="fa-solid fa-check"></i>

            Remember your preferences and settings.

          </li>

          <li>

            <i class="fa-solid fa-check"></i>

            Analyze visitor interactions and optimize UX.

          </li>

          <li>

            <i class="fa-solid fa-check"></i>

            Maintain security and protect user sessions.

          </li>

        </ul>

      </div>

      <!-- MANAGE -->

      <div class="policy-card" id="manage">

        <h2>

          <i class="fa-solid fa-sliders"></i>

          Manage Cookie Preferences

        </h2>

        <p>
          You can manage or disable cookies
          through your browser settings at any time.
        </p>

        <div class="cookie-banner" role="dialog" aria-live="polite" aria-labelledby="cookieBannerTitle" aria-describedby="cookieBannerDesc">

          <div class="banner-content">

            <h3 id="cookieBannerTitle">
              Cookie Preferences
            </h3>

            <p id="cookieBannerDesc">
              We use cookies to personalize content,
              analyze traffic and improve your experience.
            </p>

          </div>

          <div class="banner-actions">

            <button class="banner-btn accept-btn" aria-label="Accept all cookies">
              Accept All
            </button>

            <button class="banner-btn settings-btn" aria-label="Manage cookie settings">
              Manage Settings
            </button>

          </div>

        </div>

      </div>

      <!-- SECURITY -->

      <div class="policy-card" id="security">

        <h2>

          <i class="fa-solid fa-shield-halved"></i>

          Data Security

        </h2>

        <p>
          UIverse follows industry-standard security
          practices to protect cookie-related information
          and user data from unauthorized access.
        </p>

      </div>
       <!-- COOKIE STATS -->

<div class="policy-card cookie-stats-card">

  <div class="stats-header">

    <h2>
      <i class="fa-solid fa-chart-pie"></i>
      Cookie Usage Overview
    </h2>

    <p>
      Transparency about how cookies are used across the platform.
    </p>
  <div class="stats-grid">

    <div class="stat-box">
      <span class="stat-circle essential"></span>
      <h3>45%</h3>
      <p>Essential</p>
    </div>

    <div class="stat-box">
      <span class="stat-circle analytics"></span>
      <h3>25%</h3>
      <p>Analytics</p>
    </div>

    <div class="stat-box">
      <span class="stat-circle preference"></span>
      <h3>20%</h3>
      <p>Preferences</p>
    </div>

    <div class="stat-box">
      <span class="stat-circle marketing"></span>
      <h3>10%</h3>
      <p>Marketing</p>
    </div>

  </div>

</div>
<!-- COOKIE TIMELINE -->

<div class="policy-card">

  <h2>
    <i class="fa-solid fa-clock-rotate-left"></i>
    Cookie Lifecycle
  </h2>
      <!-- FOOTER -->

      </div>

  <div class="stats-grid">

    <div class="stat-box">
      <span class="stat-circle essential"></span>
      <h3>45%</h3>
