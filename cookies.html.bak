  </div>

</div>
<!-- COOKIE TIMELINE -->

<div class="policy-card">

  <h2>
    <i class="fa-solid fa-clock-rotate-left"></i>
    Cookie Lifecycle
  </h2>

  <div class="cookie-timeline">
  <div class="cookie-timeline">

    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <h3>Visit Website</h3>
        <p>
          Cookies are created when you access the platform.
        </p>
      </div>

    </div>

    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <h3>Store Preferences</h3>
        <p>
          Theme, language and session preferences are saved.
        </p>
      </div>

    </div>

    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <h3>Analyze Activity</h3>
        <p>
          Anonymous analytics improve user experience.
        </p>
      </div>

    </div>

    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <h3>Visit Website</h3>
        <p>
          Cookies are created when you access the platform.
        <h3>Automatic Expiry</h3>
        <p>
          Cookies expire or can be removed anytime.
        </p>
      </div>

    </div>

    <div class="timeline-item">

      <div class="timeline-dot"></div>

      <div class="timeline-content">
        <h3>Store Preferences</h3>
        <p>
          Theme, language and session preferences are saved.
        </p>
      </div>

    </div>

