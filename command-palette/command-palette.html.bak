<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />

  <meta name="viewport"
    content="width=device-width, initial-scale=1.0" />

  <title>Advanced Command Palette UI</title>

  <!-- Fonts -->

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500;700&display=swap"
    rel="stylesheet">

  <!-- Icons -->

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <style>

  </head>

<body>

  <!-- ================= HERO ================= -->

  <section class="hero">

    <div class="hero-content">

      <span class="hero-badge">
        ⌘ Smart Navigation System
      </span>

      <h1>
        Command Palette <br>
        Interface ⚡
      </h1>

      <p>
        Open the command palette using
        keyboard shortcuts and quickly
        navigate actions, pages and tools.
      </p>

      <button id="openPaletteBtn">

        Open Palette

        <span>
          ⌘K
        </span>

      </button>

    </div>

  </section>

  <!-- ================= QUICK STATS ================= -->

  <section class="quick-stats">

    <div class="stat-card">
      <i class="fa-solid fa-bolt"></i>
      <div>
        <h3>120+</h3>
        <p>Commands</p>
      </div>
    </div>

    <div class="stat-card">
      <i class="fa-solid fa-keyboard"></i>
      <div>
        <h3>25</h3>
        <p>Shortcuts</p>
      </div>
    </div>

    <div class="stat-card">
      <i class="fa-solid fa-layer-group"></i>
      <div>
        <h3>8</h3>
        <p>Categories</p>
      </div>
    </div>

    <div class="stat-card">
      <i class="fa-solid fa-user-check"></i>
      <div>
        <h3>98%</h3>
        <p>Efficiency</p>
      </div>
    </div>

  </section>

  <!-- ================= FEATURES ================= -->

  <section class="features">

    <div class="feature-card">

      <div class="feature-icon">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
      </div>

      <h3>Smart Suggestions</h3>

      <p>
        Predictive commands appear instantly
        based on your recent activity.
      </p>

    </div>

    <div class="feature-card">

      <div class="feature-icon">
        <i class="fa-solid fa-terminal"></i>
      </div>

      <h3>Developer Friendly</h3>

      <p>
        Designed for keyboard-first workflows
        and ultra-fast navigation.
      </p>

    </div>

    <div class="feature-card">

      <div class="feature-icon">
        <i class="fa-solid fa-shield"></i>
      </div>

      <h3>Secure Actions</h3>

      <p>
        Execute sensitive actions safely
        with confirmations and permissions.
      </p>

    </div>

  </section>

  <!-- ================= RECENT COMMANDS ================= -->

  <section class="recent-section">

    <div class="section-title">

      <h2>
        Recent Commands
      </h2>

      <p>
        Your most frequently used actions
      </p>

    </div>

    <div class="recent-grid">

      <div class="recent-card">

        <i class="fa-solid fa-clock-rotate-left"></i>

        <div>
          <h4>Open Dashboard</h4>
          <span>2 minutes ago</span>
        </div>

      </div>

      <div class="recent-card">

        <i class="fa-solid fa-folder-open"></i>

        <div>
          <h4>Project Overview</h4>
          <span>10 minutes ago</span>
        </div>

      </div>

      <div class="recent-card">

        <i class="fa-solid fa-chart-pie"></i>

        <div>
          <h4>Analytics Panel</h4>
          <span>20 minutes ago</span>
        </div>

      </div>

      <div class="recent-card">

        <i class="fa-solid fa-user-gear"></i>

        <div>
          <h4>Profile Settings</h4>
          <span>1 hour ago</span>
        </div>

      </div>

    </div>

  </section>

  <!-- ================= SHORTCUT GUIDE ================= -->

  <section class="shortcut-guide">

    <div class="section-title">

      <h2>
        Keyboard Shortcuts
      </h2>

      <p>
        Master productivity instantly
      </p>

    </div>

    <div class="shortcut-list">

      <div class="shortcut-item">
        <span>Open Command Palette</span>
        <div>
          <kbd>⌘</kbd>
          <kbd>K</kbd>
        </div>
      </div>

      <div class="shortcut-item">
        <span>Search Commands</span>
        <kbd>/</kbd>
      </div>

      <div class="shortcut-item">
        <span>Close Palette</span>
        <kbd>ESC</kbd>
      </div>

      <div class="shortcut-item">
        <span>Navigate Down</span>
        <kbd>↓</kbd>
      </div>

      <div class="shortcut-item">
        <span>Navigate Up</span>
        <kbd>↑</kbd>
      </div>

      <div class="shortcut-item">
        <span>Execute Command</span>
        <kbd>ENTER</kbd>
      </div>

    </div>

  </section>

  <!-- ================= TEAM SECTION ================= -->

  <section class="team-section">

    <div class="section-title">

      <h2>
        Built For Teams
      </h2>

      <p>
        Collaborate with shared shortcuts,
        workflows and workspace commands.
      </p>

    </div>

    <div class="team-grid">

      <div class="team-card">

        <i class="fa-solid fa-code"></i>

        <h3>Developers</h3>

        <p>
          Faster debugging and project navigation.
        </p>

      </div>

      <div class="team-card">

        <i class="fa-solid fa-palette"></i>

        <h3>Designers</h3>

        <p>
          Quick access to assets and layouts.
        </p>

      </div>

      <div class="team-card">

        <i class="fa-solid fa-briefcase"></i>

        <h3>Managers</h3>

        <p>
          Streamlined productivity workflows.
        </p>

      </div>

    </div>

  </section>

  <!-- ================= FOOTER ================= -->

  <footer class="footer">

    <h2>
      Ready to Boost Productivity?
    </h2>

    <p>
      Experience lightning-fast navigation
      with the modern command palette system.
    </p>

    <button>
      Launch Workspace
    </button>

  </footer>

  <!-- ================= COMMAND PALETTE ================= -->

  <div class="palette-overlay"
    id="paletteOverlay">

    <div class="command-palette">

      <!-- SEARCH -->

      <div class="palette-search">

        <i class="fa-solid fa-magnifying-glass"></i>

        <input
          type="text"
          id="commandInput"
          placeholder="Search commands..." />

        <kbd>
          ESC
        </kbd>

      </div>

      <!-- COMMAND LIST -->

      <div class="command-list"
        id="commandList">

        <!-- GROUP -->

        <div class="command-group">

          <h4>
            Navigation
          </h4>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-house"></i>

              <span>
                Go to Dashboard
              </span>

            </div>

            <kbd>
              G D
            </kbd>

          </button>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-user"></i>

              <span>
                Open Profile
              </span>

            </div>

            <kbd>
              G P
            </kbd>

          </button>

        </div>

        <!-- GROUP -->

        <div class="command-group">

          <h4>
            Actions
          </h4>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-plus"></i>

              <span>
                Create New Project
              </span>

            </div>

            <kbd>
              N
            </kbd>

          </button>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-moon"></i>

              <span>
                Toggle Dark Mode
              </span>

            </div>

            <kbd>
              D
            </kbd>

          </button>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-arrow-right-from-bracket"></i>

              <span>
                Logout Account
              </span>

            </div>

            <kbd>
              L
            </kbd>

          </button>

        </div>

        <!-- GROUP -->

        <div class="command-group">

          <h4>
            Tools
          </h4>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-chart-line"></i>

              <span>
                Open Analytics
              </span>

            </div>

            <kbd>
              A
            </kbd>

          </button>

          <button class="command-item">

            <div class="command-left">

              <i class="fa-solid fa-gear"></i>

              <span>
                Settings
              </span>

            </div>

            <kbd>
              S
            </kbd>

          </button>

        </div>

      </div>

    </div>

  </div>

  <!-- ================= JAVASCRIPT ================= -->

  <script>

    /* ================= COMMAND SEARCH ================= */

    const commandInput =
    document.getElementById("commandInput");

    const commandItems =
    document.querySelectorAll(".command-item");

    commandInput.addEventListener("keyup", () => {

      let value =
      commandInput.value.toLowerCase();

      commandItems.forEach(item => {

        let text =
        item.innerText.toLowerCase();

        item.style.display =
        text.includes(value)
        ? "flex"
        : "none";

      });

    });

    /* ================= OPEN/CLOSE PALETTE ================= */

    const overlay =
    document.getElementById("paletteOverlay");

    const openBtn =
    document.getElementById("openPaletteBtn");

    openBtn.onclick = () => {

      overlay.classList.add("active");

      commandInput.focus();

    };

    document.addEventListener("keydown", (e) => {

      if (
        (e.metaKey || e.ctrlKey)
        && e.key.toLowerCase() === "k"
      ) {

        e.preventDefault();

        overlay.classList.toggle("active");

        commandInput.focus();

      }

      if (e.key === "Escape") {

        overlay.classList.remove("active");

      }

    });

    /* ================= CLOSE ON OUTSIDE CLICK ================= */

    overlay.addEventListener("click", (e) => {

      if (e.target === overlay) {

        overlay.classList.remove("active");

      }

    });

    /* ================= DEMO ALERT ================= */

    commandItems.forEach(item => {

      item.addEventListener("click", () => {

        alert(
          item.innerText.trim()
        );

      });

    });

  </script>

    <script src="../dist/shared.js"></script>
</body>

</html>