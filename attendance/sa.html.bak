<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Student Attendance Tracker</title>

  <!-- Google Font -->
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <link rel="stylesheet" href="sa.css" />
</head>

<body>

  <div class="attendance-dashboard">

    <!-- Sidebar -->
    <aside class="sidebar">
      <h2>EduTrack</h2>

      <ul>
        <li class="active">Attendance</li>
        <li>Students</li>
        <li>Reports</li>
        <li>Settings</li>
      </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">

      <!-- Top Bar -->
      <div class="top-bar">

        <div>
          <h1>Student Attendance Tracker</h1>
          <p>Manage daily student attendance records</p>
        </div>

        <div class="top-actions">
          <input
            type="text"
            id="searchInput"
            placeholder="Search student..."
          />

          <button class="add-btn">
            + Add Student
          </button>
        </div>

      </div>

      <!-- Stats -->
      <div class="stats-section">

        <div class="stat-card">
          <span>Total Students</span>
          <h2 id="totalCount">40</h2>
        </div>

        <div class="stat-card present-card">
          <span>Present</span>
          <h2 id="presentCount">32</h2>
        </div>

        <div class="stat-card absent-card">
          <span>Absent</span>
          <h2 id="absentCount">8</h2>
        </div>

      </div>

      <!-- Attendance Table -->
      <div class="table-container">

        <table>

          <thead>
            <tr>
              <th>Student Name</th>
              <th>Roll No</th>
              <th>Status</th>
            </tr>
          </thead>

          <tbody id="studentTable">

            <tr>
              <td>Rahul Sharma</td>
              <td>101</td>
              <td>
                <button class="status-btn present">
                  Present
                </button>
              </td>
            </tr>

            <tr>
              <td>Anjali Verma</td>
              <td>102</td>
              <td>
                <button class="status-btn absent">
                  Absent
                </button>
              </td>
            </tr>

            <tr>
              <td>Saiteja</td>
              <td>103</td>
              <td>
                <button class="status-btn present">
                  Present
                </button>
              </td>
            </tr>

            <tr>
              <td>Priya Singh</td>
              <td>104</td>
              <td>
                <button class="status-btn present">
                  Present
                </button>
              </td>
            </tr>

            <tr>
              <td>Arjun Patel</td>
              <td>105</td>
              <td>
                <button class="status-btn absent">
                  Absent
                </button>
              </td>
            </tr>

          </tbody>

        </table>

      </div>

    </main>

  </div>

  <script src="sa.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>