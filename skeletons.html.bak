<!DOCTYPE html>
<html lang="en">
  <head>
  <link rel="stylesheet" href="dist/shared.css">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Skeletons — UIverse</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Page Styles -->
    <link rel="stylesheet" href="skeletons.css" />
    <!-- UIverse Runtime Loader -->
    <script src="js/loader.js" defer></script>
  </head>
  <body>
    <!-- ================= SIDEBAR ================= -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand">
        <span class="brand-icon">⬡</span>
        <span class="brand-text">UIverse <span class="brand-badge">V2</span></span>
      </div>
      <nav class="sidebar-nav" aria-label="Primary navigation">
        <ul>
          <li><a href="index.html"><i class="fa-solid fa-house"></i><span>Home</span></a></li>
          <li><a href="button.html"><i class="fa-solid fa-hand-pointer"></i><span>Buttons</span></a></li>
          <li><a href="cards.html"><i class="fa-solid fa-table-cells-large"></i><span>Cards</span></a></li>
          <li><a href="loaders.html"><i class="fa-solid fa-spinner"></i><span>Loaders</span></a></li>
          <li><a href="dashboard.html"><i class="fa-solid fa-gauge-high"></i><span>Dashboard</span></a></li>
          <li><a href="testimonials.html"><i class="fa-solid fa-star"></i><span>Testimonials</span></a></li>
          <li class="active"><a href="skeletons.html"><i class="fa-solid fa-layer-group"></i><span>Skeletons</span></a></li>
        </ul>
      </nav>
    </aside>

    <!-- ================= PAGE CONTAINER ================= -->
    <div class="page-container">
      <!-- ================= TOP NAVBAR ================= -->
      <header class="topbar">
        <div class="topbar-left">
          <a href="index.html" class="topbar-logo">
            <span class="logo-mark">UI</span>
            <span class="logo-text">UIverse</span>
          </a>
          <div class="topbar-search">
            <label class="screen-reader-text" for="component-search">Search components</label>
            <input id="component-search" type="search" class="search-input" placeholder="Search skeleton components..." />
            <button type="button" class="search-action"><i class="fa-solid fa-magnifying-glass"></i></button>
          </div>
        </div>
        <div class="topbar-right">
          <button class="topbar-action" type="button" aria-label="Notifications">
            <i class="fa-solid fa-bell"></i>
          </button>
          <button class="topbar-action" type="button" aria-label="Favorites">
            <i class="fa-solid fa-heart"></i>
          </button>
          <button class="topbar-action theme-toggle" type="button" aria-label="Toggle theme">
            <i class="fa-solid fa-moon"></i>
          </button>
        </div>
      </header>

      <!-- ================= MAIN CONTENT ================= -->
      <main class="main-content">
        <!-- Hero Section -->
        <section class="hero-section" aria-labelledby="hero-heading">
          <div class="hero-copy">
            <span class="hero-label">Premium</span>
            <h1 id="hero-heading" class="hero-title">Modern Skeleton Loading Components</h1>
            <p class="hero-description">
              Explore lightweight, responsive skeleton screens designed for premium user interfaces and polished load states.
            </p>
            <div class="hero-badges">
              <span class="badge badge-primary">Shimmer Effect</span>
              <span class="badge badge-secondary">Responsive</span>
              <span class="badge badge-tertiary">Lightweight</span>
            </div>
          </div>
          <div class="hero-preview">
            <article class="skeleton-preview-card">
              <header class="preview-header">
                <div class="preview-title">
                  <span class="preview-tag">Preview</span>
                  <h2>Skeleton App Loader</h2>
                </div>
                <span class="status-pill">Loading</span>
              </header>
              <div class="preview-body">
                <div class="skeleton-row skeleton-row-large"></div>
                <div class="skeleton-grid">
                  <div class="skeleton-block skeleton-block-avatar"></div>
                  <div class="skeleton-block skeleton-block-text"></div>
                </div>
                <div class="skeleton-row skeleton-row-small"></div>
                <div class="skeleton-row skeleton-row-medium"></div>
              </div>
            </article>
          </div>
        </section>

        <!-- Filter Bar -->
        <section class="filter-bar" aria-label="Skeleton filters">
          <button class="filter-pill active">All</button>
          <button class="filter-pill">Cards</button>
          <button class="filter-pill">Profile</button>
          <button class="filter-pill">Dashboard</button>
          <button class="filter-pill">Tables</button>
          <button class="filter-pill">Content</button>
        </section>

        <!-- Components Grid -->
        <section class="components-section" aria-labelledby="components-heading">
          <div class="section-header">
            <div>
              <h2 id="components-heading">Skeleton Components</h2>
              <p>Scalable skeleton structures for advanced frontend systems.</p>
            </div>
            <span class="section-note">10 premium components</span>
          </div>

          <div class="component-grid">
            <!-- Profile Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Profile Skeleton</h3>
                <span class="tag">Profile</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton profile-skeleton">
                  <div class="avatar-circle"></div>
                  <div class="text-bar text-bar-title"></div>
                  <div class="text-bar text-bar-subtitle"></div>
                  <div class="text-row text-row-short"></div>
                </div>
              </div>
              <p class="component-description">Clean profile skeleton with avatar, title, and supporting text placeholders.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">View</button>
                <button class="btn btn-outline">Use</button>
              </div>
            </article>

            <!-- Dashboard Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Dashboard Skeleton</h3>
                <span class="tag">Dashboard</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton dashboard-skeleton">
                  <div class="text-bar text-bar-heading"></div>
                  <div class="skeleton-grid dashboard-grid-preview">
                    <div class="skeleton-card"></div>
                    <div class="skeleton-card"></div>
                    <div class="skeleton-card"></div>
                  </div>
                </div>
              </div>
              <p class="component-description">Multi-panel dashboard placeholders with chart and summary loading states.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Preview</button>
                <button class="btn btn-outline">Copy</button>
              </div>
            </article>

            <!-- Blog Card Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Blog Card Skeleton</h3>
                <span class="tag">Cards</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton card-skeleton">
                  <div class="media-block"></div>
                  <div class="text-bar text-bar-title"></div>
                  <div class="text-bar text-bar-short"></div>
                </div>
              </div>
              <p class="component-description">A premium blog card loader with image and text line placeholders.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Demo</button>
                <button class="btn btn-outline">Add</button>
              </div>
            </article>

            <!-- Table Row Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Table Row Skeleton</h3>
                <span class="tag">Tables</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton table-skeleton">
                  <div class="table-row-row">
                    <div class="table-cell cell-avatar"></div>
                    <div class="table-cell cell-line"></div>
                    <div class="table-cell cell-line-short"></div>
                    <div class="table-cell cell-line-medium"></div>
                  </div>
                  <div class="table-row-row">
                    <div class="table-cell cell-avatar"></div>
                    <div class="table-cell cell-line"></div>
                    <div class="table-cell cell-line-short"></div>
                    <div class="table-cell cell-line-medium"></div>
                  </div>
                </div>
              </div>
              <p class="component-description">Table row placeholders for data-driven interfaces and reports.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Inspect</button>
                <button class="btn btn-outline">Copy</button>
              </div>
            </article>

            <!-- Product Card Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Product Card Skeleton</h3>
                <span class="tag">Cards</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton product-skeleton">
                  <div class="media-block media-block-square"></div>
                  <div class="text-bar text-bar-title"></div>
                  <div class="text-bar text-bar-short"></div>
                  <div class="button-placeholder"></div>
                </div>
              </div>
              <p class="component-description">A shopping card loader built for premium marketplace layouts.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Use</button>
                <button class="btn btn-outline">Inspect</button>
              </div>
            </article>

            <!-- Analytics Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Analytics Skeleton</h3>
                <span class="tag">Dashboard</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton analytics-skeleton">
                  <div class="text-bar text-bar-title"></div>
                  <div class="chart-placeholder"></div>
                  <div class="skeleton-grid chart-stats-grid">
                    <div class="stat-block"></div>
                    <div class="stat-block"></div>
                    <div class="stat-block"></div>
                  </div>
                </div>
              </div>
              <p class="component-description">Analytics panel skeleton with chart and metric placeholders.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Preview</button>
                <button class="btn btn-outline">Use</button>
              </div>
            </article>

            <!-- Chat Message Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Chat Message Skeleton</h3>
                <span class="tag">Content</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton chat-skeleton">
                  <div class="message-row">
                    <div class="avatar-circle avatar-sm"></div>
                    <div class="text-bar text-bar-medium"></div>
                  </div>
                  <div class="message-row message-row-right">
                    <div class="text-bar text-bar-long"></div>
                  </div>
                </div>
              </div>
              <p class="component-description">A messaging loader with alternating bubble shapes and avatars.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Demo</button>
                <button class="btn btn-outline">Copy</button>
              </div>
            </article>

            <!-- Video Card Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Video Card Skeleton</h3>
                <span class="tag">Media</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton video-skeleton">
                  <div class="media-block media-block-video"></div>
                  <div class="text-bar text-bar-short"></div>
                  <div class="text-bar text-bar-line"></div>
                </div>
              </div>
              <p class="component-description">Video card placeholder with preview and details load bars.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Preview</button>
                <button class="btn btn-outline">Use</button>
              </div>
            </article>

            <!-- Article Loading Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Article Loading Skeleton</h3>
                <span class="tag">Content</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton article-skeleton">
                  <div class="text-bar text-bar-heading"></div>
                  <div class="text-bar text-bar-long"></div>
                  <div class="text-bar text-bar-medium"></div>
                  <div class="text-bar text-bar-short"></div>
                </div>
              </div>
              <p class="component-description">Long-form article loader for editorial and blog layouts.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Inspect</button>
                <button class="btn btn-outline">Copy</button>
              </div>
            </article>

            <!-- Team Member Skeleton -->
            <article class="component-card">
              <div class="component-card-head">
                <h3>Team Member Skeleton</h3>
                <span class="tag">Profile</span>
              </div>
              <div class="component-preview">
                <div class="preview-skeleton team-skeleton">
                  <div class="avatar-circle avatar-large"></div>
                  <div class="text-bar text-bar-title"></div>
                  <div class="text-bar text-bar-short"></div>
                  <div class="button-placeholder button-placeholder-sm"></div>
                </div>
              </div>
              <p class="component-description">Profile placeholder for team listings and people cards.</p>
              <div class="component-actions">
                <button class="btn btn-secondary">Preview</button>
                <button class="btn btn-outline">Use</button>
              </div>
            </article>
          </div>
        </section>

        <!-- Footer -->
        <footer class="page-footer">
          <div class="footer-grid">
            <div class="footer-column">
              <h3>UIverse</h3>
              <p>Design systems for premium UI experiences and modern product interfaces.</p>
            </div>
            <div class="footer-column">
              <h4>Navigation</h4>
              <ul>
                <li><a href="index.html">Home</a></li>
                <li><a href="cards.html">Cards</a></li>
                <li><a href="dashboard.html">Dashboard</a></li>
                <li><a href="testimonials.html">Testimonials</a></li>
              </ul>
            </div>
            <div class="footer-column">
              <h4>Resources</h4>
              <ul>
                <li><a href="#">Docs</a></li>
                <li><a href="#">Components</a></li>
                <li><a href="#">Templates</a></li>
              </ul>
            </div>
            <div class="footer-column newsletter-column">
              <h4>Newsletter</h4>
              <p>Subscribe for new skeleton sets, component updates, and premium UI releases.</p>
              <form class="footer-form">
                <label class="screen-reader-text" for="footer-newsletter">Email</label>
                <input id="footer-newsletter" type="email" placeholder="Enter your email" />
                <button type="submit" class="btn btn-primary">Subscribe</button>
              </form>
            </div>
          </div>
          <div class="footer-bottom">
            <p>&copy; 2026 UIverse. Crafted for modern interface systems.</p>
            <div class="social-links">
              <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
              <a href="#" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
              <a href="#" aria-label="Dribbble"><i class="fab fa-dribbble"></i></a>
            </div>
          </div>
        </footer>
      </main>
    </div>
    <script src="dist/shared.js"></script>
</body>
</html>
