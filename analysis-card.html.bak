<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>


  <div class="analytics-card" role="main">

    <!-- HEADER -->
    <div class="card-header">

      <div class="title-section">
        <span class="tag">Dashboard</span>
        <h2>Analytics Overview</h2>
        <p>Track your weekly business growth</p>
      </div>

      <button class="menu-btn">
        <i class="fa-solid fa-ellipsis"></i>
      </button>

    </div>

    <!-- TOP STATS -->
    <div class="stats-section">

      <div class="stat-box revenue">
        <div class="icon">
          <i class="fa-solid fa-dollar-sign"></i>
        </div>

        <div class="stat-info">
          <span class="label">Revenue</span>
          <h3>$12.4K</h3>

          <div class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +12%
          </div>
        </div>
      </div>

      <div class="stat-box users">
        <div class="icon">
          <i class="fa-solid fa-users"></i>
        </div>

        <div class="stat-info">
          <span class="label">Users</span>
          <h3>8,450</h3>

          <div class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +8%
          </div>
        </div>
      </div>

      <div class="stat-box bounce">
        <div class="icon">
          <i class="fa-solid fa-chart-line"></i>
        </div>

        <div class="stat-info">
          <span class="label">Bounce Rate</span>
          <h3>32%</h3>

          <div class="growth negative">
            <i class="fa-solid fa-arrow-trend-down"></i>
            -3%
          </div>
        </div>
      </div>

    </div>

    <!-- PROGRESS SECTION -->
    <div class="progress-wrapper">

      <div class="progress-item">
        <div class="progress-top">
          <span>Monthly Target</span>
          <span>78%</span>
        </div>

        <div class="progress-bar">
          <div class="progress-fill target-fill"></div>
        </div>
      </div>

      <div class="progress-item">
        <div class="progress-top">
          <span>Customer Growth</span>
          <span>65%</span>
        </div>

        <div class="progress-bar">
          <div class="progress-fill customer-fill"></div>
        </div>
      </div>

    </div>

    <!-- CHART -->
    <div class="chart-container">

      <div class="chart-header">
        <h3>Weekly Traffic</h3>

        <div class="chart-badge">
          Live
        </div>
      </div>

      <div class="chart-section">

        <div class="chart-item">
          <div class="bar" style="height: 50%;"></div>
          <span>Mon</span>
        </div>

        <div class="chart-item">
          <div class="bar" style="height: 75%;"></div>
          <span>Tue</span>
        </div>

        <div class="chart-item">
          <div class="bar active" style="height: 100%;"></div>
          <span>Wed</span>
        </div>

        <div class="chart-item">
          <div class="bar" style="height: 65%;"></div>
          <span>Thu</span>
        </div>

        <div class="chart-item">
          <div class="bar" style="height: 40%;"></div>
          <span>Fri</span>
        </div>

        <div class="chart-item">
          <div class="bar" style="height: 90%;"></div>
          <span>Sat</span>
        </div>

        <div class="chart-item">
          <div class="bar" style="height: 70%;"></div>
          <span>Sun</span>
        </div>

      </div>

    </div>

    <!-- ACTIVITY -->
    <div class="activity-section">

      <div class="activity-header">
        <h3>Recent Activity</h3>
      </div>

      <div class="activity-list">

        <div class="activity-item">
          <div class="activity-icon green">
            <i class="fa-solid fa-check"></i>
          </div>

          <div class="activity-text">
            <h4>Payment Received</h4>
            <p>$1,240 from client</p>
          </div>

          <span class="time">2m ago</span>
        </div>

        <div class="activity-item">
          <div class="activity-icon blue">
            <i class="fa-solid fa-user-plus"></i>
          </div>

          <div class="activity-text">
            <h4>New User Joined</h4>
            <p>245 registrations today</p>
          </div>

          <span class="time">10m ago</span>
        </div>

        <div class="activity-item">
          <div class="activity-icon orange">
            <i class="fa-solid fa-chart-column"></i>
          </div>

          <div class="activity-text">
            <h4>Report Generated</h4>
            <p>Weekly report updated</p>
          </div>

          <span class="time">1h ago</span>
        </div>

      </div>

    </div>

    <!-- FOOTER -->
    <div class="footer">

      <button id="refreshBtn" class="refresh-btn">
        <i class="fa-solid fa-rotate"></i>
        Refresh Data
      </button>

      <button class="export-btn">
        <i class="fa-solid fa-download"></i>
        Export
      </button>

    </div>

  </div>
  <!-- TEAM PERFORMANCE CARD -->

<div class="team-card">

  <div class="card-header">
    <div>
      <span class="tag">Team</span>
      <h2>Top Performers</h2>
    </div>
  </div>

  <div class="team-grid">

    <div class="member">
      <img src="https://i.pravatar.cc/100?img=1">
      <h4>Sarah Lee</h4>
      <p>UI Designer</p>
      <div class="score">96% Efficiency</div>
    </div>

    <div class="member">
      <img src="https://i.pravatar.cc/100?img=5">
      <h4>David Kim</h4>
      <p>Marketing</p>
      <div class="score">89% Efficiency</div>
    </div>

    <div class="member">
      <img src="https://i.pravatar.cc/100?img=8">
      <h4>John Carter</h4>
      <p>Developer</p>
      <div class="score">93% Efficiency</div>
    </div>

  </div>

</div>

<!-- SALES PERFORMANCE CARD -->

<div class="sales-card">

  <div class="circle-progress"></div>

  <div class="sales-info">
    <span class="tag">Revenue</span>
    <h3>Quarterly Sales</h3>
    <p>
      Your company achieved 72% of the quarterly
      revenue target with strong growth in
      subscriptions and customer retention.
    </p>
  </div>

</div>
<!-- =================================
     CRYPTO PORTFOLIO CARD
================================= -->

<div class="crypto-card">

  <div class="card-top">
    <div>
      <span class="tag">Finance</span>
      <h2>Crypto Portfolio</h2>
    </div>

    <button class="menu-btn">
      <i class="fa-solid fa-wallet"></i>
    </button>
  </div>

  <div class="crypto-balance">
    <h1>$84,240</h1>
    <span class="positive">+18.2% this month</span>
  </div>

  <div class="coin-list">

    <div class="coin">
      <div class="coin-info">
        <i class="fa-brands fa-bitcoin"></i>
        <div>
          <h4>Bitcoin</h4>
          <p>BTC</p>
        </div>
      </div>

      <div class="coin-price">
        <h4>$42,120</h4>
        <span class="positive">+5.2%</span>
      </div>
    </div>

    <div class="coin">
      <div class="coin-info">
        <i class="fa-brands fa-ethereum"></i>
        <div>
          <h4>Ethereum</h4>
          <p>ETH</p>
        </div>
      </div>

      <div class="coin-price">
        <h4>$18,500</h4>
        <span class="positive">+3.9%</span>
      </div>
    </div>

  </div>

</div>

<!-- =================================
     AI INSIGHTS CARD
================================= -->

<div class="ai-card">

  <div class="ai-header">
    <div>
      <span class="tag">AI Report</span>
      <h2>Smart Insights</h2>
    </div>

    <div class="ai-badge">
      AI Powered
    </div>
  </div>

  <div class="insight-box">
    <i class="fa-solid fa-brain"></i>

    <div>
      <h3>Customer activity increased</h3>
      <p>
        Returning users grew by 34% after your latest campaign.
      </p>
    </div>
  </div>

  <div class="insight-box">
    <i class="fa-solid fa-bolt"></i>

    <div>
      <h3>Peak traffic detected</h3>
      <p>
        Highest engagement recorded between 6PM - 9PM.
      </p>
    </div>
  </div>

</div>

<!-- =================================
     TASK PROGRESS CARD
================================= -->

<div class="task-card">

  <div class="card-top">
    <div>
      <span class="tag">Productivity</span>
      <h2>Task Progress</h2>
    </div>
  </div>

  <div class="task-list">

    <div class="task-item">
      <div class="task-left">
        <i class="fa-solid fa-check"></i>
        <span>Dashboard UI Design</span>
      </div>

      <span class="done">Completed</span>
