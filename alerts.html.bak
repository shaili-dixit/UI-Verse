.ai-alert {
  display: flex;
  gap: 14px;
  padding: 18px;
  border-radius: 18px;
  background:
    linear-gradient(
      135deg,
      rgba(108,92,231,0.15),
      rgba(0,206,201,0.1)
    );
  border: 1px solid rgba(255,255,255,0.08);
}

.ai-alert-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg,#6c5ce7,#00cec9);
  color: #fff;
}</code></pre>
