<!-- ================= SIDEBAR BACKDROP ================= -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>
<!-- =====================================================
NAVBAR
===================================================== -->

<header class="navbar">

  <div class="search-bar">

    <i class="fa-solid fa-magnifying-glass"></i>

    <input
      type="text"
      placeholder="Search snackbar components..."
    >

  </div>

  <div class="nav-actions">

    <button class="outline-btn">
      Documentation
    </button>

    <button class="primary-btn">
      Explore UI
    </button>

  </div>

</header>

<!-- =====================================================
MAIN
===================================================== -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-badge">
      ✦ Feedback Components
    </div>

    <h1>
      Modern <span>Snackbars</span>
    </h1>

    <p>

      Premium toast and snackbar
      notifications inspired by
      futuristic SaaS dashboards.

    </p>

  </section>

  <!-- GRID -->

  <section class="snackbar-grid">

    <!-- SUCCESS -->

    <div class="snackbar-card">

      <div class="card-icon green">
        <i class="fa-solid fa-circle-check"></i>
      </div>

      <h2>
        Success Snackbar
      </h2>

      <p>

        Display success alerts
        with glowing confirmation
        animations.

      </p>

      <button
        class="show-btn success-btn"
        data-type="success"
      >
        Show Snackbar
      </button>

    </div>

    <!-- ERROR -->

    <div class="snackbar-card">

      <div class="card-icon red">
        <i class="fa-solid fa-circle-xmark"></i>
      </div>

      <h2>
        Error Snackbar
      </h2>

      <p>

        Show critical alerts
        and validation feedback
        beautifully.

      </p>

      <button
        class="show-btn error-btn"
        data-type="error"
      >
        Show Snackbar
      </button>

    </div>

    <!-- INFO -->

    <div class="snackbar-card">

      <div class="card-icon blue">
        <i class="fa-solid fa-circle-info"></i>
      </div>

      <h2>
        Info Snackbar
      </h2>

      <p>

        Lightweight floating
        information alerts for
        dashboards.

      </p>

      <button
        class="show-btn info-btn"
        data-type="info"
      >
        Show Snackbar
      </button>

    </div>

  </section>

</main>

<!-- =====================================================
SNACKBAR CONTAINER
===================================================== -->

<div
  class="snackbar-container"
  id="snackbarContainer"
></div>

<script src="snackbar.js"></script>

  <script src="dist/shared.js"></script>
</body>
</html>
