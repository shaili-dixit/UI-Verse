<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Advanced Statistics Section</title>

  <link rel="stylesheet" href="statistics.css" />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
</head>

<body>

  <section class="stats-section">

    <!-- Background Shapes -->
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <!-- Section Header -->
    <div class="section-header">
      <span class="tag">OUR SUCCESS</span>

      <h1>
        Trusted By Thousands <br />
        Around The World
      </h1>

      <p>
        We deliver high-quality digital solutions that help businesses grow
        faster and achieve outstanding results.
      </p>
    </div>

    <!-- Statistics Grid -->
    <div class="stats-container">

      <!-- Card 1 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon blue">
            <i class="fa-solid fa-users"></i>
          </div>

          <span class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +12%
          </span>
        </div>

        <h2 class="counter" data-target="1200">0</h2>

        <h3>Happy Clients</h3>

        <p>
          Satisfied customers across multiple industries worldwide.
        </p>

        <div class="progress-bar">
          <div class="progress blue-progress"></div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon purple">
            <i class="fa-solid fa-rocket"></i>
          </div>

          <span class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +20%
          </span>
        </div>

        <h2 class="counter" data-target="350">0</h2>

        <h3>Projects Completed</h3>

        <p>
          Successfully delivered projects with premium quality.
        </p>

        <div class="progress-bar">
          <div class="progress purple-progress"></div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon green">
            <i class="fa-solid fa-earth-americas"></i>
          </div>

          <span class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +8%
          </span>
        </div>

        <h2 class="counter" data-target="25">0</h2>

        <h3>Countries Reached</h3>

        <p>
          Expanding services globally with trusted partnerships.
        </p>

        <div class="progress-bar">
          <div class="progress green-progress"></div>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon orange">
            <i class="fa-solid fa-star"></i>
          </div>

          <span class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +15%
          </span>
        </div>

        <h2 class="counter" data-target="98">0</h2>

        <h3>Positive Reviews</h3>

        <p>
          Rated highly by clients for excellent customer experience.
        </p>

        <div class="progress-bar">
          <div class="progress orange-progress"></div>
        </div>
      </div>

      <!-- Card 5 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon red">
            <i class="fa-solid fa-award"></i>
          </div>

          <span class="growth positive">
            <i class="fa-solid fa-arrow-trend-up"></i>
            +10%
          </span>
        </div>

        <h2 class="counter" data-target="45">0</h2>

        <h3>Awards Won</h3>

        <p>
          Recognized internationally for innovation and creativity.
        </p>

        <div class="progress-bar">
          <div class="progress red-progress"></div>
        </div>
      </div>

      <!-- Card 6 -->
      <div class="stat-card">
        <div class="card-top">
          <div class="icon cyan">
            <i class="fa-solid fa-clock"></i>
          </div>

          <span class="growth negative">
            <i class="fa-solid fa-arrow-trend-down"></i>
            -5%
          </span>
        </div>

        <h2 class="counter" data-target="24">0</h2>

        <h3>Support Hours</h3>

        <p>
          Dedicated support team available around the clock.
        </p>

        <div class="progress-bar">
          <div class="progress cyan-progress"></div>
        </div>
      </div>

    </div>

    <!-- Bottom CTA -->
    <div class="stats-footer">
      <a href="#" class="stats-btn">
        Explore More
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

  </section>

  <script src="statistics.js"></script>

  <script src="dist/shared.js"></script>
</body>
</html>