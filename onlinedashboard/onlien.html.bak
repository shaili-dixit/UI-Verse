<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-hashes'; script-src-attr 'unsafe-hashes'; style-src 'self' https: 'unsafe-hashes' sha256-58z99ByVy7SdymDhZRA1QYViuxJroVpot5sN8df70FM= sha256-5gz2c1mG+rwxmYnSeeebLAR8qCrXnUfXX6WitG8+IzU= sha256-zBbmyZbc/pcETv15w4K5wdeKFoPmeL5InSPiW2gBkpg=; style-src-attr 'unsafe-hashes' sha256-58z99ByVy7SdymDhZRA1QYViuxJroVpot5sN8df70FM= sha256-5gz2c1mG+rwxmYnSeeebLAR8qCrXnUfXX6WitG8+IzU= sha256-zBbmyZbc/pcETv15w4K5wdeKFoPmeL5InSPiW2gBkpg=">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Online Course Dashboard</title>
  <link rel="stylesheet" href="online.css">
</head>
<body>

  <div class="dashboard">

    <aside class="sidebar">
      <h2>EduLearn</h2>

      <ul>
        <li class="active">Dashboard</li>
        <li>My Courses</li>
        <li>Assignments</li>
        <li>Certificates</li>
        <li>Settings</li>
      </ul>
    </aside>

    <main class="main-content">

      <div class="header">
        <h1>My Courses</h1>
        <button>Explore Courses</button>
      </div>


      <!-- Add this section BELOW header and ABOVE course-grid -->

<div class="stats-grid">

  <div class="stat-card">
    <h3>Courses Enrolled</h3>
    <p>12</p>
  </div>

  <div class="stat-card">
    <h3>Certificates Earned</h3>
    <p>5</p>
  </div>

  <div class="stat-card">
    <h3>Hours Learned</h3>
    <p>148h</p>
  </div>

  <div class="stat-card">
    <h3>Assignments Done</h3>
    <p>32</p>
  </div>

</div>
      <div class="course-grid">

        <div class="course-card">
          <h3>Frontend Development</h3>
          <p>Learn HTML, CSS, JavaScript, and responsive design.</p>

          <div class="progress-section">
            <span>75% Completed</span>

            <div class="progress-bar">
              <div class="progress" style="width: 75%;"></div>
            </div>
          </div>
        </div>

        <div class="course-card">
          <h3>Python Programming</h3>
          <p>Master Python basics, projects, and problem solving.</p>

          <div class="progress-section">
            <span>60% Completed</span>

            <div class="progress-bar">
              <div class="progress" style="width: 60%;"></div>
            </div>
          </div>
        </div>

        <div class="course-card">
          <h3>UI/UX Design</h3>
          <p>Design modern and user-friendly digital experiences.</p>

          <div class="progress-section">
            <span>45% Completed</span>

            <div class="progress-bar">
              <div class="progress" style="width: 45%;"></div>
            </div>
          </div>
        </div>

      </div>

    </main>

  </div>

  <script src="online.js"></script>
    <script src="../dist/shared.js"></script>
</body>
</html>