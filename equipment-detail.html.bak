<!doctype html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' http://127.0.0.1:5000 http://localhost:5000 https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-inline'; style-src 'self' https: 'unsafe-inline'">
  <title>Equipment Detail — UI-Verse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="equipment.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>
<body>
  <main class="detail-shell">
    <section class="detail-hero panel">
      <a href="equipment.html" class="back-link">← Back to marketplace</a>
      <div id="detailHero" class="detail-hero-content">
        <p class="loading-state">Loading equipment details…</p>
      </div>
    </section>

    <section class="detail-grid">
      <section class="panel booking-panel">
        <div class="panel-heading">
          <h2>Book rental dates</h2>
          <p>Blocked dates are disabled based on confirmed bookings.</p>
        </div>

        <form id="bookingForm" class="booking-form">
          <div class="field-grid">
            <label>
              Renter ID
              <input name="renter_id" type="text" placeholder="FARM-021" required>
            </label>
            <label>
              Renter name
              <input name="renter_name" type="text" placeholder="Maya Rao" required>
            </label>
            <label>
              Start date
              <input id="startDate" name="start_date" type="text" placeholder="Select start date" required>
            </label>
            <label>
              End date
              <input id="endDate" name="end_date" type="text" placeholder="Select end date" required>
            </label>
          </div>

          <div class="cost-summary">
            <div>
              <span>Daily rate</span>
              <strong id="dailyRateText">—</strong>
            </div>
            <div>
              <span>Rental days</span>
              <strong id="rentalDaysText">0</strong>
            </div>
            <div>
              <span>Total cost</span>
              <strong id="totalCostText">$0</strong>
            </div>
          </div>

          <button type="submit" class="primary-btn">Confirm booking</button>
          <p id="bookingStatus" class="status" aria-live="polite"></p>
        </form>
      </section>

      <section class="panel bookings-panel">
        <div class="panel-heading">
          <h2>Existing rental blocks</h2>
          <p>Use these dates to avoid double booking.</p>
        </div>
        <div id="bookingList" class="booking-list"></div>
      </section>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="js/features/equipment-detail.js"></script>
  <script src="dist/shared.js"></script>
</body>
</html>