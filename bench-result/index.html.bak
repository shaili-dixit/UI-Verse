<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Bench Result Dashboard</title>
  </head>
<body>

  <div class="container">

    <!-- HEADER -->
    <header class="header">

      <div class="header-left">
        <h1>Bench Results Dashboard</h1>
        <p>Performance overview, analytics & candidate insights</p>
      </div>

      <div class="search-box">
        <span>🔍</span>
        <input
          type="text"
          id="searchInput"
          placeholder="Search candidate..."
        />
      </div>

    </header>

    <!-- STATS -->
    <section class="stats">

      <div class="card primary">
        <h3>Total Candidates</h3>
        <p id="total">0</p>
      </div>

      <div class="card success">
        <h3>Passed</h3>
        <p id="passed">0</p>
      </div>

      <div class="card danger">
        <h3>Failed</h3>
        <p id="failed">0</p>
      </div>

      <div class="card warning">
        <h3>Average Score</h3>
        <p id="average">0%</p>
      </div>

    </section>

    <!-- TABLE -->
    <section class="table-wrapper">

      <div class="table-top">
        <div>
          <h2>Candidate Results</h2>
          <p>Live result tracking table</p>
        </div>
      </div>

      <div class="table-container">
        <table>

          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Score</th>
              <th>Status</th>
            </tr>
          </thead>

          <tbody id="resultTable"></tbody>

        </table>
      </div>

    </section>

  </div>

      <script src="../dist/shared.js"></script>
</body>
</html>