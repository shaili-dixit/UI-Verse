<!doctype html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' http://127.0.0.1:5000 http://localhost:5000 https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-inline'; style-src 'self' https: 'unsafe-inline'">
  <title>Verify Produce — UI-Verse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="traceability.css">
</head>
<body>
  <main class="verify-shell">
    <section class="verify-hero">
      <div>
        <span class="eyebrow">Consumer verification</span>
        <h1>Produce journey timeline</h1>
        <p>Scan results show the recorded chain of custody for the selected batch.</p>
      </div>
      <a class="back-link" href="trace.html">← Generate another QR</a>
    </section>

    <section class="panel batch-panel" id="batch-panel">
      <div class="loading-state">Loading batch details...</div>
    </section>

    <section class="panel timeline-panel">
      <div class="panel-heading">
        <h2>Ledger timeline</h2>
        <p>Events are append-only and hash-linked.</p>
      </div>
      <div class="timeline" id="timeline"></div>
    </section>
  </main>

  <script src="js/features/verify-produce.js"></script>
  <script src="dist/shared.js"></script>
</body>
</html>