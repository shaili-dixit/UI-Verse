<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8" />

  <meta
    http-equiv="Content-Security-Policy"
    content="
      default-src 'self' https:;
      base-uri 'self';
      frame-ancestors 'none';
      object-src 'none';
      connect-src 'self' https:;
      img-src 'self' data: https:;
      font-src 'self' data: https:;
      style-src 'self' https: 'unsafe-inline';
      script-src 'self' https: 'unsafe-inline';
    "
  />

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Loaders — UIverse</title>

  <!-- Fonts -->
  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- Font Awesome -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />

  <!-- CSS -->
  <link rel="stylesheet" href="loaders.css" />

  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #f5f7fb;
      color: #111827;
    }

    body.dark-mode {
      background: #0f172a;
      color: #fff;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .main {
      padding: 120px 40px 60px;
      margin-left: 280px;
    }

    .main h1 {
      font-size: 42px;
      margin-bottom: 30px;
      font-family: 'Syne', sans-serif;
    }

    .loaders-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 24px;
    }

    .component-card {
      background: #fff;
      border-radius: 20px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      transition: 0.3s;
    }

    body.dark-mode .component-card {
      background: #1e293b;
    }

    .component-card:hover {
      transform: translateY(-5px);
    }

    .component-card h3 {
      margin-bottom: 20px;
      font-size: 22px;
    }

    .loader-demo-box {
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,0.03);
      border-radius: 14px;
      margin-bottom: 20px;
    }

    body.dark-mode .loader-demo-box {
      background: rgba(255,255,255,0.05);
    }

    .actions {
      display: flex;
      gap: 12px;
      margin-bottom: 15px;
    }

    .actions button {
      border: none;
      padding: 10px 16px;
      border-radius: 10px;
      cursor: pointer;
      background: #2563eb;
      color: #fff;
      font-weight: 600;
      transition: 0.3s;
    }

    .actions button:hover {
      opacity: 0.9;
    }

    .code-block {
      display: none;
      background: #0f172a;
      color: #f8fafc;
      padding: 16px;
      border-radius: 12px;
      overflow-x: auto;
      white-space: pre-wrap;
    }

    .code-block.show {
      display: block;
    }

    /* ================= LOADERS ================= */

    .loader-spin {
      width: 60px;
      height: 60px;
      border: 5px solid #dbeafe;
      border-top-color: #2563eb;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    .loader-gradient {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      border: 6px solid transparent;
      border-top: 6px solid #06b6d4;
      border-right: 6px solid #8b5cf6;
      animation: spin 1s linear infinite;
    }

    .loader-dots {
      display: flex;
      gap: 10px;
    }

    .loader-dots span {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #2563eb;
      animation: bounce 0.6s infinite alternate;
    }

    .loader-dots span:nth-child(2) {
      animation-delay: 0.2s;
    }

    .loader-dots span:nth-child(3) {
      animation-delay: 0.4s;
    }

    .loader-pulse {
      width: 60px;
      height: 60px;
      background: #2563eb;
      border-radius: 50%;
      animation: pulse 1s infinite;
    }

    .loader-bar-wrap {
      width: 220px;
      height: 12px;
      background: #dbeafe;
      border-radius: 999px;
      overflow: hidden;
    }

    .loader-bar {
      width: 40%;
      height: 100%;
      background: #2563eb;
      animation: loading 1.5s infinite;
    }

    .skeleton-card {
      width: 240px;
    }

    .skeleton-avatar,
    .skeleton-line {
      background: linear-gradient(
        90deg,
        #e5e7eb 25%,
        #f3f4f6 50%,
        #e5e7eb 75%
      );

      background-size: 200% 100%;
      animation: shimmer 1.4s infinite;
      border-radius: 10px;
    }

    .skeleton-avatar {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      margin-bottom: 20px;
    }

    .skeleton-line {
      height: 14px;
      margin-bottom: 12px;
    }

    .l1 {
      width: 100%;
    }

    .l2 {
      width: 85%;
    }

    .l3 {
      width: 65%;
    }

    .loader-bars {
      display: flex;
      gap: 8px;
      align-items: flex-end;
      height: 70px;
    }

    .loader-bars span {
      width: 10px;
      height: 20px;
      background: #2563eb;
      border-radius: 10px;
      animation: bars 1s infinite ease-in-out;
    }

    .loader-bars span:nth-child(2) {
      animation-delay: 0.1s;
    }

    .loader-bars span:nth-child(3) {
      animation-delay: 0.2s;
    }

    .loader-bars span:nth-child(4) {
      animation-delay: 0.3s;
    }

    .loader-bars span:nth-child(5) {
      animation-delay: 0.4s;
    }

    @keyframes spin {
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes bounce {
      to {
        transform: translateY(-12px);
        opacity: 0.5;
      }
    }

    @keyframes pulse {
      0% {
        transform: scale(1);
        opacity: 1;
      }

      100% {
        transform: scale(1.4);
        opacity: 0;
      }
    }

    @keyframes loading {
      0% {
        transform: translateX(-100%);
      }

      100% {
        transform: translateX(350%);
      }
    }

    @keyframes shimmer {
      100% {
        background-position: -200% 0;
      }
    }

    @keyframes bars {
      0%, 100% {
        height: 20px;
      }

      50% {
        height: 70px;
      }
    }

    /* ================= NAVBAR ================= */

    .navbar {
      position: fixed;
      top: 0;
      left: 280px;
      right: 0;
      height: 80px;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(10px);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 30px;
      z-index: 1000;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }

    body.dark-mode .navbar {
      background: rgba(15,23,42,0.95);
    }

    .logo {
      font-size: 24px;
      font-weight: 800;
      font-family: 'Syne', sans-serif;
    }

    .search-bar {
      position: relative;
      width: 320px;
    }

    .search-bar input {
      width: 100%;
      padding: 12px 42px;
      border-radius: 12px;
      border: 1px solid #d1d5db;
      outline: none;
    }

    .search-icon {
      position: absolute;
      top: 14px;
      left: 14px;
    }

    .search-kbd {
      position: absolute;
      right: 12px;
      top: 12px;
      opacity: 0.5;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-btn,
    .theme-toggle {
      border: none;
      cursor: pointer;
      border-radius: 12px;
      padding: 12px 18px;
      font-weight: 600;
    }

    .primary-nav-btn {
      background: #2563eb;
      color: white;
    }

    .outline-nav-btn {
      background: transparent;
      border: 1px solid #d1d5db;
    }

    .theme-toggle {
      width: 48px;
      height: 48px;
      font-size: 18px;
    }

    /* ================= SIDEBAR ================= */

    .sidebar {
      width: 280px;
      height: 100vh;
      background: #111827;
      position: fixed;
      top: 0;
      left: 0;
      overflow-y: auto;
      padding: 30px 20px;
      z-index: 1001;
    }

    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 40px;
      color: white;
      font-size: 28px;
      font-family: 'Syne', sans-serif;
      font-weight: 800;
    }

    .sidebar-nav ul {
      list-style: none;
    }

    .sidebar-nav li {
      margin-bottom: 10px;
    }

    .sidebar-nav a {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-radius: 12px;
      color: #cbd5e1;
      transition: 0.3s;
    }

    .sidebar-nav li.active a,
    .sidebar-nav a:hover {
      background: #2563eb;
      color: white;
    }

    .sidebar-footer {
      margin-top: 40px;
      display: flex;
      gap: 14px;
    }

    .sidebar-footer a {
      color: white;
      font-size: 20px;
    }

    /* ================= FOOTER ================= */

    .footer {
      margin-left: 280px;
      background: #fff;
      padding: 10px 30px;
      margin-top: 30px;
    }

    body.dark-mode .footer {
      background: #111827;
    }

    .footer-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
    }

    .footer-col h3 {
      margin-bottom: 10px;
    }

    .footer-col ul {
      list-style: none;
    }

    .footer-col li {
      margin-bottom: 10px;
    }

    .newsletter-form {
      display: flex;
      gap: 10px;
      margin-top: 12px;
    }

    .newsletter-form input {
      flex: 1;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid #d1d5db;
    }

    .newsletter-form button {
      border: none;
      background: #2563eb;
      color: white;
      padding: 12px 16px;
      border-radius: 10px;
      cursor: pointer;
    }

    .footer-bottom {
      margin-top: 40px;
      text-align: center;
      opacity: 0.7;
      color: #aaa;
    }

    /* ================= SCROLL BUTTON ================= */

    #scrollTopBtn {
      position: fixed;
      right: 30px;
      bottom: 30px;
      width: 50px;
      height: 50px;
      border-radius: 50%;
      border: none;
      background: #2563eb;
      color: white;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: 0.3s;
    }

    #scrollTopBtn.visible {
      opacity: 1;
      pointer-events: auto;
    }

    /* ================= MOBILE ================= */

    .menu-toggle {
      display: none;
    }

    .sidebar-backdrop {
      display: none;
    }

    @media (max-width: 991px) {

      .sidebar {
        left: -100%;
        transition: 0.3s;
      }

      .sidebar.open {
        left: 0;
      }

      .sidebar-backdrop.visible {
        display: block;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
      }

      .navbar {
        left: 0;
      }

      .main,
      .footer {
        margin-left: 0;
      }

      .menu-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        border: none;
        border-radius: 12px;
        cursor: pointer;
      }

      .search-bar {
        display: none;
      }

    }

  </style>

  </head>

