<!-- =====================================================
MAIN
===================================================== -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-badge">
      ✦ Navigation Components
    </div>

    <h1>
      Modern <span>Dropdowns</span>
    </h1>

    <p>

      Beautiful futuristic dropdown
      components crafted for premium
      dashboards and modern websites.

    </p>

  </section>

  <!-- GRID -->

  <section class="dropdown-grid">

    <!-- BASIC -->

    <div class="dropdown-card">

      <div class="card-top">

        <span class="card-label">
          BASIC
        </span>

        <div class="card-icon purple">
          <i class="fa-solid fa-list"></i>
        </div>

      </div>

      <h2>
        Simple Dropdown
      </h2>

      <p>

        Clean modern dropdown
        menu with smooth transitions.

      </p>

      <div class="dropdown-wrapper">

        <button class="dropdown-btn">

          Select Option

          <i class="fa-solid fa-chevron-down"></i>

        </button>

        <div class="dropdown-menu">

          <div class="dropdown-item">
            Dashboard
          </div>

          <div class="dropdown-item">
            Analytics
          </div>

          <div class="dropdown-item">
            Settings
          </div>

          <div class="dropdown-item">
            Logout
          </div>

        </div>

      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code1', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code1', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code1" class="code-block"><code>&lt;div class="dropdown-wrapper"&gt;
  &lt;button class="dropdown-btn"&gt;
    Select Option
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu"&gt;
    &lt;div class="dropdown-item"&gt;Dashboard&lt;/div&gt;
    &lt;div class="dropdown-item"&gt;Analytics&lt;/div&gt;
    &lt;div class="dropdown-item"&gt;Settings&lt;/div&gt;
    &lt;div class="dropdown-item"&gt;Logout&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>

    </div>

    <!-- PROFILE -->

    <div class="dropdown-card">

      <div class="card-top">

        <span class="card-label">
          PROFILE
        </span>

        <div class="card-icon blue">
          <i class="fa-solid fa-user"></i>
        </div>

      </div>

      <h2>
        Profile Menu
      </h2>

      <p>

        Beautiful profile dropdown
        with icon based navigation.

      </p>

      <div class="dropdown-wrapper">

        <button class="dropdown-btn profile-btn">

          <img
            src="https://i.pravatar.cc/100"
            alt=""
          >

          Chinmay

          <i class="fa-solid fa-chevron-down"></i>

        </button>

        <div class="dropdown-menu">

          <div class="dropdown-item">
            <i class="fa-solid fa-user"></i>
            Profile
          </div>

          <div class="dropdown-item">
            <i class="fa-solid fa-gear"></i>
            Settings
          </div>

          <div class="dropdown-item">
            <i class="fa-solid fa-bookmark"></i>
            Saved
          </div>

          <div class="dropdown-item logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            Logout
          </div>

        </div>

      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code2', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code2', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code2" class="code-block"><code>&lt;div class="dropdown-wrapper"&gt;
  &lt;button class="dropdown-btn profile-btn"&gt;
    &lt;img src="https://i.pravatar.cc/100" alt=""&gt;
    Chinmay
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu"&gt;
    &lt;div class="dropdown-item"&gt;
      &lt;i class="fa-solid fa-user"&gt;&lt;/i&gt; Profile
    &lt;/div&gt;
    &lt;div class="dropdown-item"&gt;
      &lt;i class="fa-solid fa-gear"&gt;&lt;/i&gt; Settings
    &lt;/div&gt;
    &lt;div class="dropdown-item"&gt;
      &lt;i class="fa-solid fa-bookmark"&gt;&lt;/i&gt; Saved
    &lt;/div&gt;
    &lt;div class="dropdown-item logout"&gt;
      &lt;i class="fa-solid fa-right-from-bracket"&gt;&lt;/i&gt; Logout
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>

    </div>

    <!-- NOTIFICATION -->

    <div class="dropdown-card large-card">

      <div class="card-top">

        <span class="card-label">
          ADVANCED
        </span>

        <div class="card-icon orange">
          <i class="fa-solid fa-bell"></i>
        </div>

      </div>

      <h2>
        Notification Dropdown
      </h2>

      <p>

        Interactive dropdown panel
        perfect for notifications
        and activity feeds.

      </p>

      <div class="dropdown-wrapper notification-wrap">

        <button class="dropdown-btn notification-btn">

          <i class="fa-solid fa-bell"></i>

          Notifications

          <span class="badge">
            4
          </span>

        </button>

        <div class="dropdown-menu notification-menu">

          <div class="notify-item">

            <div class="notify-icon green">
              <i class="fa-solid fa-check"></i>
            </div>

            <div>

              <strong>
                Deployment Successful
              </strong>

              <span>
                2 min ago
              </span>

            </div>

          </div>

          <div class="notify-item">

            <div class="notify-icon purple-bg">
              <i class="fa-solid fa-code"></i>
            </div>

            <div>

              <strong>
                New Component Added
              </strong>

              <span>
                10 min ago
              </span>

            </div>

          </div>

          <div class="notify-item">

            <div class="notify-icon orange-bg">
              <i class="fa-solid fa-fire"></i>
            </div>

            <div>

              <strong>
                Trending UI Layout
              </strong>

              <span>
                1 hour ago
              </span>

            </div>

          </div>

        </div>

      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code3', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code3', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code3" class="code-block"><code>&lt;div class="dropdown-wrapper notification-wrap"&gt;
  &lt;button class="dropdown-btn notification-btn"&gt;
    &lt;i class="fa-solid fa-bell"&gt;&lt;/i&gt; Notifications
    &lt;span class="badge"&gt;4&lt;/span&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu notification-menu"&gt;
    &lt;div class="notify-item"&gt;
      &lt;div class="notify-icon green"&gt;&lt;i class="fa-solid fa-check"&gt;&lt;/i&gt;&lt;/div&gt;
      &lt;div&gt;
        &lt;strong&gt;Deployment Successful&lt;/strong&gt;
        &lt;span&gt;2 min ago&lt;/span&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="notify-item"&gt;
      &lt;div class="notify-icon purple-bg"&gt;&lt;i class="fa-solid fa-code"&gt;&lt;/i&gt;&lt;/div&gt;
      &lt;div&gt;
        &lt;strong&gt;New Component Added&lt;/strong&gt;
        &lt;span&gt;10 min ago&lt;/span&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="notify-item"&gt;
      &lt;div class="notify-icon orange-bg"&gt;&lt;i class="fa-solid fa-fire"&gt;&lt;/i&gt;&lt;/div&gt;
      &lt;div&gt;
        &lt;strong&gt;Trending UI Layout&lt;/strong&gt;
        &lt;span&gt;1 hour ago&lt;/span&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>

    </div>

    <!-- 4. MULTI-LEVEL DROPDOWN -->
    <div class="dropdown-card">
      <div class="card-top">
        <span class="card-label">
          NESTED MENU
        </span>
        <div class="card-icon teal-grad">
          <i class="fa-solid fa-folder-tree"></i>
        </div>
      </div>
      <h2>
        Nested Dropdown
      </h2>
      <p>
        Tiered option menus that reveal secondary slide-out panels on hover.
      </p>
      <div class="dropdown-wrapper multilevel-wrap">
        <button class="dropdown-btn">
          <span>Options Menu</span>
          <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="dropdown-menu">
          <div class="dropdown-item">
            <i class="fa-solid fa-file-export"></i>
            <span>Share Project</span>
            <i class="fa-solid fa-chevron-right submenu-arrow"></i>
            <div class="dropdown-submenu">
              <div class="dropdown-item">
                <i class="fa-solid fa-envelope"></i>
                <span>Email Link</span>
              </div>
              <div class="dropdown-item">
                <i class="fa-solid fa-link"></i>
                <span>Copy Link</span>
              </div>
              <div class="dropdown-item">
                <i class="fa-brands fa-slack"></i>
                <span>Slack</span>
              </div>
            </div>
          </div>
          <div class="dropdown-item">
            <i class="fa-solid fa-pen-to-square"></i>
            <span>Preferences</span>
            <i class="fa-solid fa-chevron-right submenu-arrow"></i>
            <div class="dropdown-submenu">
              <div class="dropdown-item">
                <i class="fa-solid fa-user-lock"></i>
                <span>Permissions</span>
              </div>
              <div class="dropdown-item">
                <i class="fa-solid fa-palette"></i>
                <span>Themes</span>
              </div>
            </div>
          </div>
          <div class="dropdown-item">
            <i class="fa-solid fa-download"></i>
            <span>Export Raw File</span>
          </div>
        </div>
      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code4', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code4', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code4" class="code-block"><code>&lt;div class="dropdown-wrapper multilevel-wrap"&gt;
  &lt;button class="dropdown-btn"&gt;
    &lt;span&gt;Options Menu&lt;/span&gt;
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu"&gt;
    &lt;div class="dropdown-item"&gt;
      &lt;i class="fa-solid fa-file-export"&gt;&lt;/i&gt; Share Project
      &lt;i class="fa-solid fa-chevron-right submenu-arrow"&gt;&lt;/i&gt;
      &lt;div class="dropdown-submenu"&gt;
        &lt;div class="dropdown-item"&gt;Email Link&lt;/div&gt;
        &lt;div class="dropdown-item"&gt;Copy Link&lt;/div&gt;
        &lt;div class="dropdown-item"&gt;Slack&lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="dropdown-item"&gt;
      &lt;i class="fa-solid fa-pen-to-square"&gt;&lt;/i&gt; Preferences
      &lt;i class="fa-solid fa-chevron-right submenu-arrow"&gt;&lt;/i&gt;
      &lt;div class="dropdown-submenu"&gt;
        &lt;div class="dropdown-item"&gt;Permissions&lt;/div&gt;
        &lt;div class="dropdown-item"&gt;Themes&lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="dropdown-item"&gt;&lt;i class="fa-solid fa-download"&gt;&lt;/i&gt; Export Raw File&lt;/div&gt;
