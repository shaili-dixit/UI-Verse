  &lt;button class="dropdown-btn profile-btn"&gt;
    &lt;img src="https://i.pravatar.cc/100?img=13" alt=""&gt;
    &lt;span&gt;UIverse Studio&lt;/span&gt;
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu workspace-menu"&gt;
    &lt;div class="dropdown-item active-team"&gt;...&lt;/div&gt;
    &lt;div class="dropdown-item"&gt;...&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
    </div>

    <!-- 12. DATE RANGE DROPDOWN -->
    <div class="dropdown-card">
      <div class="card-top">
        <span class="card-label">
          ANALYTICS
        </span>
        <div class="card-icon yellow-grad">
          <i class="fa-solid fa-calendar-days"></i>
        </div>
      </div>
      <h2>
        Date Range
      </h2>
      <p>
        Compact date range picker layout for dashboards (static UI, no calendar JS).
      </p>
      <div class="dropdown-wrapper daterange-wrap">
        <button class="dropdown-btn">
          <span>Last 30 days</span>
          <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="dropdown-menu daterange-menu">
          <div class="range-presets">
            <div class="dropdown-item"><span>Today</span></div>
            <div class="dropdown-item"><span>Last 7 days</span></div>
            <div class="dropdown-item"><span>Last 30 days</span></div>
            <div class="dropdown-item"><span>This quarter</span></div>
          </div>
          <div class="range-divider"></div>
          <div class="range-fields">
            <label class="range-field">
              <span>From</span>
              <input type="text" value="Apr 20, 2026" readonly>
            </label>
            <label class="range-field">
              <span>To</span>
              <input type="text" value="May 20, 2026" readonly>
            </label>
          </div>
          <div class="range-actions">
            <button class="range-btn ghost">Cancel</button>
            <button class="range-btn primary">Apply</button>
          </div>
        </div>
      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code12', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code12', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code12" class="code-block"><code>&lt;div class="dropdown-wrapper daterange-wrap"&gt;
  &lt;button class="dropdown-btn"&gt;
    &lt;span&gt;Last 30 days&lt;/span&gt;
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu daterange-menu"&gt;...&lt;/div&gt;
&lt;/div&gt;</code></pre>
    </div>

    <!-- 13. PRIORITY SORT DROPDOWN -->
    <div class="dropdown-card">
      <div class="card-top">
        <span class="card-label">
          SORTING
        </span>
        <div class="card-icon purple">
          <i class="fa-solid fa-arrow-up-wide-short"></i>
        </div>
      </div>
      <h2>
        Priority Sort
      </h2>
      <p>
        Radio-style sort options with an inline check indicator and descriptions.
      </p>
      <div class="dropdown-wrapper sort-wrap">
        <button class="dropdown-btn">
          <span>Sort: Recommended</span>
          <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="dropdown-menu sort-menu">
          <div class="dropdown-item sort-item active-sort">
            <div class="sort-text">
              <strong>Recommended</strong>
              <span>Balanced for most lists</span>
            </div>
            <i class="fa-solid fa-circle-check check-icon"></i>
          </div>
          <div class="dropdown-item sort-item">
            <div class="sort-text">
              <strong>Newest</strong>
              <span>Recently updated first</span>
            </div>
            <i class="fa-solid fa-circle check-icon empty"></i>
          </div>
          <div class="dropdown-item sort-item">
            <div class="sort-text">
              <strong>Highest priority</strong>
              <span>Urgent tasks on top</span>
            </div>
            <i class="fa-solid fa-circle check-icon empty"></i>
          </div>
        </div>
      </div>

      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('code13', this)">
          <i class="fa-solid fa-code"></i> View Code
        </button>
        <button class="action-btn copy-btn" onclick="copyCode('code13', this)">
          <i class="fa-solid fa-copy"></i> Copy
        </button>
      </div>

      <pre id="code13" class="code-block"><code>&lt;div class="dropdown-wrapper sort-wrap"&gt;
  &lt;button class="dropdown-btn"&gt;
    &lt;span&gt;Sort: Recommended&lt;/span&gt;
    &lt;i class="fa-solid fa-chevron-down"&gt;&lt;/i&gt;
  &lt;/button&gt;
  &lt;div class="dropdown-menu sort-menu"&gt;
    &lt;div class="dropdown-item sort-item"&gt;...&lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</code></pre>
    </div>

  </section>

</main>
