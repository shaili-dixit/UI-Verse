<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>Checkbox UI — UIverse</title>

  <!-- Fonts -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  >

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;700&display=swap"
    rel="stylesheet"
  >

  <!-- Icons -->

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  >

  <!-- CSS -->

  <link
    rel="stylesheet"
    href="checkboxs.css"
  >

</head>

<body>

<!-- =====================================================
SIDEBAR
===================================================== -->

<aside class="sidebar">

  <div>

    <div class="sidebar-brand">

      <div class="brand-icon">
        ⬡
      </div>

      <div class="brand-text">
        UIverse
      </div>

    </div>

    <nav class="sidebar-nav">

      <a href="#">
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
      </a>

      <a
        href="#"
        class="active"
      >
        <i class="fa-solid fa-square-check"></i>
        <span>Checkbox UI</span>
      </a>

      <a href="#">
        <i class="fa-solid fa-layer-group"></i>
        <span>Components</span>
      </a>

      <a href="#">
        <i class="fa-solid fa-code"></i>
        <span>Source</span>
      </a>

      <a href="#">
        <i class="fa-solid fa-book"></i>
        <span>Docs</span>
      </a>

    </nav>

  </div>

  <div class="sidebar-footer">

    <a href="#">
      <i class="fab fa-github"></i>
    </a>

    <a href="#">
      <i class="fab fa-discord"></i>
    </a>

    <a href="#">
      <i class="fab fa-x-twitter"></i>
    </a>

  </div>

</aside>

<!-- =====================================================
NAVBAR
===================================================== -->

<header class="navbar">

  <div class="search-bar">

    <i class="fa-solid fa-magnifying-glass"></i>

    <input
      type="text"
      placeholder="Search checkbox components..."
    >

  </div>

  <div class="nav-actions">

    <button class="outline-btn">
      Documentation
    </button>

    <button class="primary-btn">
      Explore UI
    </button>

  </div>

</header>

<!-- =====================================================
MAIN
===================================================== -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-left">

      <div class="hero-badge">
        ✦ Selection Components
      </div>

      <h1>
        Modern <span>Checkbox</span>
      </h1>

      <p>

        Beautiful futuristic checkbox
        components for dashboards,
        forms and premium interfaces.

      </p>

      <div class="hero-tags">

        <span>
          Resources
        </span>

        <span>
          UI Kit
        </span>

        <span>
          +12
        </span>

      </div>

    </div>

    <div class="hero-preview">

      <div class="preview-card">

        <div class="preview-header">
          Allow Access
        </div>

        <div class="check-list">

          <!-- ITEM -->

          <label class="check-item">

            <div>

              <strong>
                Microphone Access
              </strong>

              <span>
                Enable voice permissions
              </span>

            </div>

            <div class="checkbox-wrapper">

              <input
                type="checkbox"
                checked
              >

              <span class="custom-checkbox"></span>

            </div>

          </label>

          <!-- ITEM -->

          <label class="check-item">

            <div>

              <strong>
                Camera Access
              </strong>

              <span>
                Enable webcam support
              </span>

            </div>

            <div class="checkbox-wrapper">

              <input
                type="checkbox"
                checked
              >

              <span class="custom-checkbox"></span>

            </div>

          </label>

          <!-- ITEM -->

          <label class="check-item">

            <div>

              <strong>
                Notifications
              </strong>

              <span>
                Receive instant alerts
              </span>

            </div>

            <div class="checkbox-wrapper">

              <input
                type="checkbox"
              >

              <span class="custom-checkbox"></span>

            </div>

          </label>

          <!-- ITEM -->

          <label class="check-item">

            <div>

              <strong>
                Analytics Tracking
              </strong>

              <span>
                Improve user experience
              </span>

            </div>

            <div class="checkbox-wrapper">

              <input
                type="checkbox"
              >

              <span class="custom-checkbox"></span>

            </div>

          </label>

        </div>

      </div>

    </div>

  </section>

  <!-- COMPONENTS -->

  <section class="checkbox-grid">

    <!-- BASIC -->

    <div class="checkbox-card">

      <div class="card-top">

        <span class="card-label">
          BASIC
        </span>

        <div class="card-icon purple">
          <i class="fa-solid fa-check"></i>
        </div>

      </div>

      <h2>
        Simple Checkbox
      </h2>

      <p>

        Minimal modern checkbox
        for forms and clean UI layouts.

      </p>

      <label class="checkbox-style">

        <input
          type="checkbox"
          checked
        >

        <span class="checkbox-ui"></span>

        <span>
          Accept Terms & Conditions
        </span>

      </label>

    </div>

    <!-- GLOW -->

    <div class="checkbox-card">

      <div class="card-top">

        <span class="card-label">
          GLOW
        </span>

        <div class="card-icon blue">
          <i class="fa-solid fa-bolt"></i>
        </div>

      </div>

      <h2>
        Neon Checkbox
      </h2>

      <p>

        Futuristic glowing checkbox
        with animated neon effects.

      </p>

      <label class="checkbox-style glow-check">

        <input
          type="checkbox"
        >

        <span class="checkbox-ui"></span>

        <span>
          Enable Experimental Features
        </span>

      </label>

    </div>

    <!-- TASK -->

    <div class="checkbox-card">

      <div class="card-top">

        <span class="card-label">
          TASK
        </span>

        <div class="card-icon orange">
          <i class="fa-solid fa-list-check"></i>
        </div>

      </div>

      <h2>
        Task Checkbox
      </h2>

      <p>

        Interactive task completion
        checkbox for kanban systems.

      </p>

      <div class="task-list-ui">

        <label class="task-item">

          <input
            type="checkbox"
            checked
          >

          <span>
            Build dashboard page
          </span>

        </label>

        <label class="task-item">

          <input
            type="checkbox"
          >

          <span>
            Design profile cards
          </span>

        </label>

        <label class="task-item">

          <input
            type="checkbox"
          >

          <span>
            Deploy UIverse update
          </span>

        </label>

      </div>

    </div>

  </section>

</main>
<!-- ================= FOOTER ================= -->
