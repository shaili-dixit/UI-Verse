<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8" />

  <meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-hashes'; script-src-attr 'unsafe-hashes'; style-src 'self' https: 'unsafe-inline'; style-src-attr 'unsafe-inline'"
  />

  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Pricing Plans</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- CSS -->
  <link rel="stylesheet" href="pricingpage.css" />
</head>

<body>

  <!-- Pricing Section -->
  <section class="pricing">

    <div class="heading">
      <h1>Our Pricing Plans</h1>
      <p>Choose a plan that perfectly fits your needs.</p>
    </div>

    <div class="cards">

      <!-- Basic -->
      <div class="card">
        <h2>Basic</h2>

        <div class="price">
          ₹299<span>/month</span>
        </div>

        <ul>
          <li>5 UI Components</li>
          <li>Email Support</li>
          <li>Free Updates</li>
          <li>Community Access</li>
        </ul>

        <button>Get Started</button>
      </div>

      <!-- Pro -->
      <div class="card popular">

        <span class="tag">POPULAR</span>

        <h2>Pro</h2>

        <div class="price">
          ₹799<span>/month</span>
        </div>

        <ul>
          <li>Unlimited Components</li>
          <li>Priority Support</li>
          <li>Premium Templates</li>
          <li>Weekly Updates</li>
          <li>Advanced Animations</li>
        </ul>

        <button>Buy Now</button>
      </div>

      <!-- Enterprise -->
      <div class="card">
        <h2>Enterprise</h2>

        <div class="price">
          ₹1499<span>/month</span>
        </div>

        <ul>
          <li>Team Access</li>
          <li>Custom UI Design</li>
          <li>24/7 Support</li>
          <li>Advanced Features</li>
          <li>Dedicated Manager</li>
        </ul>

        <button>Contact Us</button>
      </div>

    </div>

  </section>

  <!-- Footer -->
  <footer>

    <h3>UIverse Pricing</h3>

    <p>
      Modern UI components & templates for developers and designers.
    </p>

    <div class="footer-links">
      <a href="#">Home</a>
      <a href="#">Pricing</a>
      <a href="#">Templates</a>
      <a href="#">Support</a>
      <a href="#">Contact</a>
    </div>

    <p class="copyright">
      © 2026 UIverse. All rights reserved.
    </p>

  </footer>

  <script src="dist/shared.js"></script>
</body>
</html>