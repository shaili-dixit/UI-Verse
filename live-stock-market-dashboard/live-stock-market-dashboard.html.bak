<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0" />

  <title>TradePulse — Live Stock Market Dashboard</title>

  <!-- Google Fonts -->

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap"
    rel="stylesheet">

  <!-- Font Awesome -->

  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- CSS -->

  <link rel="stylesheet"
    href="live-stock-market-dashboard.css" />

</head>

<body>

  <!-- ================= SIDEBAR ================= -->

  <aside class="sidebar">

    <div class="logo">
      📈 TradePulse
    </div>

    <nav class="sidebar-nav">

      <a href="#" class="active">
        <i class="fa-solid fa-chart-line"></i>
        Overview
      </a>

      <a href="#">
        <i class="fa-solid fa-arrow-trend-up"></i>
        Markets
      </a>

      <a href="#">
        <i class="fa-solid fa-wallet"></i>
        Portfolio
      </a>

      <a href="#">
        <i class="fa-solid fa-star"></i>
        Watchlist
      </a>

      <a href="#">
        <i class="fa-solid fa-bell"></i>
        Alerts
      </a>

      <a href="#">
        <i class="fa-solid fa-gear"></i>
        Settings
      </a>

    </nav>

    <!-- WALLET CARD -->

    <div class="portfolio-card">

      <h3>
        💰 Portfolio Value
      </h3>

      <h2>
        $284,320
      </h2>

      <p>
        +12.4% This Month
      </p>

      <button>
        Invest More
      </button>

    </div>

  </aside>

  <!-- ================= MAIN ================= -->

  <main class="main">

    <!-- TOPBAR -->

    <header class="topbar">

      <div>

        <h1>
          Live Stock Market Dashboard 📊
        </h1>

        <p>
          Track real-time stock movements, monitor your portfolio and analyze market trends.
        </p>

      </div>

      <div class="top-actions">

        <div class="search-box">

          <i class="fa-solid fa-magnifying-glass"></i>

          <input
            type="text"
            placeholder="Search stocks..." />

        </div>

        <button class="profile-btn">

          <img
            src="https://i.pravatar.cc/100?img=14"
            alt="profile">

        </button>

      </div>

    </header>

    <!-- HERO -->

    <section class="hero">

      <div class="hero-content">

        <span class="hero-badge">
          🚀 Market Highlights
        </span>

        <h2>
          Smart Investing <br>
          Starts Here 💹
        </h2>

        <p>
          Analyze stock performance, track investments and get live insights from global financial markets.
        </p>

        <div class="hero-buttons">

          <button class="trade-btn">
            Start Trading
          </button>

          <button class="watch-btn">
            View Watchlist
          </button>

        </div>

      </div>

      <!-- MARKET CARD -->

      <div class="market-card">

        <div class="market-header">

          <div>

            <h3>
              NASDAQ
            </h3>

            <p>
              Real-time Market Index
            </p>

          </div>

          <span class="green">
            +2.84%
          </span>

        </div>

        <div class="chart">

          <div class="line"></div>

        </div>

        <div class="market-stats">

          <div>

            <h4>
              18,450
            </h4>

            <p>
              Current
            </p>

          </div>

          <div>

            <h4>
              18,120
            </h4>

            <p>
              Open
            </p>

          </div>

          <div>

            <h4>
              18,510
            </h4>

            <p>
              High
            </p>

          </div>

        </div>

      </div>

    </section>

    <!-- STATS -->

    <section class="stats-grid">

      <div class="stat-card">

        <h2>
          1.2K+
        </h2>

        <p>
          Stocks Tracked
        </p>

      </div>

      <div class="stat-card">

        <h2>
          84%
        </h2>

        <p>
          Portfolio Growth
        </p>

      </div>

      <div class="stat-card">

        <h2>
          $8.5M
        </h2>

        <p>
          Trading Volume
        </p>

      </div>

      <div class="stat-card">

        <h2>
          24/7
        </h2>

        <p>
          Market Insights
        </p>

      </div>

    </section>

    <!-- STOCK TABLE -->

    <section class="stocks-section">

      <div class="section-header">

        <h2>
          📈 Trending Stocks
        </h2>

        <button>
          View All
        </button>

      </div>

      <div class="stock-table">

        <div class="table-header">

          <span>Company</span>
          <span>Price</span>
          <span>Change</span>
          <span>Status</span>

        </div>

        <!-- ROW -->

        <div class="table-row">

          <div class="company">

            <div class="icon purple">
              A
            </div>

            <div>

              <h4>
                Apple Inc.
              </h4>

              <p>
                AAPL
              </p>

            </div>

          </div>

          <span>
            $214.25
          </span>

          <span class="green">
            +4.8%
          </span>

          <button class="buy-btn">
            Buy
          </button>

        </div>

        <!-- ROW -->

        <div class="table-row">

          <div class="company">

            <div class="icon blue">
              T
            </div>

            <div>

              <h4>
                Tesla
              </h4>

              <p>
                TSLA
              </p>

            </div>

          </div>

          <span>
            $684.12
          </span>

          <span class="red">
            -2.1%
          </span>

          <button class="buy-btn">
            Buy
          </button>

        </div>

        <!-- ROW -->

        <div class="table-row">

          <div class="company">

            <div class="icon pink">
              N
            </div>

            <div>

              <h4>
                NVIDIA
              </h4>

              <p>
                NVDA
              </p>

            </div>

          </div>

          <span>
            $982.40
          </span>

          <span class="green">
            +8.5%
          </span>

          <button class="buy-btn">
            Buy
          </button>

        </div>

      </div>

    </section>

    <!-- ACTIVITY -->

    <section class="activity-grid">

      <!-- RECENT TRANSACTIONS -->

      <div class="activity-card">

        <h2>
          ⚡ Recent Transactions
        </h2>

        <div class="transaction-list">

          <div class="transaction">

            <div>

              <h4>
                Bought Apple Shares
              </h4>

              <p>
                10 Shares • Today
              </p>

            </div>

            <span class="green">
              +$2,140
            </span>

          </div>

          <div class="transaction">

            <div>

              <h4>
                Sold Tesla Shares
              </h4>

              <p>
                5 Shares • Yesterday
              </p>

            </div>

            <span class="red">
              -$3,420
            </span>

          </div>

          <div class="transaction">

            <div>

              <h4>
                Bought NVIDIA Shares
              </h4>

              <p>
                2 Shares • Today
              </p>

            </div>

            <span class="green">
              +$1,964
            </span>

          </div>

        </div>

      </div>

      <!-- ANALYTICS -->

      <div class="analytics-card">

        <h2>
          📉 Portfolio Split
        </h2>

        <div class="circle-chart">

          <div class="circle-inner">
            68%
          </div>

        </div>

        <div class="legend">

          <div>
            <span class="dot purple"></span>
            Tech
          </div>

          <div>
            <span class="dot blue"></span>
            Crypto
          </div>

          <div>
            <span class="dot pink"></span>
            Energy
          </div>

        </div>

      </div>

    </section>

  </main>

  <!-- JS -->

  <script src="live-stock-market-dashboard.js"></script>

    <script src="../dist/shared.js"></script>
</body>

</html>