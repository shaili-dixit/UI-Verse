<!-- Updated HTML -->

<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Battery Health Indicator</title>
  </head>
<body>

  <div class="battery-container">

    <h1>Battery Health</h1>

    <div class="battery-wrapper">
      <div class="battery">
        <div class="battery-level" id="batteryLevel"></div>
      </div>

      <div class="battery-cap"></div>
    </div>

    <h2 id="percentage">75%</h2>

    <p class="status">Battery status is stable ⚡</p>

    <button id="chargeBtn">Charge Battery</button>

  </div>

      <script src="../dist/shared.js"></script>
</body>
</html>