<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patterns — UIverse</title>

  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <link rel="stylesheet" href="patterns.css">
</head>
<body data-playground-type="pattern">

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <span class="brand-icon">⬡</span>
      <span class="brand-text">UIverse <span class="brand-badge">V2</span></span>
    </div>

    <nav class="sidebar-nav">
      <ul>
        <li>
          <a href="index.html">
            <i class="fa-solid fa-house"></i>
            <span>Home</span>
          </a>
        </li>
        <li>
          <a href="breadcrumbs.html">
            <i class="fa-solid fa-angles-right"></i>
            <span>Breadcrumbs</span>
          </a>
        </li>
        <li>
          <a href="cards.html">
            <i class="fa-solid fa-table-cells-large"></i>
            <span>Cards</span>
          </a>
        </li>
        <li>
          <a href="inputs.html">
            <i class="fa-solid fa-keyboard"></i>
            <span>Inputs</span>
          </a>
        </li>
        <li>
          <a href="button.html">
            <i class="fa-solid fa-hand-pointer"></i>
            <span>Buttons</span>
          </a>
        </li>
        <li class="active">
          <a href="patterns.html">
            <i class="fa-solid fa-layer-group"></i>
            <span>Patterns</span>
          </a>
        </li>
      </ul>
    </nav>

    <div class="sidebar-footer">
      <a href="#" aria-label="GitHub" title="GitHub"><i class="fab fa-github"></i></a>
      <a href="#" aria-label="LinkedIn" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
      <a href="#" aria-label="Twitter" title="Twitter"><i class="fab fa-x-twitter"></i></a>
    </div>
  </aside>

  <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

  <header class="navbar" id="navbar">
    <button type="button" class="menu-toggle" onclick="toggleSidebar()" aria-label="Toggle Sidebar Navigation">
      <i class="fa-solid fa-bars"></i>
    </button>
    <div class="logo">UIverse</div>
    <div class="search-bar">
      <i class="fa-solid fa-magnifying-glass search-icon"></i>
      <input type="text" id="searchInput" placeholder="Search patterns..." oninput="liveFilter(this.value)">
      <kbd class="search-kbd">⌘K</kbd>
    </div>
    <div class="nav-right">
      <button type="button" class="nav-btn outline-nav-btn"><i class="fa-solid fa-plus"></i> Add Component</button>
      <a href="MyCollection.html" class="nav-btn primary-nav-btn"><i class="fa-solid fa-bookmark"></i> My Collection</a>
      <button type="button" id="darkModeToggle" class="theme-toggle" aria-label="Toggle Dark Mode"><i class="fa-solid fa-moon"></i></button>
    </div>
  </header>

  <main class="main-home">
    <section class="page-hero pattern-hero">
      <div class="page-hero-left">
        <div class="breadcrumb">
          <a href="index.html">Home</a>
          <i class="fa-solid fa-chevron-right"></i>
          <span>Patterns</span>
        </div>
        <h1 class="page-title">Reusable Pattern Components</h1>
        <p class="page-desc">A compact library of background patterns and layout textures you can drop into modern interfaces. Each tile is built for easy reuse in cards, covers, and section backgrounds.</p>
        <div class="page-meta">
          <span class="meta-badge"><i class="fa-solid fa-layer-group"></i> 5 Components</span>
          <span class="meta-badge"><i class="fa-solid fa-bolt"></i> Ready to Reuse</span>
          <span class="meta-badge"><i class="fa-solid fa-palette"></i> Background Patterns</span>
        </div>
      </div>
      <div class="page-hero-right pattern-hero-art">
        <div class="pattern-swatch pattern-swatch-1"></div>
        <div class="pattern-swatch pattern-swatch-2"></div>
        <div class="pattern-swatch pattern-swatch-3"></div>
      </div>
    </section>

    <section class="patterns-section">
      <div class="section-header-row">
        <h2 class="inputs-section-title">Pattern Gallery</h2>
        <span class="section-count">5 components</span>
      </div>

      <div class="patterns-grid">
        <article class="component-card pattern-card" data-name="diagonal blocks geometric purple" data-sec="geometric">
          <div class="card-top">
            <span class="card-label">Diagonal Blocks</span>
            <span class="card-tag tag-popular">Popular</span>
          </div>
          <div class="card-preview pattern-preview pattern-diagonal-blocks">
            <span class="pattern-preview-label">Geometric</span>
          </div>
          <p class="card-desc">A bold diagonal block pattern for hero cards and premium section fills.</p>
          <div class="actions">
            <button type="button" class="action-btn view-btn" onclick="toggleCode('p1', this)"><i class="fa-solid fa-code"></i> View Code</button>
            <button type="button" class="action-btn copy-btn" onclick="copyCode('p1', this)"><i class="fa-solid fa-copy"></i> Copy</button>
          </div>
          <pre id="p1" class="code-block"><code>&lt;div class="pattern-diagonal-blocks"&gt;&lt;/div&gt;</code></pre>
        </article>

        <article class="component-card pattern-card" data-name="triangular tessellation grid pattern" data-sec="geometric">
          <div class="card-top">
            <span class="card-label">Triangular Tessellation</span>
            <span class="card-tag tag-essential">Essential</span>
          </div>
          <div class="card-preview pattern-preview pattern-triangles">
            <span class="pattern-preview-label">Tessellation</span>
          </div>
          <p class="card-desc">A sharp triangle lattice inspired by poster design and abstract UI backgrounds.</p>
          <div class="actions">
            <button type="button" class="action-btn view-btn" onclick="toggleCode('p2', this)"><i class="fa-solid fa-code"></i> View Code</button>
            <button type="button" class="action-btn copy-btn" onclick="copyCode('p2', this)"><i class="fa-solid fa-copy"></i> Copy</button>
          </div>
          <pre id="p2" class="code-block"><code>&lt;div class="pattern-triangles"&gt;&lt;/div&gt;</code></pre>
        </article>

        <article class="component-card pattern-card" data-name="soft grid subtle monochrome pattern" data-sec="grid">
          <div class="card-top">
            <span class="card-label">Soft Grid</span>
            <span class="card-tag tag-trending">Trending</span>
          </div>
          <div class="card-preview pattern-preview pattern-soft-grid">
            <span class="pattern-preview-label">Minimal</span>
          </div>
          <p class="card-desc">A restrained grid texture for dashboards, documentation, and neutral panels.</p>
          <div class="actions">
            <button type="button" class="action-btn view-btn" onclick="toggleCode('p3', this)"><i class="fa-solid fa-code"></i> View Code</button>
            <button type="button" class="action-btn copy-btn" onclick="copyCode('p3', this)"><i class="fa-solid fa-copy"></i> Copy</button>
          </div>
          <pre id="p3" class="code-block"><code>&lt;div class="pattern-soft-grid"&gt;&lt;/div&gt;</code></pre>
        </article>

        <article class="component-card pattern-card" data-name="grain mesh texture magenta dark" data-sec="texture">
          <div class="card-top">
            <span class="card-label">Grain Mesh</span>
            <span class="card-tag tag-new">New</span>
          </div>
          <div class="card-preview pattern-preview pattern-grain-mesh">
            <span class="pattern-preview-label">Texture</span>
          </div>
          <p class="card-desc">A textured mesh surface with depth for feature banners and editorial panels.</p>
          <div class="actions">
            <button type="button" class="action-btn view-btn" onclick="toggleCode('p4', this)"><i class="fa-solid fa-code"></i> View Code</button>
            <button type="button" class="action-btn copy-btn" onclick="copyCode('p4', this)"><i class="fa-solid fa-copy"></i> Copy</button>
          </div>
          <pre id="p4" class="code-block"><code>&lt;div class="pattern-grain-mesh"&gt;&lt;/div&gt;</code></pre>
        </article>

        <article class="component-card pattern-card" data-name="stacked wave stripes pattern" data-sec="wave">
          <div class="card-top">
            <span class="card-label">Stacked Waves</span>
            <span class="card-tag tag-warning">Featured</span>
          </div>
          <div class="card-preview pattern-preview pattern-wave-rows">
            <span class="pattern-preview-label">Motion</span>
          </div>
          <p class="card-desc">Layered curves that work well for playful headers, banners, and background accents.</p>
          <div class="actions">
            <button type="button" class="action-btn view-btn" onclick="toggleCode('p5', this)"><i class="fa-solid fa-code"></i> View Code</button>
            <button type="button" class="action-btn copy-btn" onclick="copyCode('p5', this)"><i class="fa-solid fa-copy"></i> Copy</button>
          </div>
          <pre id="p5" class="code-block"><code>&lt;div class="pattern-wave-rows"&gt;&lt;/div&gt;</code></pre>
        </article>
      </div>
    </section>
  </main>

  <button type="button" id="scrollTopBtn" onclick="scrollToTop()" title="Back to top">
    <i class="fa-solid fa-chevron-up"></i>
  </button>

  <footer class="footer">
    <div class="footer-container">
      <div class="footer-col brand">
        <h2 class="footer-logo">⬡ UIverse</h2>
        <p>Build modern reusable UI components with clean HTML, CSS, and JavaScript.</p>
        <div class="socials">
          <a href="#" aria-label="GitHub"><i class="fab fa-github"></i></a>
          <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin"></i></a>
          <a href="#" aria-label="Twitter"><i class="fab fa-x-twitter"></i></a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2026 UIverse. Made with ❤️ for developers worldwide.</p>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById('darkModeToggle');
    const icon = toggle.querySelector('i');

    if (localStorage.getItem('theme') === 'dark') {
      document.body.classList.add('dark-mode');
      icon.className = 'fa-solid fa-sun';
    }

    toggle.addEventListener('click', () => {
      document.body.classList.toggle('dark-mode');
      const isDark = document.body.classList.contains('dark-mode');
      icon.className = isDark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });

    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarBackdrop').classList.toggle('visible');
    }

    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    window.addEventListener('scroll', () => {
      document.getElementById('scrollTopBtn').classList.toggle('visible', window.scrollY > 400);
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
    });

    function toggleCode(id, btn) {
      const block = document.getElementById(id);
      const isOpen = block.classList.toggle('open');
      btn.innerHTML = isOpen ? '<i class="fa-solid fa-eye-slash"></i> Hide Code' : '<i class="fa-solid fa-code"></i> View Code';
    }

    function copyCode(id, btn) {
      navigator.clipboard.writeText(document.getElementById(id).innerText).then(() => {
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = '<i class="fa-solid fa-copy"></i> Copy';
          btn.classList.remove('copied');
        }, 1600);
      });
    }

    function liveFilter(val) {
      const q = val.toLowerCase();
      document.querySelectorAll('.component-card').forEach(card => {
        const name = card.dataset.name.toLowerCase();
        const label = card.querySelector('.card-label')?.textContent.toLowerCase() || '';
        const match = name.includes(q) || label.includes(q);
        card.style.display = match ? '' : 'none';
      });
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('in-view'); });
      }, { threshold: 0.08 });
      document.querySelectorAll('.component-card').forEach(el => observer.observe(el));
      setTimeout(() => {
        document.querySelectorAll('.component-card').forEach(el => el.classList.add('in-view'));
      }, 300);
    } else {
      document.querySelectorAll('.component-card').forEach(el => el.classList.add('in-view'));
    }
  </script>
  <script src="dist/shared.js"></script>
</body>
</html>
