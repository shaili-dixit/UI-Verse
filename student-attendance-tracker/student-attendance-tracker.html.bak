<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0" />

  <title>Student Attendance Tracker UI</title>

  <!-- GOOGLE FONTS -->

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
    rel="stylesheet" />

  <!-- FONT AWESOME -->

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- CSS -->

  <link
    rel="stylesheet"
    href="student-attendance-tracker.css" />

</head>

<body>

  <!-- SIDEBAR -->

  <aside class="sidebar">

    <div class="logo">
      🎓 EduTrack
    </div>

    <nav class="sidebar-menu">

      <a href="#" class="active">
        <i class="fa-solid fa-chart-line"></i>
        Dashboard
      </a>

      <a href="#">
        <i class="fa-solid fa-user-graduate"></i>
        Students
      </a>

      <a href="#">
        <i class="fa-solid fa-calendar-check"></i>
        Attendance
      </a>

      <a href="#">
        <i class="fa-solid fa-book-open"></i>
        Subjects
      </a>

      <a href="#">
        <i class="fa-solid fa-chart-pie"></i>
        Reports
      </a>

      <a href="#">
        <i class="fa-solid fa-bell"></i>
        Notifications
      </a>

      <a href="#">
        <i class="fa-solid fa-gear"></i>
        Settings
      </a>

    </nav>

    <!-- ATTENDANCE CARD -->

    <div class="attendance-card">

      <span>
        📘 Monthly Attendance
      </span>

      <h2>
        94%
      </h2>

      <p>
        Student attendance performance improved by 8% compared to last month.
      </p>

      <button>
        View Reports
      </button>

    </div>

  </aside>

  <!-- MAIN CONTENT -->

  <main class="main-content">

    <!-- TOPBAR -->

    <header class="topbar">

      <div>

        <h1>
          Student Attendance Tracker 📚
        </h1>

        <p>
          Track attendance records, monitor performance and manage student data efficiently.
        </p>

      </div>

      <div class="top-actions">

        <div class="search-box">

          <i class="fa-solid fa-magnifying-glass"></i>

          <input
            type="text"
            placeholder="Search students..." />

        </div>

        <button class="notification-btn">
          <i class="fa-solid fa-bell"></i>
        </button>

        <button class="profile-btn">

          <img
            src="https://i.pravatar.cc/100?img=32"
            alt="profile" />

        </button>

      </div>

    </header>

    <!-- HERO -->

    <section class="hero-section">

      <div class="hero-content">

        <span class="hero-badge">
          ⚡ Smart Attendance System
        </span>

        <h2>
          Monitor Attendance <br>
          Improve Performance
        </h2>

        <p>
          Manage attendance records, analyze classroom participation and generate detailed reports instantly.
        </p>

        <div class="hero-buttons">

          <button class="primary-btn">
            Mark Attendance
          </button>

          <button class="secondary-btn">
            Generate Report
          </button>

        </div>

      </div>

      <!-- CLASS CARD -->

      <div class="class-card">

        <div class="class-header">

          <span>
            🏫 Active Class
          </span>

          <i class="fa-solid fa-users"></i>

        </div>

        <h2>
          Computer Science - CSE 3A
        </h2>

        <p>
          Attendance tracking for today's session.
        </p>

        <div class="progress-section">

          <div class="progress-text">

            <span>
              Present Students
            </span>

            <span>
              42 / 48
            </span>

          </div>

          <div class="progress-bar">
            <div class="progress-fill"></div>
          </div>

        </div>

        <div class="class-footer">

          <div>

            <h4>
              Subject
            </h4>

            <p>
              Data Structures
            </p>

          </div>

          <div>

            <h4>
              Time
            </h4>

            <p>
              10:00 AM
            </p>

          </div>

        </div>

      </div>

    </section>

    <!-- STATS -->

    <section class="stats-grid">

      <div class="stat-card">

        <i class="fa-solid fa-user-check"></i>

        <div>

          <h2>
            1,248
          </h2>

          <p>
            Present Records
          </p>

        </div>

      </div>

      <div class="stat-card">

        <i class="fa-solid fa-user-xmark"></i>

        <div>

          <h2>
            82
          </h2>

          <p>
            Absent Records
          </p>

        </div>

      </div>

      <div class="stat-card">

        <i class="fa-solid fa-school"></i>

        <div>

          <h2>
            18
          </h2>

          <p>
            Active Classes
          </p>

        </div>

      </div>

      <div class="stat-card">

        <i class="fa-solid fa-chart-column"></i>

        <div>

          <h2>
            94%
          </h2>

          <p>
            Overall Attendance
          </p>

        </div>

      </div>

    </section>

    <!-- STUDENT TABLE -->

    <section class="table-section">

      <div class="section-header">

        <h2>
          🧑‍🎓 Student Attendance List
        </h2>

        <button>
          Export CSV
        </button>

      </div>

      <div class="table-wrapper">

        <table>

          <thead>

            <tr>

              <th>
                Student
              </th>

              <th>
                Roll No
              </th>

              <th>
                Subject
              </th>

              <th>
                Attendance
              </th>

              <th>
                Status
              </th>

            </tr>

          </thead>

          <tbody>

            <tr>

              <td class="student-cell">

                <img
                  src="https://i.pravatar.cc/50?img=11"
                  alt="" />

                Sophia Carter

              </td>

              <td>
                CSE101
              </td>

              <td>
                Data Structures
              </td>

              <td>
                96%
              </td>

              <td>
                <span class="status present">
                  Present
                </span>
              </td>

            </tr>

            <tr>

              <td class="student-cell">

                <img
                  src="https://i.pravatar.cc/50?img=18"
                  alt="" />

                Ethan Walker

              </td>

              <td>
                CSE102
              </td>

              <td>
                Operating Systems
              </td>

              <td>
                88%
              </td>

              <td>
                <span class="status absent">
                  Absent
                </span>
              </td>

            </tr>

            <tr>

              <td class="student-cell">

                <img
                  src="https://i.pravatar.cc/50?img=24"
                  alt="" />

                Olivia Brown

              </td>

              <td>
                CSE103
              </td>

              <td>
                DBMS
              </td>

              <td>
                92%
              </td>

              <td>
                <span class="status present">
                  Present
                </span>
              </td>

            </tr>

            <tr>

              <td class="student-cell">

                <img
                  src="https://i.pravatar.cc/50?img=31"
                  alt="" />

                Noah Wilson

              </td>

              <td>
                CSE104
              </td>

              <td>
                Computer Networks
              </td>

              <td>
                98%
              </td>

              <td>
                <span class="status present">
                  Present
                </span>
              </td>

            </tr>

          </tbody>

        </table>

      </div>

    </section>

    <!-- BOTTOM GRID -->

    <section class="bottom-grid">

      <!-- SUBJECTS -->

      <div class="subjects-card">

        <div class="section-header small">

          <h2>
            📖 Subjects
          </h2>

          <button>
            Add Subject
          </button>

        </div>

        <div class="subjects-grid">

          <div class="subject-item">

            <i class="fa-solid fa-code"></i>

            <h4>
              Programming
            </h4>

            <p>
              92% Attendance
            </p>

          </div>

          <div class="subject-item">

            <i class="fa-solid fa-database"></i>

            <h4>
              DBMS
            </h4>

            <p>
              88% Attendance
            </p>

          </div>

          <div class="subject-item">

            <i class="fa-solid fa-network-wired"></i>

            <h4>
              Networks
            </h4>

            <p>
              96% Attendance
            </p>

          </div>

          <div class="subject-item">

            <i class="fa-solid fa-microchip"></i>

            <h4>
              OS
            </h4>

            <p>
              90% Attendance
            </p>

          </div>

        </div>

      </div>

      <!-- INSIGHTS -->

      <div class="insights-card">

        <span class="insight-badge">
          📊 Attendance Insights
        </span>

        <h2>
          Performance Summary
        </h2>

        <p>
          Students with attendance above 90% show higher academic engagement and performance.
        </p>

        <div class="insight-stats">

          <div>

            <h3>
              86%
            </h3>

            <p>
              High Attendance
            </p>

          </div>

          <div>

            <h3>
              14%
            </h3>

            <p>
              Low Attendance
            </p>

          </div>

        </div>

        <button>
          Open Analytics
        </button>

      </div>

    </section>

  </main>

  <!-- JS -->

  <script src="student-attendance-tracker.js"></script>

    <script src="../dist/shared.js"></script>
</body>

</html>