<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Infinite Scroll Gallery</title>
  <link rel="stylesheet" href="gallery.css">
</head>
<body>

<h1>Infinite Scroll Gallery</h1>

<!-- SEARCH + FILTER BAR -->
<div class="toolbar">
  <input type="text" id="searchInput" placeholder="Search images..." />

  <select id="categoryFilter">
    <option value="all">All</option>
    <option value="nature">Nature</option>
    <option value="city">City</option>
    <option value="tech">Tech</option>
  </select>
</div>

<!-- GALLERY -->
<div class="gallery masonry" id="gallery"></div>

<!-- SKELETON LOADER -->
<div class="skeleton-container" id="skeleton">
  <div class="skeleton-card"></div>
  <div class="skeleton-card"></div>
  <div class="skeleton-card"></div>
</div>

<!-- LOADER -->
<div class="loader" id="loader">Loading more images...</div>

<!-- IMAGE MODAL -->
<div class="modal" id="modal">
  <span class="close" id="closeModal">&times;</span>
  <img id="modalImg" />
</div>

<script src="gallery.js"></script>
    <script src="../dist/shared.js"></script>
</body>
</html>