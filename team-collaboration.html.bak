<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>
    Team Collaboration UI | UIverse
  </title>

  <!-- GOOGLE FONTS -->

  <link
    href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- FONT AWESOME -->

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />

  <!-- CSS -->

  <link
    rel="stylesheet"
    href="team-collaboration.css"
  />

  <link
    rel="stylesheet"
    href="shared-sidebar.css"
  />

</head>

<body>

<!-- =========================================================
SIDEBAR
========================================================= -->

<aside class="sidebar">

  <div class="sidebar-brand">

    <div class="brand-icon">
      ⬡
    </div>

    <div class="brand-text">
      UIverse
    </div>

  </div>

  <nav class="sidebar-nav">

    <ul>

      <li>
        <a href="index.html">
          <i class="fa-solid fa-house"></i>
          <span>Home</span>
        </a>
      </li>

      <li class="active">
        <a href="team-collaboration.html">
          <i class="fa-solid fa-user-group"></i>
          <span>Team Collaboration</span>
        </a>
      </li>

      <li>
        <a href="dashboard.html">
          <i class="fa-solid fa-chart-line"></i>
          <span>Dashboard</span>
        </a>
      </li>

      <li>
        <a href="cards.html">
          <i class="fa-solid fa-layer-group"></i>
          <span>Cards</span>
        </a>
      </li>

    </ul>

  </nav>

</aside>

<!-- =========================================================
NAVBAR
========================================================= -->

<header class="navbar">

  <div class="logo">
    UIverse
  </div>

  <div class="search-bar">

    <i class="fa-solid fa-magnifying-glass"></i>

    <input
      type="text"
      placeholder="Search collaboration components..."
    />

  </div>

</header>

<!-- =========================================================
MAIN
========================================================= -->

<main class="main-home">

  <!-- HERO -->

  <section class="hero-section">

    <div class="hero-badge">
      🚀 Collaboration Components
    </div>

    <h1>
      Team Collaboration
      <span>UI Components</span>
    </h1>

    <p>

      Beautiful collaboration layouts crafted
      for productivity apps, workspace tools,
      project management dashboards and
      modern SaaS platforms.

    </p>

  </section>

  <!-- =========================================================
TEAM MEMBERS
========================================================= -->

  <section class="component-section">

    <div class="section-title">

      <span>
        Team Members
      </span>

      <h2>
        Workspace Team Cards
      </h2>

    </div>

    <div class="team-grid">

      <!-- CARD -->

      <div class="team-card">

        <div class="status-dot online"></div>

        <img
          src="https://i.pravatar.cc/150?img=11"
          alt=""
        />

        <h3>
          Sarah Johnson
        </h3>

        <p>
          UI/UX Designer
        </p>

        <div class="team-stats">

          <span>
            14 Projects
          </span>

          <span>
            96% Activity
          </span>

        </div>

        <button>
          View Profile
        </button>

      </div>

      <!-- CARD -->

      <div class="team-card">

        <div class="status-dot busy"></div>

        <img
          src="https://i.pravatar.cc/150?img=12"
          alt=""
        />

        <h3>
          Michael Lee
        </h3>

        <p>
          Frontend Developer
        </p>

        <div class="team-stats">

          <span>
            21 Projects
          </span>

          <span>
            89% Activity
          </span>

        </div>

        <button>
          View Profile
        </button>

      </div>

      <!-- CARD -->

      <div class="team-card">

        <div class="status-dot offline"></div>

        <img
          src="https://i.pravatar.cc/150?img=14"
          alt=""
        />

        <h3>
          Emma Watson
        </h3>

        <p>
          Product Manager
        </p>

        <div class="team-stats">

          <span>
            9 Projects
          </span>

          <span>
            78% Activity
          </span>

        </div>

        <button>
          View Profile
        </button>

      </div>

    </div>

  </section>

  <!-- =========================================================
ACTIVITY FEED
========================================================= -->

  <section class="component-section">

    <div class="section-title">

      <span>
        Live Activity
      </span>

      <h2>
        Workspace Activity Feed
      </h2>

    </div>

    <div class="activity-feed">

      <!-- ITEM -->

      <div class="activity-item">

        <div class="activity-icon">
          <i class="fa-solid fa-check"></i>
        </div>

        <div class="activity-content">

          <h4>
            Dashboard UI Updated
          </h4>

          <p>
            Sarah completed the analytics dashboard redesign.
          </p>

        </div>

        <span>
          2m ago
        </span>

      </div>

      <!-- ITEM -->

      <div class="activity-item">

        <div class="activity-icon purple">
          <i class="fa-solid fa-code"></i>
        </div>

        <div class="activity-content">

          <h4>
            New API Integrated
          </h4>

          <p>
            Michael pushed new authentication updates.
          </p>

        </div>

        <span>
          10m ago
        </span>

      </div>

      <!-- ITEM -->

      <div class="activity-item">

        <div class="activity-icon pink">
          <i class="fa-solid fa-message"></i>
        </div>

        <div class="activity-content">

          <h4>
            Team Discussion
          </h4>

          <p>
            Emma created a new project discussion thread.
          </p>

        </div>

        <span>
          28m ago
        </span>

      </div>

    </div>

  </section>

  <!-- =========================================================
TASK PANEL
========================================================= -->

  <section class="component-section">

    <div class="section-title">

      <span>
        Tasks
      </span>

      <h2>
        Task Assignment Panel
      </h2>

    </div>

    <div class="task-grid">

      <!-- TASK -->

      <div class="task-card">

        <div class="task-top">

          <span class="task-tag">
            Design
          </span>

          <span class="task-priority high">
            High
          </span>

        </div>

        <h3>
          Create Dashboard Wireframe
        </h3>

        <p>
          Build modern responsive dashboard layouts
          for analytics platform.
        </p>

        <div class="task-members">

          <img src="https://i.pravatar.cc/100?img=15" alt="">
          <img src="https://i.pravatar.cc/100?img=16" alt="">
          <img src="https://i.pravatar.cc/100?img=17" alt="">

        </div>

      </div>

      <!-- TASK -->

      <div class="task-card">

        <div class="task-top">

          <span class="task-tag">
            Development
          </span>

          <span class="task-priority medium">
            Medium
          </span>

        </div>

        <h3>
          Implement Team Authentication
        </h3>

        <p>
          Add Firebase authentication and
          role-based access control.
        </p>

        <div class="task-members">

          <img src="https://i.pravatar.cc/100?img=18" alt="">
          <img src="https://i.pravatar.cc/100?img=19" alt="">

        </div>

      </div>

    </div>

  </section>

  <!-- =========================================================
CHAT PREVIEW
========================================================= -->

  <section class="component-section">

    <div class="section-title">

      <span>
        Team Chat
      </span>

      <h2>
        Collaboration Messaging UI
      </h2>

    </div>

    <div class="chat-preview">

      <!-- MESSAGE -->

      <div class="message received">

        <img
          src="https://i.pravatar.cc/100?img=21"
          alt=""
        />

        <div class="message-box">

          <h4>
            Sarah
          </h4>

          <p>
            The new dashboard design is ready for review 🚀
          </p>

        </div>

      </div>

      <!-- MESSAGE -->

      <div class="message sent">

        <div class="message-box">

          <h4>
            You
          </h4>

          <p>
            Awesome! I'll check and push feedback soon.
          </p>

        </div>

      </div>

    </div>

  </section>

</main>

</body>
</html>