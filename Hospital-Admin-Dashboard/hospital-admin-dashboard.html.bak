<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MediCore — Hospital Admin Dashboard</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

  <!-- Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

  <!-- CSS -->
  <link rel="stylesheet" href="hospital-admin-dashboard.css" />
</head>

<body>

<div class="app-wrapper">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">

    <div class="logo">🏥 MediCore</div>

    <nav class="sidebar-nav" aria-label="Main Navigation">

      <a href="#" class="active" aria-current="page">
        <i class="fa-solid fa-chart-pie"></i> Dashboard
      </a>

      <a href="#"><i class="fa-solid fa-user-doctor"></i> Doctors</a>
      <a href="#"><i class="fa-solid fa-bed"></i> Patients</a>
      <a href="#"><i class="fa-solid fa-calendar-check"></i> Appointments</a>
      <a href="#"><i class="fa-solid fa-syringe"></i> Pharmacy</a>
      <a href="#"><i class="fa-solid fa-chart-line"></i> Analytics</a>
      <a href="#"><i class="fa-solid fa-gear"></i> Settings</a>

    </nav>

    <div class="user-card">
      <img src="https://i.pravatar.cc/150?img=12" alt="Admin profile picture">
      <h3>Dr. Emily Carter</h3>
      <p>Hospital Administrator</p>
      <button type="button">Manage Staff</button>
    </div>

  </aside>

  <!-- MAIN -->
  <main class="main">

    <!-- TOPBAR -->
    <header class="topbar">

      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
        <i class="fa-solid fa-bars"></i>
      </button>

      <div>
        <h1>Hospital Dashboard</h1>
        <p>Manage patients, doctors, appointments and analytics.</p>
      </div>

      <div class="top-actions">

        <label class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search patients..." />
        </label>

        <button class="notification-btn" type="button" aria-label="Notifications">
          <i class="fa-solid fa-bell"></i>
        </button>

      </div>

    </header>

    <!-- HERO -->
    <section class="hero">

      <div class="hero-content">
        <span class="hero-tag">Smart Healthcare Management</span>

        <h2>Real-Time Hospital <br> Operations 🏥</h2>

        <p>
          Monitor patient flow, manage staff schedules, track appointments and improve healthcare efficiency.
        </p>

        <div class="hero-buttons">
          <button class="primary-btn" type="button">Add Patient</button>
          <button class="secondary-btn" type="button">View Reports</button>
        </div>
      </div>

      <div class="hero-visual">

        <div class="visual-circle">
          <i class="fa-solid fa-heart-pulse"></i>
        </div>

        <div class="floating-card">👨‍⚕️ 84 Doctors Active</div>
        <div class="floating-card">🛏 324 Patients Admitted</div>
        <div class="floating-card">⚡ Emergency Unit Online</div>

      </div>

    </section>

    <!-- STATS -->
    <section class="stats-grid">

      <div class="stat-card purple">
        <h2>324</h2><p>Total Patients</p>
      </div>

      <div class="stat-card blue">
        <h2>84</h2><p>Doctors Available</p>
      </div>

      <div class="stat-card pink">
        <h2>52</h2><p>Appointments Today</p>
      </div>

      <div class="stat-card green">
        <h2>96%</h2><p>Recovery Rate</p>
      </div>

    </section>

    <!-- DOCTORS -->
    <section class="doctor-section">

      <div class="section-header">
        <h2>👨‍⚕️ Doctors On Duty</h2>
        <button type="button">View All</button>
      </div>

      <div class="doctor-grid">

        <div class="doctor-card">
          <div class="doctor-image"><i class="fa-solid fa-user-doctor"></i></div>
          <h3>Dr. John Smith</h3>
          <p>Cardiologist</p>
          <div class="doctor-footer">
            <span>12 Patients</span>
            <button type="button" class="manage-btn">Manage</button>
          </div>
        </div>

        <div class="doctor-card">
          <div class="doctor-image"><i class="fa-solid fa-user-doctor"></i></div>
          <h3>Dr. Sophia Lee</h3>
          <p>Neurologist</p>
          <div class="doctor-footer">
            <span>9 Patients</span>
            <button type="button" class="manage-btn">Manage</button>
          </div>
        </div>

        <div class="doctor-card">
          <div class="doctor-image"><i class="fa-solid fa-user-doctor"></i></div>
          <h3>Dr. David Miller</h3>
          <p>Orthopedic</p>
          <div class="doctor-footer">
            <span>15 Patients</span>
            <button type="button" class="manage-btn">Manage</button>
          </div>
        </div>

      </div>
    </section>

    <!-- APPOINTMENTS -->
    <section class="appointment-section">

      <div class="section-header">
        <h2>📅 Upcoming Appointments</h2>
      </div>

      <div class="appointment-list">

        <div class="appointment-item">
          <div class="appointment-left">
            <div class="appointment-icon"><i class="fa-solid fa-user"></i></div>
            <div>
              <h3>Emma Watson</h3>
              <p>Cardiology • 10:00 AM</p>
            </div>
          </div>
          <button class="join-btn" type="button">Open</button>
        </div>

        <div class="appointment-item">
          <div class="appointment-left">
            <div class="appointment-icon"><i class="fa-solid fa-user"></i></div>
            <div>
              <h3>Liam Carter</h3>
              <p>Neurology • 1:30 PM</p>
            </div>
          </div>
          <button class="join-btn" type="button">Open</button>
        </div>

        <div class="appointment-item">
          <div class="appointment-left">
            <div class="appointment-icon"><i class="fa-solid fa-user"></i></div>
            <div>
              <h3>Olivia Johnson</h3>
              <p>Orthopedic • 4:00 PM</p>
            </div>
          </div>
          <button class="join-btn" type="button">Open</button>
        </div>

      </div>

    </section>

  </main>

</div>

<script src="hospital-admin-dashboard.js"></script>

    <script src="../dist/shared.js"></script>
</body>
</html>