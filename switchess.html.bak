        <span class="card-tag tag-popular">Basic</span>
      </div>
      <div class="card-preview">
        <label class="text-indicator-switch">
          <input type="checkbox" checked />
          <span class="text-slider"></span>
        </label>
      </div>
      <p class="card-desc">Sleek status selector where the sliding switch itself displays text toggling between ON / OFF.</p>
      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('sc9', this)"><i class="fa-solid fa-code"></i> View Code</button>
        <button class="action-btn copy-btn" onclick="copyCode('sc9', this)"><i class="fa-solid fa-copy"></i> Copy</button>
      </div>
      <pre id="sc9" class="code-block"><code>&lt;label class="text-indicator-switch"&gt;
  &lt;input type="checkbox" checked /&gt;
  &lt;span class="text-slider"&gt;&lt;/span&gt;
&lt;/label&gt;</code></pre>
    </div>

    <div class="component-card" data-name="retro arcade pixel border toggle switch" data-cat="pro">
      <div class="card-top">
        <span class="card-label">Retro Switch</span>
        <span class="card-tag tag-pro">Pro</span>
      </div>
      <div class="card-preview">
        <label class="retro-arcade-switch">
          <input type="checkbox" />
          <span class="retro-slider"></span>
        </label>
      </div>
      <p class="card-desc">Neo-brutalist arcade pixel console layout with solid thick borders and dynamic neon red/green indicators.</p>
      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('sc10', this)"><i class="fa-solid fa-code"></i> View Code</button>
        <button class="action-btn copy-btn" onclick="copyCode('sc10', this)"><i class="fa-solid fa-copy"></i> Copy</button>
      </div>
      <pre id="sc10" class="code-block"><code>&lt;label class="retro-arcade-switch"&gt;
  &lt;input type="checkbox" /&gt;
  &lt;span class="retro-slider"&gt;&lt;/span&gt;
&lt;/label&gt;</code></pre>
    </div>

  </div>
</main>

