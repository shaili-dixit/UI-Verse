<main class="main-home">
  <div class="page-hero">
    <div class="page-hero-left">
      <div class="breadcrumb">
        <a href="index.html">Home</a>
        <i class="fa-solid fa-chevron-right"></i>
        <span>Switches V2</span>
      </div>
      <h1 class="page-title">Switch Components</h1>
      <p class="page-desc">Modern, interactive checkbox toggle switches built using pure CSS. Includes sleek glassy sliders, neumorphic pushes, cyberpunk terminal toggles, elastic curves, and 3D arcade buttons.</p>
      <div class="page-meta">
        <span class="meta-badge"><i class="fa-solid fa-layer-group"></i> 10 Styles</span>
        <span class="meta-badge"><i class="fa-solid fa-code"></i> HTML + CSS</span>
        <span class="meta-badge"><i class="fa-solid fa-mobile-screen"></i> Responsive</span>
      </div>
    </div>
    <div class="page-hero-right">
      <div class="hero-preview-toggles">
        <label class="ios-glass-switch">
          <input type="checkbox" checked />
          <span class="ios-slider"></span>
        </label>
        <label class="elastic-switch" style="margin-top: 10px;">
          <input type="checkbox" />
          <span class="elastic-slider"></span>
        </label>
      </div>
    </div>
  </div>

  <div class="toggles-grid" id="togglesGrid">

    <div class="component-card" data-name="ios glass blur toggle switch" data-cat="styled">
      <div class="card-top">
        <span class="card-label">iOS Glass Switch</span>
        <span class="card-tag tag-popular">Popular</span>
      </div>
      <div class="card-preview">
        <label class="ios-glass-switch">
          <input type="checkbox" checked />
          <span class="ios-slider"></span>
        </label>
      </div>
      <p class="card-desc">Sleek, transparent toggle slider utilizing backdrop blur filters and fine borders matching Apple design semantics.</p>
      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('sc1', this)"><i class="fa-solid fa-code"></i> View Code</button>
        <button class="action-btn copy-btn" onclick="copyCode('sc1', this)"><i class="fa-solid fa-copy"></i> Copy</button>
      </div>
      <pre id="sc1" class="code-block"><code>&lt;label class="ios-glass-switch"&gt;
  &lt;input type="checkbox" checked /&gt;
  &lt;span class="ios-slider"&gt;&lt;/span&gt;
&lt;/label&gt;</code></pre>
    </div>

    <div class="component-card" data-name="neumorphic recessed shadow toggle switch" data-cat="styled">
      <div class="card-top">
        <span class="card-label">Neumorphic Switch</span>
        <span class="card-tag tag-popular">Popular</span>
      </div>
      <div class="card-preview">
        <label class="neumorphic-switch">
          <input type="checkbox" />
          <span class="neu-slider"></span>
        </label>
      </div>
      <p class="card-desc">Deep recessed track container displaying convex / concave styling. Toggling triggers glowing dynamic gradients.</p>
      <div class="actions">
        <button class="action-btn view-btn" onclick="toggleCode('sc2', this)"><i class="fa-solid fa-code"></i> View Code</button>
        <button class="action-btn copy-btn" onclick="copyCode('sc2', this)"><i class="fa-solid fa-copy"></i> Copy</button>
      </div>
      <pre id="sc2" class="code-block"><code>&lt;label class="neumorphic-switch"&gt;
  &lt;input type="checkbox" /&gt;
  &lt;span class="neu-slider"&gt;&lt;/span&gt;
&lt;/label&gt;</code></pre>
    </div>

    <div class="component-card" data-name="cyberpunk neon terminal glitch toggle switch" data-cat="pro">
      <div class="card-top">
        <span class="card-label">Cyberpunk Switch</span>
        <span class="card-tag tag-pro">Pro</span>
      </div>
      <div class="card-preview">
        <label class="cyberpunk-switch">
          <input type="checkbox" checked />
          <span class="cyber-slider"></span>
        </label>
      </div>
      <p class="card-desc">Sharp terminal borders emitting cyan glowing filters on checked states. Fits modern gaming landing profiles.</p>
      <div class="actions">
