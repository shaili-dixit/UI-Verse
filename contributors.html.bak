<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="stylesheet" href="dist/shared.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contributors — UIverse</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="contributors.css" />
  </head>

<body>

  <!-- NOTE: This file is the canonical contributors page. It was created by migrating content
       from the legacy `contributorss.html` filename to a corrected `contributors.html` path.
       The legacy file now redirects here. -->

  <header class="navbar">
    <a href="index.html" class="logo-link">
      <div class="logo">⬡ UIverse</div>
    </a>
    <div class="nav-right">
      <a href="documentation.html" class="nav-btn outline-btn">Documentation</a>
      <a href="https://github.com/Tushar-sonawane06/UI-Verse" target="_blank" rel="noopener noreferrer" class="nav-btn primary-btn">
        <i class="fa-brands fa-github"></i> GitHub Project
      </a>
    </div>
  </header>

  <main class="contributors-main">
    <section class="contributors-hero">
      <div class="hero-badge"><i class="fa-solid fa-code-branch"></i> Open Source Community</div>
      <h1 class="hero-title">Project <span>Contributors</span></h1>
      <p class="hero-desc">Meet the amazing contributors helping build and improve the project through open-source collaboration.</p>
    </section>

    <section class="contributors-section">
      <div class="section-head">
        <span class="section-tag">CONTRIBUTORS</span>
        <h2>Core Contributors</h2>
      </div>

      <div class="contributors-grid" id="contributorsGrid">
        <div class="contributor-card">
          <div class="contributor-image">
            <img src="https://avatars.githubusercontent.com/u/9919?v=4" alt="Contributor Avatar" />
          </div>
          <div class="contributor-info">
            <h3>GitHub User</h3>
            <p>Open source contributor helping improve UIverse components and developer experience.</p>
            <div class="contributor-links">
              <a href="#"><i class="fa-brands fa-github"></i></a>
              <a href="#"><i class="fa-brands fa-linkedin"></i></a>
              <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-container">
      <div class="socials">
        <a href="https://github.com" target="_blank" title="GitHub"><i class="fab fa-github"></i></a>
        <a href="https://linkedin.com" target="_blank" title="LinkedIn"><i class="fab fa-linkedin"></i></a>
        <a href="https://twitter.com" target="_blank" title="Twitter"><i class="fab fa-x-twitter"></i></a>
      </div>
      <div class="footer-col">
        <h3>Explore</h3>
        <ul>
          <li><a href="button.html">Buttons</a></li>
          <li><a href="navbar.html">Navbars</a></li>
          <li><a href="cards.html">Cards</a></li>
          <li><a href="inputs.html">Inputs</a></li>
          <li><a href="forms.html">Forms</a></li>
        </ul>
      </div>
    </div>
  </footer>

  <script src="dist/shared.js"></script>
</body>

</html>
