<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="../dist/shared.css">
  <meta charset="UTF-8">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; connect-src 'self' https:; img-src 'self' data: https:; font-src 'self' data: https:; script-src 'self' https: 'unsafe-hashes'; script-src-attr 'unsafe-hashes'; style-src 'self' https: 'unsafe-hashes'; style-src-attr 'unsafe-hashes'">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Animated Search Bar UI</title>

  <!-- Font Awesome -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(135deg,#667eea,#764ba2);
      padding:20px;
    }

    .search-wrapper{
      width:100%;
      max-width:500px;
    }

    .title{
      text-align:center;
      color:#fff;
      font-size:32px;
      margin-bottom:25px;
      font-weight:bold;
    }

    .search-container{
      position:relative;
      width:100%;
      background:#fff;
      border-radius:60px;
      padding:8px;
      display:flex;
      align-items:center;
      box-shadow:0 10px 30px rgba(0,0,0,0.2);
      transition:0.4s ease;
    }

    .search-container:hover{
      transform:translateY(-3px);
    }

    .search-container input{
      flex:1;
      border:none;
      outline:none;
      padding:16px 20px;
      font-size:16px;
      border-radius:50px;
      background:transparent;
    }

    .search-container input::placeholder{
      color:#888;
    }

    .search-btn{
      width:55px;
      height:55px;
      border:none;
      border-radius:50%;
      background:#667eea;
      color:#fff;
      font-size:18px;
      cursor:pointer;
      transition:0.3s ease;
    }

    .search-btn:hover{
      background:#5a67d8;
      transform:scale(1.08);
    }

    /* Search Suggestions */

    .suggestions{
      margin-top:18px;
      background:#fff;
      border-radius:18px;
      overflow:hidden;
      box-shadow:0 8px 20px rgba(0,0,0,0.15);
    }

    .suggestions li{
      list-style:none;
      padding:15px 20px;
      cursor:pointer;
      transition:0.3s;
      display:flex;
      align-items:center;
      gap:12px;
      font-size:15px;
    }

    .suggestions li:hover{
      background:#f3f4ff;
      color:#667eea;
      padding-left:28px;
    }

    .suggestions i{
      color:#667eea;
    }

    /* Responsive */

    @media(max-width:500px){

      .title{
        font-size:24px;
      }

      .search-container input{
        font-size:14px;
      }

      .search-btn{
        width:50px;
        height:50px;
      }

    }

  </style>
</head>

<body>

  <div class="search-wrapper">

    <h1 class="title">Animated Search Bar</h1>

    <div class="search-container">

      <input 
        type="text"
        id="searchInput"
        placeholder="Search for anything..."
      >

      <button class="search-btn" id="searchBtn">

        <i class="fa-solid fa-magnifying-glass"></i>

      </button>

    </div>

    <!-- Search Suggestions -->

    <ul class="suggestions" id="suggestionsList">

      <li>
        <i class="fa-solid fa-fire"></i>
        Trending UI Designs
      </li>

      <li>
        <i class="fa-solid fa-code"></i>
        HTML CSS Projects
      </li>

      <li>
        <i class="fa-solid fa-laptop-code"></i>
        Frontend Developer
      </li>

      <li>
        <i class="fa-solid fa-palette"></i>
        UI/UX Inspiration
      </li>

      <li>
        <i class="fa-solid fa-rocket"></i>
        Modern Web Animation
      </li>

    </ul>

  </div>

    <script src="../dist/shared.js"></script>
</body>
</html>